@{
    ViewData["Title"] = "Cinema Approvals";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook Admin — Cinema Approvals</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
    <style>
        body { font-family:'DM Sans',sans-serif; }
        .brand { font-family:'Bebas Neue',sans-serif; letter-spacing:0.05em; }
        .cinput { width:100%;background:#1e1e1e;border:1px solid #2a2a2a;border-radius:8px;padding:10px 14px;color:#fff;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color 0.2s,box-shadow 0.2s; }
        .cinput:focus { border-color:#E50914;box-shadow:0 0 0 3px rgba(229,9,20,0.12); }
        .cinput::placeholder { color:#555; }
        textarea.cinput { resize:vertical;min-height:80px; }
        .slide-panel { transform:translateX(100%);transition:transform 0.35s cubic-bezier(0.4,0,0.2,1); }
        .slide-panel.open { transform:translateX(0); }
        .sidebar-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:80; }
        .sidebar-overlay.show { display:block; }
        #toast-container { position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none; }
        .toast { pointer-events:all;min-width:280px;max-width:340px;background:#141414;border:1px solid #2a2a2a;border-radius:12px;padding:14px 18px;display:flex;align-items:flex-start;gap:12px;box-shadow:0 8px 32px rgba(0,0,0,0.6);animation:toastIn 0.35s cubic-bezier(0.34,1.56,0.64,1) forwards;font-size:14px;color:#fff; }
        .toast.removing { animation:toastOut 0.25s ease forwards; }
        .toast-success { border-left:3px solid #22c55e; }
        .toast-error { border-left:3px solid #E50914; }
        .toast-warning { border-left:3px solid #f59e0b; }
        @@keyframes toastIn  { from{opacity:0;transform:translateX(100px);}to{opacity:1;transform:translateX(0);} }
        @@keyframes toastOut { from{opacity:1;transform:translateX(0);}to{opacity:0;transform:translateX(100px);} }
        @@keyframes fadeIn   { from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);} }
        .fade-in { animation:fadeIn 0.3s ease forwards; }
        @@keyframes spin { to{transform:rotate(360deg);} }
        .spinner { display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 0.7s linear infinite; }
    </style>
</head>
<body class="bg-[#0a0a0a] text-white min-h-screen">

<div id="toast-container"></div>

<!-- Navbar -->
<nav class="fixed top-0 left-0 right-0 h-14 bg-[#0a0a0a]/95 border-b border-[#2a2a2a] flex items-center px-4 sm:px-6 gap-4 z-50 backdrop-blur-sm">
    <button onclick="toggleSidebar()" class="sm:hidden text-[#888] text-xl p-1">☰</button>
    <span class="brand text-2xl text-[#E50914]">CINEBOOK</span>
    <span class="hidden sm:block text-xs text-[#2a2a2a]">|</span>
    <span class="hidden sm:block text-sm text-[#888]">Admin Panel</span>
    <div class="flex-1"></div>
    <span id="adminName" class="hidden sm:block text-sm text-[#888]"></span>
    <button onclick="logout()" class="text-sm text-[#888] border border-[#2a2a2a] rounded-md px-3 py-1.5 hover:border-[#555] hover:text-white transition-all">Sign Out</button>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<aside id="sidebar" class="fixed left-0 top-14 bottom-0 w-56 bg-[#141414] border-r border-[#2a2a2a] px-3 py-5 z-[100] flex flex-col gap-1 -translate-x-full sm:translate-x-0 transition-transform duration-300">
    <div class="text-xs text-[#555] tracking-widest px-3 pb-3">MANAGE</div>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/Admin/Movies">🎬 Movies</a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#E50914] bg-[#E50914]/10" href="/Admin/Approvals">🏟 Cinema Approvals</a>
    <div class="flex-1"></div>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/">🏠 Home</a>
</aside>

<div class="sm:ml-56 pt-14 flex min-h-screen">
    <div class="flex-1 p-4 sm:p-6 overflow-y-auto max-h-[calc(100vh-56px)]">

        <div class="mb-6">
            <h1 class="text-xl font-bold">Cinema Approvals</h1>
            <p class="text-sm text-[#888] mt-0.5">Review and approve cinema manager applications</p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-3 mb-6">
            <div class="bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 flex items-center gap-3">
                <div class="text-2xl">⏳</div>
                <div><div class="text-xl font-bold" id="pendingCount">0</div><div class="text-xs text-[#888]">Pending</div></div>
            </div>
            <div class="bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 flex items-center gap-3">
                <div class="text-2xl">✅</div>
                <div><div class="text-xl font-bold" id="approvedCount">0</div><div class="text-xs text-[#888]">Approved</div></div>
            </div>
            <div class="bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 flex items-center gap-3">
                <div class="text-2xl">❌</div>
                <div><div class="text-xl font-bold" id="rejectedCount">0</div><div class="text-xs text-[#888]">Rejected</div></div>
            </div>
        </div>

        <!-- Filter pills -->
        <div class="flex gap-2 mb-5 flex-wrap">
            <button class="px-4 py-1.5 rounded-full text-sm font-medium bg-[#E50914] text-white border border-[#E50914] transition-all filter-pill active" onclick="setFilter('all',this)">All</button>
            <button class="px-4 py-1.5 rounded-full text-sm font-medium text-[#888] border border-[#2a2a2a] bg-[#141414] hover:border-[#444] hover:text-white transition-all filter-pill" onclick="setFilter('Pending',this)">⏳ Pending</button>
            <button class="px-4 py-1.5 rounded-full text-sm font-medium text-[#888] border border-[#2a2a2a] bg-[#141414] hover:border-[#444] hover:text-white transition-all filter-pill" onclick="setFilter('Approved',this)">✅ Approved</button>
            <button class="px-4 py-1.5 rounded-full text-sm font-medium text-[#888] border border-[#2a2a2a] bg-[#141414] hover:border-[#444] hover:text-white transition-all filter-pill" onclick="setFilter('Rejected',this)">❌ Rejected</button>
        </div>

        <div id="cinemaList">
            <div class="text-center py-16 text-[#555]"><div class="text-4xl mb-3">🏟</div><div>Loading cinemas...</div></div>
        </div>
    </div>
</div>

<!-- Overlay -->
<div class="fixed inset-0 bg-black/60 z-40 opacity-0 pointer-events-none transition-opacity duration-300" id="overlay" onclick="closePanel()"></div>

<!-- Slide Panel -->
<div class="slide-panel fixed right-0 top-14 bottom-0 w-full sm:w-[500px] bg-[#141414] border-l border-[#2a2a2a] z-50 flex flex-col" id="slidePanel">
    <div class="p-5 border-b border-[#2a2a2a] flex items-center justify-between flex-shrink-0">
        <div>
            <div class="text-base font-semibold" id="panelCinemaName">Cinema Details</div>
            <div class="text-xs text-[#888] mt-0.5" id="panelManagerName"></div>
        </div>
        <button onclick="closePanel()" class="text-[#888] hover:text-white text-2xl leading-none transition-colors">✕</button>
    </div>

    <div class="flex-1 overflow-y-auto p-5">
        <!-- Status banner -->
        <div id="currentStatusBanner" class="rounded-xl px-4 py-3 mb-5 text-sm font-semibold"></div>

        <!-- Cinema Info -->
        <div class="mb-5">
            <div class="text-xs font-bold text-[#888] tracking-widest mb-3">CINEMA INFO</div>
            <div id="cinemaDetails" class="space-y-2"></div>
        </div>

        <!-- Manager Info -->
        <div class="mb-5">
            <div class="text-xs font-bold text-[#888] tracking-widest mb-3">MANAGER INFO</div>
            <div id="managerDetails" class="space-y-2"></div>
        </div>

        <!-- Maps link -->
        <div id="mapsLinkSection" class="hidden mb-5">
            <a id="mapsLink" href="#" target="_blank" class="inline-flex items-center gap-2 bg-[#1e1e1e] border border-[#2a2a2a] text-white text-sm px-4 py-2.5 rounded-lg hover:border-[#444] transition-all">
                📍 View on Google Maps →
            </a>
        </div>

        <!-- Rejection textarea -->
        <div id="rejectionBox" class="hidden mt-4">
            <label class="block text-xs font-medium text-[#999] mb-2">Rejection Reason *</label>
            <textarea class="cinput" id="rejectionReason" placeholder="Explain why this application is being rejected..."></textarea>
        </div>

        <div id="alreadyProcessed" class="hidden bg-[#1e1e1e] border border-[#2a2a2a] rounded-xl px-4 py-3 text-sm text-[#888] mt-3">
            This application has already been processed. You can re-review it below.
        </div>
    </div>

    <div class="p-4 border-t border-[#2a2a2a] flex gap-3 flex-shrink-0" id="panelFooter">
        <button id="approveBtn" onclick="processApproval(true)"
            class="flex-1 bg-green-700 hover:bg-green-800 text-white font-semibold text-sm py-2.5 rounded-lg transition-colors">
            ✅ Approve
        </button>
        <button id="rejectBtn" onclick="toggleRejectBox()"
            class="flex-1 bg-[#E50914]/10 text-[#f87171] border border-[#E50914]/30 hover:bg-[#E50914]/20 font-semibold text-sm py-2.5 rounded-lg transition-all">
            ❌ Reject
        </button>
    </div>
</div>

<script>
function showToast(msg, type='info', duration=4000) {
    const icons={success:'✓',error:'✕',info:'ℹ',warning:'⚠'};
    const colors={success:'#22c55e',error:'#E50914',info:'#3b82f6',warning:'#f59e0b'};
    const c=document.getElementById('toast-container');
    const t=document.createElement('div'); t.className=`toast toast-${type}`;
    t.innerHTML=`<div style="width:22px;height:22px;border-radius:50%;background:${colors[type]}20;border:1px solid ${colors[type]}50;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px;color:${colors[type]};font-weight:700;">${icons[type]}</div><div style="flex:1;line-height:1.5;">${msg}</div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#555;cursor:pointer;font-size:18px;padding:0;">✕</button>`;
    c.appendChild(t);
    setTimeout(()=>{t.classList.add('removing');setTimeout(()=>t.remove(),250);},duration);
}

function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('-translate-x-full');
    document.getElementById('sidebarOverlay').classList.toggle('show');
}

const token = localStorage.getItem('token');
const user = JSON.parse(localStorage.getItem('user') || '{}');
if (!token) window.location.href = '/Auth/Login';
if (user.role !== 'Admin') window.location.href = '/Home/Index';
document.getElementById('adminName').textContent = user.fullName || 'Admin';

let allCinemas = [], selectedCinema = null, rejectBoxOpen = false;
function authHeaders() { return {'Content-Type':'application/json','Authorization':`Bearer ${token}`}; }

async function loadCinemas() {
    try {
        const res = await fetch('/api/cinemas', { headers: authHeaders() });
        const data = await res.json();
        if (data.success) { allCinemas = data.data; updateStats(); renderCinemas(allCinemas); }
        else showToast('Failed to load cinemas', 'error');
    } catch { showToast('Network error loading cinemas', 'error'); }
}

function updateStats() {
    document.getElementById('pendingCount').textContent = allCinemas.filter(c => c.approvalStatus === 'Pending' || c.approvalStatus === 0).length;
    document.getElementById('approvedCount').textContent = allCinemas.filter(c => c.approvalStatus === 'Approved' || c.approvalStatus === 1).length;
    document.getElementById('rejectedCount').textContent = allCinemas.filter(c => c.approvalStatus === 'Rejected' || c.approvalStatus === 2).length;
}

function setFilter(f, el) {
    document.querySelectorAll('.filter-pill').forEach(p => { p.classList.remove('bg-[#E50914]','text-white','border-[#E50914]'); p.classList.add('text-[#888]','border-[#2a2a2a]','bg-[#141414]'); });
    el.classList.add('bg-[#E50914]','text-white','border-[#E50914]'); el.classList.remove('text-[#888]','border-[#2a2a2a]','bg-[#141414]');
    let filtered = allCinemas;
    if (f === 'Pending') filtered = allCinemas.filter(c => c.approvalStatus === 'Pending' || c.approvalStatus === 0);
    else if (f === 'Approved') filtered = allCinemas.filter(c => c.approvalStatus === 'Approved' || c.approvalStatus === 1);
    else if (f === 'Rejected') filtered = allCinemas.filter(c => c.approvalStatus === 'Rejected' || c.approvalStatus === 2);
    renderCinemas(filtered);
}

function getStatusInfo(s) {
    if (s === 'Pending' || s === 0) return { label:'⏳ Pending', cls:'text-yellow-400 bg-yellow-400/10 border-yellow-400/20' };
    if (s === 'Approved' || s === 1) return { label:'✅ Approved', cls:'text-green-400 bg-green-400/10 border-green-400/20' };
    return { label:'❌ Rejected', cls:'text-red-400 bg-red-400/10 border-red-400/20' };
}

function renderCinemas(cinemas) {
    const list = document.getElementById('cinemaList');
    if (!cinemas.length) { list.innerHTML=`<div class="text-center py-16 text-[#555]"><div class="text-4xl mb-3">🏟</div><div>No cinemas found</div></div>`; return; }
    list.innerHTML = cinemas.map(c => {
        const s = getStatusInfo(c.approvalStatus);
        return `<div class="fade-in bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 mb-3 flex gap-4 cursor-pointer hover:border-[#3a3a3a] hover:bg-[#1a1a1a] transition-all" onclick="selectCinema('${c.id}')" id="card-${c.id}">
            <div class="w-12 h-12 rounded-xl bg-[#222] flex-shrink-0 flex items-center justify-center overflow-hidden">
                ${c.cinemaLogo ? `<img src="${c.cinemaLogo}" class="w-full h-full object-cover rounded-xl" onerror="this.parentElement.textContent='🏟'" />` : '🏟'}
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between gap-2 mb-1">
                    <div class="font-semibold text-sm truncate">${c.cinemaName}</div>
                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full border flex-shrink-0 ${s.cls}">${s.label}</span>
                </div>
                <div class="text-xs text-[#888]">📍 ${c.city}, ${c.state}</div>
                <div class="text-xs text-[#888] mt-0.5">👤 ${c.managerName} • 📞 ${c.managerPhone}</div>
                <div class="text-xs text-[#555] mt-1">${new Date(c.registeredAt).toLocaleDateString()}</div>
            </div>
        </div>`;
    }).join('');
}

function detailRow(label, val) {
    return `<div class="flex gap-2 py-2.5 border-b border-[#1e1e1e] text-sm"><span class="text-[#888] w-28 flex-shrink-0">${label}</span><span class="font-medium">${val}</span></div>`;
}

function selectCinema(id) {
    selectedCinema = allCinemas.find(c => c.id === id);
    if (!selectedCinema) return;
    document.querySelectorAll('[id^="card-"]').forEach(c => c.classList.remove('border-[#E50914]','bg-[#E50914]/5'));
    document.getElementById(`card-${id}`)?.classList.add('border-[#E50914]','bg-[#E50914]/5');

    document.getElementById('panelCinemaName').textContent = selectedCinema.cinemaName;
    document.getElementById('panelManagerName').textContent = `Manager: ${selectedCinema.managerName}`;

    const banner = document.getElementById('currentStatusBanner');
    const s = selectedCinema.approvalStatus;
    if (s === 'Pending' || s === 0) { banner.style.cssText='background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.3);color:#fbbf24;'; banner.textContent='⏳ Awaiting your review'; }
    else if (s === 'Approved' || s === 1) { banner.style.cssText='background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);color:#4ade80;'; banner.textContent='✅ This cinema is approved and active'; }
    else { banner.style.cssText='background:rgba(229,9,20,0.1);border:1px solid rgba(229,9,20,0.3);color:#f87171;'; banner.textContent=`❌ Rejected — "${selectedCinema.rejectionReason || 'No reason'}`; }

    document.getElementById('cinemaDetails').innerHTML = [
        detailRow('Cinema Name', selectedCinema.cinemaName),
        detailRow('Address', selectedCinema.address),
        detailRow('City / State', `${selectedCinema.city}, ${selectedCinema.state} — ${selectedCinema.pinCode}`),
        detailRow('License No.', selectedCinema.licenseNumber),
        detailRow('Registered', new Date(selectedCinema.registeredAt).toLocaleString()),
    ].join('');
    document.getElementById('managerDetails').innerHTML = [
        detailRow('Full Name', selectedCinema.managerName),
        detailRow('Phone', selectedCinema.managerPhone),
    ].join('');

    if (selectedCinema.googleMapsLink) { document.getElementById('mapsLinkSection').classList.remove('hidden'); document.getElementById('mapsLink').href = selectedCinema.googleMapsLink; }
    else document.getElementById('mapsLinkSection').classList.add('hidden');

    document.getElementById('rejectionBox').classList.add('hidden');
    document.getElementById('rejectionReason').value = '';
    rejectBoxOpen = false;
    document.getElementById('approveBtn').style.opacity = '1';
    document.getElementById('approveBtn').onclick = () => processApproval(true);

    const isPending = s === 'Pending' || s === 0;
    document.getElementById('alreadyProcessed').classList.toggle('hidden', isPending);
    document.getElementById('approveBtn').textContent = isPending ? '✅ Approve' : '✅ Re-Approve';
    document.getElementById('rejectBtn').textContent = '❌ Reject';

    document.getElementById('slidePanel').classList.add('open');
    const ov = document.getElementById('overlay');
    ov.classList.remove('opacity-0','pointer-events-none'); ov.classList.add('opacity-100');
}

function closePanel() {
    document.getElementById('slidePanel').classList.remove('open');
    const ov = document.getElementById('overlay');
    ov.classList.add('opacity-0','pointer-events-none'); ov.classList.remove('opacity-100');
    document.querySelectorAll('[id^="card-"]').forEach(c => c.classList.remove('border-[#E50914]','bg-[#E50914]/5'));
    selectedCinema = null;
}

function toggleRejectBox() {
    rejectBoxOpen = !rejectBoxOpen;
    document.getElementById('rejectionBox').classList.toggle('hidden', !rejectBoxOpen);
    document.getElementById('rejectBtn').textContent = rejectBoxOpen ? 'Cancel' : '❌ Reject';
    document.getElementById('approveBtn').style.opacity = rejectBoxOpen ? '0.4' : '1';
    if (rejectBoxOpen) {
        document.getElementById('approveBtn').onclick = null;
        document.getElementById('rejectBtn').onclick = () => processApproval(false);
    } else {
        document.getElementById('approveBtn').onclick = () => processApproval(true);
        document.getElementById('rejectBtn').onclick = toggleRejectBox;
    }
}

async function processApproval(isApproved) {
    if (!selectedCinema) return;
    const reason = document.getElementById('rejectionReason').value.trim();
    if (!isApproved && !reason) { document.getElementById('rejectionReason').focus(); showToast('Please provide a rejection reason', 'warning'); return; }
    const btn = isApproved ? document.getElementById('approveBtn') : document.getElementById('rejectBtn');
    const origText = btn.textContent;
    btn.disabled = true; btn.textContent = 'Processing...';
    try {
        const res = await fetch(`/api/cinemas/${selectedCinema.id}/approve`, {
            method:'PUT', headers: authHeaders(),
            body: JSON.stringify({ isApproved, rejectionReason: isApproved ? null : reason })
        });
        const result = await res.json();
        if (result.success) {
            showToast(isApproved ? `✅ ${selectedCinema.cinemaName} approved!` : `❌ Cinema application rejected`, isApproved ? 'success' : 'info');
            await loadCinemas(); closePanel();
        } else { showToast(result.message || 'Failed', 'error'); }
    } catch { showToast('Something went wrong', 'error'); }
    finally { btn.disabled = false; btn.textContent = origText; }
}

function logout() { localStorage.clear(); window.location.href = '/Auth/Login'; }
loadCinemas();
</script>
</body>
</html>
