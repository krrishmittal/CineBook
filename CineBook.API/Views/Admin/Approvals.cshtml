@{
    ViewData["Title"] = "Cinema Approvals";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook Admin — Cinema Approvals</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --red: #E50914; --red-dark: #b20710;
            --bg: #0a0a0a; --surface: #141414;
            --surface2: #1e1e1e; --surface3: #242424;
            --border: #2a2a2a; --text: #ffffff; --muted: #888888;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; overflow-x: hidden; }
        .brand { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.05em; }

        .navbar {
            position: fixed; top: 0; left: 0; right: 0; height: 56px;
            background: rgba(10,10,10,0.97); border-bottom: 1px solid var(--border);
            display: flex; align-items: center; padding: 0 24px; gap: 16px; z-index: 200;
        }

        .sidebar {
            position: fixed; left: 0; top: 56px; bottom: 0; width: 220px;
            background: var(--surface); border-right: 1px solid var(--border);
            padding: 20px 12px; z-index: 100; display: flex; flex-direction: column; gap: 4px;
        }
        .nav-item {
            display: flex; align-items: center; gap: 10px; padding: 10px 12px;
            border-radius: 6px; font-size: 14px; font-weight: 500; color: var(--muted);
            cursor: pointer; transition: all 0.2s; text-decoration: none;
            border: none; background: none; width: 100%;
        }
        .nav-item:hover { background: var(--surface2); color: var(--text); }
        .nav-item.active { background: rgba(229,9,20,0.12); color: var(--red); }

        .main { margin-left: 220px; padding-top: 56px; display: flex; min-height: 100vh; }

        /* List Panel */
        .list-panel { flex: 1; padding: 24px; overflow-y: auto; max-height: calc(100vh - 56px); }

        /* Slide Panel */
        .slide-panel {
            width: 500px; background: var(--surface);
            border-left: 1px solid var(--border);
            position: fixed; right: -500px; top: 56px; bottom: 0;
            transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
            z-index: 150; display: flex; flex-direction: column;
        }
        .slide-panel.open { right: 0; }

        .overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.6);
            z-index: 140; opacity: 0; pointer-events: none; transition: opacity 0.3s;
        }
        .overlay.show { opacity: 1; pointer-events: all; }

        .panel-header {
            padding: 20px 24px; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
        }
        .panel-body { flex: 1; overflow-y: auto; padding: 24px; }
        .panel-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; gap: 10px; flex-shrink: 0; }

        /* Cinema Card */
        .cinema-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 10px; padding: 16px; margin-bottom: 10px;
            cursor: pointer; transition: all 0.2s;
            display: flex; align-items: flex-start; gap: 14px;
        }
        .cinema-card:hover { border-color: #3a3a3a; background: var(--surface2); }
        .cinema-card.selected { border-color: var(--red); background: rgba(229,9,20,0.05); }

        .cinema-logo {
            width: 48px; height: 48px; border-radius: 8px;
            background: var(--surface3); display: flex; align-items: center;
            justify-content: center; font-size: 22px; flex-shrink: 0;
            overflow: hidden;
        }

        /* Badges */
        .badge {
            display: inline-flex; align-items: center; padding: 2px 9px;
            border-radius: 20px; font-size: 11px; font-weight: 600;
        }
        .badge-pending { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
        .badge-approved { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.2); }
        .badge-rejected { background: rgba(229,9,20,0.15); color: #f87171; border: 1px solid rgba(229,9,20,0.2); }

        /* Stat cards */
        .stat-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 8px; padding: 16px 20px;
            display: flex; align-items: center; gap: 14px;
        }

        /* Filter pills */
        .filter-pill {
            padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 500;
            border: 1px solid var(--border); background: var(--surface); color: var(--muted);
            cursor: pointer; transition: all 0.2s; white-space: nowrap;
        }
        .filter-pill:hover { border-color: #444; color: var(--text); }
        .filter-pill.active { background: var(--red); border-color: var(--red); color: white; }

        /* Detail rows in panel */
        .detail-row {
            display: flex; gap: 10px; padding: 10px 0;
            border-bottom: 1px solid var(--border); font-size: 13px;
        }
        .detail-row:last-child { border-bottom: none; }
        .detail-label { color: var(--muted); min-width: 110px; flex-shrink: 0; }
        .detail-val { color: var(--text); font-weight: 500; }

        /* Action buttons */
        .btn-approve {
            flex: 1; background: #16a34a; color: white;
            font-family: 'DM Sans', sans-serif; font-weight: 600;
            font-size: 14px; padding: 11px; border: none; border-radius: 6px;
            cursor: pointer; transition: background 0.2s;
        }
        .btn-approve:hover { background: #15803d; }

        .btn-reject {
            flex: 1; background: rgba(229,9,20,0.15); color: #f87171;
            font-family: 'DM Sans', sans-serif; font-weight: 600;
            font-size: 14px; padding: 11px;
            border: 1px solid rgba(229,9,20,0.3); border-radius: 6px;
            cursor: pointer; transition: all 0.2s;
        }
        .btn-reject:hover { background: rgba(229,9,20,0.25); }

        .cinput {
            width: 100%; background: var(--surface2); border: 1px solid var(--border);
            border-radius: 6px; padding: 11px 14px; color: var(--text);
            font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none;
            transition: border-color 0.2s; resize: vertical; min-height: 80px;
        }
        .cinput:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(229,9,20,0.12); }

        .rejection-box { display: none; margin-top: 14px; }

        label { display: block; font-size: 12px; font-weight: 500; color: #999; margin-bottom: 5px; }

        .empty { text-align: center; padding: 60px 20px; color: var(--muted); }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .cinema-card { animation: fadeIn 0.3s ease forwards; }

        .section-title {
            font-size: 20px; font-weight: 700;
            display: flex; align-items: center; gap: 10px;
        }
        .section-title::before {
            content: ''; width: 3px; height: 20px;
            background: var(--red); border-radius: 2px;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <span class="brand" style="font-size:22px; color:var(--red);">CINEBOOK</span>
        <span style="font-size:12px; color:var(--border);">|</span>
        <span style="font-size:13px; color:var(--muted);">Admin Panel</span>
        <div style="flex:1;"></div>
        <span id="adminName" style="font-size:13px; color:var(--muted);"></span>
        <button onclick="logout()" style="background:none; border:1px solid var(--border); color:var(--muted); font-family:'DM Sans',sans-serif; font-size:13px; padding:6px 14px; border-radius:6px; cursor:pointer;">Sign Out</button>
    </nav>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div style="font-size:11px; color:var(--muted); letter-spacing:0.1em; padding:4px 12px 12px;">MANAGE</div>
        <a class="nav-item" href="/Admin/Movies">🎬 Movies</a>
        <a class="nav-item active" href="/Admin/Approvals">🏟 Cinema Approvals</a>
        <div style="flex:1;"></div>
        <a class="nav-item" href="/">🏠 Home</a>
    </aside>

    <div class="main">
        <div class="list-panel">

            <!-- Header -->
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
                <div>
                    <h1 style="font-size:22px; font-weight:700;">Cinema Approvals</h1>
                    <p style="font-size:13px; color:var(--muted); margin-top:2px;">Review and approve cinema manager applications</p>
                </div>
            </div>

            <!-- Stats -->
            <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:24px;">
                <div class="stat-card">
                    <div style="font-size:26px;">⏳</div>
                    <div>
                        <div style="font-size:22px; font-weight:700;" id="pendingCount">0</div>
                        <div style="font-size:12px; color:var(--muted);">Pending</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div style="font-size:26px;">✅</div>
                    <div>
                        <div style="font-size:22px; font-weight:700;" id="approvedCount">0</div>
                        <div style="font-size:12px; color:var(--muted);">Approved</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div style="font-size:26px;">❌</div>
                    <div>
                        <div style="font-size:22px; font-weight:700;" id="rejectedCount">0</div>
                        <div style="font-size:12px; color:var(--muted);">Rejected</div>
                    </div>
                </div>
            </div>

            <!-- Filter pills -->
            <div style="display:flex; gap:8px; margin-bottom:16px;">
                <div class="filter-pill active" onclick="setFilter('all', this)">All</div>
                <div class="filter-pill" onclick="setFilter('Pending', this)">⏳ Pending</div>
                <div class="filter-pill" onclick="setFilter('Approved', this)">✅ Approved</div>
                <div class="filter-pill" onclick="setFilter('Rejected', this)">❌ Rejected</div>
            </div>

            <!-- Cinema List -->
            <div id="cinemaList">
                <div class="empty">
                    <div style="font-size:40px; margin-bottom:12px;">🏟</div>
                    <div style="font-size:16px; font-weight:500;">Loading cinemas...</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Overlay -->
    <div class="overlay" id="overlay" onclick="closePanel()"></div>

    <!-- Slide Panel -->
    <div class="slide-panel" id="slidePanel">
        <div class="panel-header">
            <div>
                <div style="font-size:17px; font-weight:600;" id="panelCinemaName">Cinema Details</div>
                <div style="font-size:12px; color:var(--muted); margin-top:2px;" id="panelManagerName"></div>
            </div>
            <button onclick="closePanel()" style="background:none; border:none; color:var(--muted); font-size:22px; cursor:pointer;">✕</button>
        </div>

        <div class="panel-body">

            <!-- Status banner -->
            <div id="currentStatusBanner" style="border-radius:8px; padding:12px 16px; margin-bottom:20px; font-size:13px; font-weight:600;"></div>

            <!-- Cinema Details -->
            <div style="margin-bottom:20px;">
                <div style="font-size:13px; font-weight:600; color:var(--muted); letter-spacing:0.06em; margin-bottom:10px;">CINEMA INFO</div>
                <div id="cinemaDetails"></div>
            </div>

            <!-- Manager Details -->
            <div style="margin-bottom:20px;">
                <div style="font-size:13px; font-weight:600; color:var(--muted); letter-spacing:0.06em; margin-bottom:10px;">MANAGER INFO</div>
                <div id="managerDetails"></div>
            </div>

            <!-- Maps link -->
            <div id="mapsLinkSection" style="display:none; margin-bottom:20px;">
                <a id="mapsLink" href="#" target="_blank" style="
                    display:inline-flex; align-items:center; gap:8px;
                    background:var(--surface2); border:1px solid var(--border);
                    color:var(--text); text-decoration:none; font-size:13px;
                    padding:9px 16px; border-radius:6px; transition:border-color 0.2s;">
                    📍 View on Google Maps →
                </a>
            </div>

            <!-- Rejection reason input -->
            <div class="rejection-box" id="rejectionBox">
                <label>Rejection Reason *</label>
                <textarea class="cinput" id="rejectionReason"
                    placeholder="Explain why this application is being rejected..."></textarea>
            </div>

            <!-- Already processed message -->
            <div id="alreadyProcessed" style="display:none; background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:14px; font-size:13px; color:var(--muted); margin-top:8px;">
                This application has already been processed. You can re-review it using the buttons below.
            </div>

        </div>

        <div class="panel-footer" id="panelFooter">
            <button class="btn-approve" id="approveBtn" onclick="processApproval(true)">✅ Approve</button>
            <button class="btn-reject" id="rejectBtn" onclick="toggleRejectBox()">❌ Reject</button>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');

        if (!token) window.location.href = '/Auth/Login';
        if (user.role !== 'Admin') window.location.href = '/Home/Index';

        document.getElementById('adminName').textContent = user.fullName || 'Admin';

        let allCinemas = [];
        let selectedCinema = null;
        let rejectBoxOpen = false;

        function authHeaders() {
            return { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` };
        }

        // ── Load Cinemas ──────────────────────────────────────
        async function loadCinemas() {
            try {
                const res = await fetch('/api/cinemas', { headers: authHeaders() });
                const data = await res.json();

                if (data.success) {
                    allCinemas = data.data;
                    updateStats();
                    renderCinemas(allCinemas);
                }
            } catch {
                document.getElementById('cinemaList').innerHTML =
                    `<div class="empty"><div style="font-size:32px">⚠</div><div>Failed to load</div></div>`;
            }
        }

        function updateStats() {
            document.getElementById('pendingCount').textContent =
                allCinemas.filter(c => c.approvalStatus === 'Pending' || c.approvalStatus === 0).length;
            document.getElementById('approvedCount').textContent =
                allCinemas.filter(c => c.approvalStatus === 'Approved' || c.approvalStatus === 1).length;
            document.getElementById('rejectedCount').textContent =
                allCinemas.filter(c => c.approvalStatus === 'Rejected' || c.approvalStatus === 2).length;
        }

        function setFilter(filter, el) {
            document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
            el.classList.add('active');

            let filtered = allCinemas;
            if (filter === 'Pending') filtered = allCinemas.filter(c => c.approvalStatus === 'Pending' || c.approvalStatus === 0);
            else if (filter === 'Approved') filtered = allCinemas.filter(c => c.approvalStatus === 'Approved' || c.approvalStatus === 1);
            else if (filter === 'Rejected') filtered = allCinemas.filter(c => c.approvalStatus === 'Rejected' || c.approvalStatus === 2);

            renderCinemas(filtered);
        }

        function getStatusInfo(status) {
            if (status === 'Pending' || status === 0) return { label: '⏳ Pending', cls: 'badge-pending' };
            if (status === 'Approved' || status === 1) return { label: '✅ Approved', cls: 'badge-approved' };
            return { label: '❌ Rejected', cls: 'badge-rejected' };
        }

        function renderCinemas(cinemas) {
            const list = document.getElementById('cinemaList');

            if (!cinemas.length) {
                list.innerHTML = `<div class="empty"><div style="font-size:40px; margin-bottom:12px;">🏟</div><div style="font-size:16px; font-weight:500;">No cinemas found</div></div>`;
                return;
            }

            list.innerHTML = cinemas.map(c => {
                const s = getStatusInfo(c.approvalStatus);
                return `
                <div class="cinema-card" onclick="selectCinema('${c.id}')" id="card-${c.id}">
                    <div class="cinema-logo">
                        ${c.cinemaLogo
                            ? `<img src="${c.cinemaLogo}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" onerror="this.parentElement.textContent='🏟'" />`
                            : '🏟'}
                    </div>
                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:4px;">
                            <div style="font-size:15px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${c.cinemaName}</div>
                            <span class="badge ${s.cls}">${s.label}</span>
                        </div>
                        <div style="font-size:12px; color:var(--muted);">📍 ${c.city}, ${c.state}</div>
                        <div style="font-size:12px; color:var(--muted); margin-top:2px;">👤 ${c.managerName} • 📞 ${c.managerPhone}</div>
                        <div style="font-size:11px; color:#555; margin-top:4px;">Registered ${new Date(c.registeredAt).toLocaleDateString()}</div>
                    </div>
                </div>`;
            }).join('');
        }

        // ── Panel ─────────────────────────────────────────────
        function selectCinema(id) {
            selectedCinema = allCinemas.find(c => c.id === id);
            if (!selectedCinema) return;

            document.querySelectorAll('.cinema-card').forEach(c => c.classList.remove('selected'));
            document.getElementById(`card-${id}`)?.classList.add('selected');

            // Fill panel
            document.getElementById('panelCinemaName').textContent = selectedCinema.cinemaName;
            document.getElementById('panelManagerName').textContent = `Manager: ${selectedCinema.managerName}`;

            // Status banner
            const s = getStatusInfo(selectedCinema.approvalStatus);
            const banner = document.getElementById('currentStatusBanner');
            if (selectedCinema.approvalStatus === 'Pending' || selectedCinema.approvalStatus === 0) {
                banner.style.background = 'rgba(251,191,36,0.1)';
                banner.style.border = '1px solid rgba(251,191,36,0.3)';
                banner.style.color = '#fbbf24';
                banner.textContent = '⏳ Awaiting your review';
            } else if (selectedCinema.approvalStatus === 'Approved' || selectedCinema.approvalStatus === 1) {
                banner.style.background = 'rgba(34,197,94,0.1)';
                banner.style.border = '1px solid rgba(34,197,94,0.3)';
                banner.style.color = '#4ade80';
                banner.textContent = '✅ This cinema is approved and active';
            } else {
                banner.style.background = 'rgba(229,9,20,0.1)';
                banner.style.border = '1px solid rgba(229,9,20,0.3)';
                banner.style.color = '#f87171';
                banner.textContent = `❌ Rejected — "${selectedCinema.rejectionReason || 'No reason'}"`;
            }

            // Cinema details
            document.getElementById('cinemaDetails').innerHTML = `
                <div class="detail-row"><span class="detail-label">Cinema Name</span><span class="detail-val">${selectedCinema.cinemaName}</span></div>
                <div class="detail-row"><span class="detail-label">Address</span><span class="detail-val">${selectedCinema.address}</span></div>
                <div class="detail-row"><span class="detail-label">City / State</span><span class="detail-val">${selectedCinema.city}, ${selectedCinema.state} — ${selectedCinema.pinCode}</span></div>
                <div class="detail-row"><span class="detail-label">License No.</span><span class="detail-val">${selectedCinema.licenseNumber}</span></div>
                <div class="detail-row"><span class="detail-label">Registered</span><span class="detail-val">${new Date(selectedCinema.registeredAt).toLocaleString()}</span></div>
            `;

            // Manager details
            document.getElementById('managerDetails').innerHTML = `
                <div class="detail-row"><span class="detail-label">Full Name</span><span class="detail-val">${selectedCinema.managerName}</span></div>
                <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-val">${selectedCinema.managerPhone}</span></div>
            `;

            // Maps link
            if (selectedCinema.googleMapsLink) {
                document.getElementById('mapsLinkSection').style.display = 'block';
                document.getElementById('mapsLink').href = selectedCinema.googleMapsLink;
            } else {
                document.getElementById('mapsLinkSection').style.display = 'none';
            }

            // Reset rejection box
            document.getElementById('rejectionBox').style.display = 'none';
            document.getElementById('rejectionReason').value = '';
            rejectBoxOpen = false;

            // Footer buttons
            const isPending = selectedCinema.approvalStatus === 'Pending' || selectedCinema.approvalStatus === 0;
            document.getElementById('alreadyProcessed').style.display = isPending ? 'none' : 'block';
            document.getElementById('approveBtn').textContent = isPending ? '✅ Approve' : '✅ Re-Approve';
            document.getElementById('rejectBtn').textContent = '❌ Reject';

            // Open panel
            document.getElementById('slidePanel').classList.add('open');
            document.getElementById('overlay').classList.add('show');
        }

        function closePanel() {
            document.getElementById('slidePanel').classList.remove('open');
            document.getElementById('overlay').classList.remove('show');
            document.querySelectorAll('.cinema-card').forEach(c => c.classList.remove('selected'));
            selectedCinema = null;
        }

        function toggleRejectBox() {
            rejectBoxOpen = !rejectBoxOpen;
            document.getElementById('rejectionBox').style.display = rejectBoxOpen ? 'block' : 'none';
            document.getElementById('rejectBtn').textContent = rejectBoxOpen ? 'Cancel Reject' : '❌ Reject';

            if (rejectBoxOpen) {
                document.getElementById('approveBtn').onclick = null;
                document.getElementById('approveBtn').style.opacity = '0.4';
            } else {
                document.getElementById('approveBtn').onclick = () => processApproval(true);
                document.getElementById('approveBtn').style.opacity = '1';
            }
        }

        // ── Process Approval ──────────────────────────────────
        async function processApproval(isApproved) {
            if (!selectedCinema) return;

            const reason = document.getElementById('rejectionReason').value.trim();

            if (!isApproved && !reason) {
                document.getElementById('rejectionReason').focus();
                document.getElementById('rejectionReason').style.borderColor = 'var(--red)';
                return;
            }

            const btn = isApproved
                ? document.getElementById('approveBtn')
                : document.getElementById('rejectBtn');

            btn.disabled = true;
            btn.textContent = 'Processing...';

            try {
                const res = await fetch(`/api/cinemas/${selectedCinema.id}/approve`, {
                    method: 'PUT',
                    headers: authHeaders(),
                    body: JSON.stringify({
                        isApproved,
                        rejectionReason: isApproved ? null : reason
                    })
                });

                const result = await res.json();

                if (result.success) {
                    await loadCinemas();
                    closePanel();
                } else {
                    alert(result.message || 'Failed');
                }
            } catch {
                alert('Something went wrong');
            } finally {
                btn.disabled = false;
                btn.textContent = isApproved ? '✅ Approve' : '❌ Reject';
            }
        }

        // Hook reject confirm button
        document.getElementById('rejectBtn').addEventListener('click', function () {
            if (rejectBoxOpen) {
                processApproval(false);
            }
        });

        function logout() { localStorage.clear(); window.location.href = '/Auth/Login'; }

        loadCinemas();
    </script>
</body>
</html>
