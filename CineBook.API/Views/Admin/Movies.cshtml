@{
    ViewData["Title"] = "Movie Management";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook Admin — Movies</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
    <style>
        body { font-family:'DM Sans',sans-serif; }
        .brand { font-family:'Bebas Neue',sans-serif; letter-spacing:0.05em; }
        .cinput {
            width:100%; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:8px;
            padding:10px 14px; color:#fff; font-family:'DM Sans',sans-serif; font-size:14px; outline:none;
            transition:border-color 0.2s,box-shadow 0.2s;
        }
        .cinput:focus { border-color:#E50914; box-shadow:0 0 0 3px rgba(229,9,20,0.12); }
        .cinput::placeholder { color:#555; }
        select.cinput option { background:#1e1e1e; }
        textarea.cinput { resize:vertical; min-height:80px; }
        /* Toast */
        #toast-container { position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none; }
        .toast { pointer-events:all;min-width:280px;max-width:340px;background:#141414;border:1px solid #2a2a2a;border-radius:12px;padding:14px 18px;display:flex;align-items:flex-start;gap:12px;box-shadow:0 8px 32px rgba(0,0,0,0.6);animation:toastIn 0.35s cubic-bezier(0.34,1.56,0.64,1) forwards;font-size:14px;color:#fff; }
        .toast.removing { animation:toastOut 0.25s ease forwards; }
        .toast-success { border-left:3px solid #22c55e; }
        .toast-error   { border-left:3px solid #E50914; }
        .toast-info    { border-left:3px solid #3b82f6; }
        @@keyframes toastIn  { from{opacity:0;transform:translateX(100px);}to{opacity:1;transform:translateX(0);} }
        @@keyframes toastOut { from{opacity:1;transform:translateX(0);}to{opacity:0;transform:translateX(100px);} }
        @@keyframes fadeIn   { from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);} }
        .fade-in { animation:fadeIn 0.3s ease forwards; }
        .slide-panel { transform:translateX(100%); transition:transform 0.35s cubic-bezier(0.4,0,0.2,1); }
        .slide-panel.open { transform:translateX(0); }
        .sidebar-overlay { display:none; position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:80; }
        .sidebar-overlay.show { display:block; }
        @@keyframes spin { to{transform:rotate(360deg);} }
        .spinner { width:16px;height:16px;border:2px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 0.7s linear infinite;display:inline-block;vertical-align:middle; }

        /* ── Upload button ── */
        .upload-btn {
            display:inline-flex; align-items:center; gap:6px;
            background:#1e1e1e; border:1px solid #2a2a2a; border-radius:8px;
            padding:10px 14px; cursor:pointer; font-size:13px; color:#888;
            white-space:nowrap; transition:all 0.2s; flex-shrink:0;
            font-family:'DM Sans',sans-serif;
        }
        .upload-btn:hover { border-color:#E50914; color:white; }

        /* ── Poster preview ── */
        .poster-preview {
            width:70px; height:100px; border-radius:8px;
            object-fit:cover; border:1px solid #2a2a2a;
            display:none;
        }
        .upload-progress {
            height:3px; background:#2a2a2a; border-radius:2px;
            margin-top:6px; overflow:hidden; display:none;
        }
        .upload-progress-bar {
            height:100%; background:#E50914; border-radius:2px;
            width:0%; transition:width 0.3s; animation:uploadPulse 1s ease infinite;
        }
        @@keyframes uploadPulse { 0%,100%{opacity:1} 50%{opacity:0.5} }

        /* ── Pagination ── */
        .page-btn { min-width:36px;height:36px;border-radius:8px;font-size:13px;font-weight:600;border:1px solid #282828;background:#111;color:#777;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;padding:0 10px; }
        .page-btn:hover:not(:disabled) { border-color:#444;color:#fff;background:#1a1a1a; }
        .page-btn.active { background:#E50914;border-color:#E50914;color:#fff; }
        .page-btn:disabled { opacity:0.3;cursor:not-allowed; }
    </style>
</head>
<body class="bg-[#0a0a0a] text-white min-h-screen">

<div id="toast-container"></div>

<!-- Navbar -->
<nav class="fixed top-0 left-0 right-0 h-14 bg-[#0a0a0a]/95 border-b border-[#2a2a2a] flex items-center px-4 sm:px-6 gap-4 z-50 backdrop-blur-sm">
    <button id="sidebarToggle" onclick="toggleSidebar()" class="sm:hidden text-[#888] text-xl p-1">☰</button>
    <span class="brand text-2xl text-[#E50914]">CINEBOOK</span>
    <span class="hidden sm:block text-xs text-[#2a2a2a]">|</span>
    <span class="hidden sm:block text-sm text-[#888]">Admin Panel</span>
    <div class="flex-1"></div>
    <span id="adminName" class="hidden sm:block text-sm text-[#888]"></span>
    <button onclick="logout()" class="text-sm text-[#888] border border-[#2a2a2a] rounded-md px-3 py-1.5 hover:border-[#555] hover:text-white transition-all">Sign Out</button>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- Sidebar -->
<aside id="sidebar" class="fixed left-0 top-14 bottom-0 w-56 bg-[#141414] border-r border-[#2a2a2a] px-3 py-5 z-[100] flex flex-col gap-1
                           -translate-x-full sm:translate-x-0 transition-transform duration-300">
    <div class="text-xs text-[#555] tracking-widest px-3 pb-3">MANAGE</div>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#E50914] bg-[#E50914]/10" href="/Admin/Movies">🎬 Movies</a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/Admin/Approvals">🏟 Cinema Approvals</a>
    <div class="flex-1"></div>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/">🏠 Home</a>
</aside>

<!-- Main -->
<div class="sm:ml-56 pt-14 flex min-h-screen">
    <div class="flex-1 p-4 sm:p-6 overflow-y-auto max-h-[calc(100vh-56px)]">

        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
            <div>
                <h1 class="text-xl font-bold">Movie Management</h1>
                <p class="text-sm text-[#888] mt-0.5">Add, edit and manage movies</p>
            </div>
            <button onclick="openPanel()" class="bg-[#E50914] hover:bg-[#b20710] text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors w-full sm:w-auto">+ Add Movie</button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-3 mb-6">
            <div class="bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 flex items-center gap-3">
                <div class="text-3xl">🎬</div>
                <div><div class="text-xl font-bold" id="totalCount">0</div><div class="text-xs text-[#888]">Total</div></div>
            </div>
            <div class="bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 flex items-center gap-3">
                <div class="text-3xl">🟢</div>
                <div><div class="text-xl font-bold" id="showingCount">0</div><div class="text-xs text-[#888]">Showing</div></div>
            </div>
            <div class="bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 flex items-center gap-3">
                <div class="text-3xl">🔵</div>
                <div><div class="text-xl font-bold" id="comingCount">0</div><div class="text-xs text-[#888]">Coming</div></div>
            </div>
        </div>

        <!-- Search + Filter -->
        <div class="flex flex-col sm:flex-row gap-3 mb-5">
            <div class="relative flex-1">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[#555]">🔍</span>
                <input class="cinput pl-9" type="text" id="searchInput" placeholder="Search movies..." oninput="handleSearch()" />
            </div>
            <select class="cinput sm:w-44" id="statusFilter" onchange="handleFilter()">
                <option value="">All Status</option>
                <option value="NowShowing">Now Showing</option>
                <option value="ComingSoon">Coming Soon</option>
                <option value="Archived">Archived</option>
            </select>
        </div>

        <!-- Movie List -->
        <div id="movieList">
            <div class="text-center py-16 text-[#555]"><div class="text-4xl mb-3">🎬</div><div>Loading movies...</div></div>
        </div>

        <!-- ── Pagination Bar ── -->
        <div id="paginationBar" class="flex items-center justify-center gap-2 mt-10 flex-wrap"></div>
    </div>
</div>

<!-- Overlay -->
<div class="fixed inset-0 bg-black/60 z-40 opacity-0 pointer-events-none transition-opacity duration-300" id="overlay" onclick="closePanel()"></div>

<!-- Slide Panel -->
<div class="slide-panel fixed right-0 top-14 bottom-0 w-full sm:w-[480px] bg-[#141414] border-l border-[#2a2a2a] z-50 flex flex-col" id="slidePanel">
    <div class="p-5 border-b border-[#2a2a2a] flex items-center justify-between flex-shrink-0">
        <div>
            <div class="text-base font-semibold" id="panelTitle">Add Movie</div>
            <div class="text-xs text-[#888] mt-0.5" id="panelSubtitle">Fill in the movie details</div>
        </div>
        <button onclick="closePanel()" class="text-[#888] hover:text-white text-2xl leading-none transition-colors">✕</button>
    </div>

    <div class="flex-1 overflow-y-auto p-5">
        <div id="formError" class="hidden bg-[#E50914]/10 border border-[#E50914]/30 text-[#ff6b6b] rounded-lg px-4 py-2.5 text-sm mb-4"></div>
        <div id="formSuccess" class="hidden bg-green-500/10 border border-green-500/30 text-green-400 rounded-lg px-4 py-2.5 text-sm mb-4"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
                <label class="block text-xs font-medium text-[#999] mb-1.5">Movie Title *</label>
                <input class="cinput" type="text" id="fTitle" placeholder="e.g. Avengers: Endgame" />
            </div>
            <div class="sm:col-span-2">
                <label class="block text-xs font-medium text-[#999] mb-1.5">Description *</label>
                <textarea class="cinput" id="fDescription" placeholder="Movie synopsis..."></textarea>
            </div>
            <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">Language *</label>
                <input class="cinput" type="text" id="fLanguage" placeholder="e.g. English, Hindi" />
            </div>
            <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">Genre *</label>
                <input class="cinput" type="text" id="fGenre" placeholder="e.g. Action, Drama" />
            </div>
            <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">Certificate *</label>
                <select class="cinput" id="fCertificate">
                    <option value="">Select rating</option>
                    <option value="U">U — Universal</option>
                    <option value="UA">UA — Parental Guidance</option>
                    <option value="A">A — Adults Only</option>
                    <option value="S">S — Special</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">Director *</label>
                <input class="cinput" type="text" id="fDirector" placeholder="Director name" />
            </div>
            <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">Duration (min) *</label>
                <input class="cinput" type="number" id="fDuration" placeholder="e.g. 150" min="1" />
            </div>
            <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">Status *</label>
                <select class="cinput" id="fStatus">
                    <option value="ComingSoon">Coming Soon</option>
                    <option value="NowShowing">Now Showing</option>
                    <option value="Archived">Archived</option>
                </select>
            </div>
            <div class="sm:col-span-2">
                <label class="block text-xs font-medium text-[#999] mb-1.5">Cast *</label>
                <input class="cinput" type="text" id="fCast" placeholder="e.g. Robert Downey Jr., Chris Evans" />
            </div>
            <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">Release Date *</label>
                <input class="cinput" type="date" id="fReleaseDate" />
            </div>

            <!-- ── Poster URL + Upload ── -->
            <div class="sm:col-span-2">
                <label class="block text-xs font-medium text-[#999] mb-1.5">Movie Poster *</label>
                <div class="flex gap-2 items-center">
                    <input class="cinput" type="url" id="fPosterUrl" placeholder="https://... or upload below"
                           oninput="onPosterUrlInput()" />
                    <label for="posterFileInput" class="upload-btn" title="Upload image to Cloudinary">
                        <span id="uploadBtnIcon">📁</span>
                        <span id="uploadBtnText">Upload</span>
                    </label>
                    <input type="file" id="posterFileInput" accept="image/jpeg,image/png,image/webp"
                           style="display:none;" onchange="uploadPoster()" />
                </div>
                <!-- Progress bar -->
                <div class="upload-progress" id="uploadProgress">
                    <div class="upload-progress-bar" id="uploadProgressBar"></div>
                </div>
                <!-- Preview -->
                <div class="flex items-center gap-3 mt-3" id="posterPreviewWrap" style="display:none!important;">
                    <img id="posterPreviewImg" class="poster-preview" src="" alt="Poster preview" style="display:block;" />
                    <div>
                        <div class="text-xs text-green-400 font-semibold">✅ Uploaded to Cloudinary</div>
                        <div class="text-xs text-[#555] mt-0.5" id="posterPreviewName"></div>
                        <button onclick="clearPoster()" class="text-xs text-[#f87171] hover:text-red-400 mt-1 transition-colors">✕ Remove</button>
                    </div>
                </div>
                <div class="text-xs text-[#555] mt-1.5">Upload JPG/PNG/WEBP (max 5MB) or paste a URL directly</div>
            </div>

            <!-- ── Trailer URL ── -->
            <div class="sm:col-span-2">
                <label class="block text-xs font-medium text-[#999] mb-1.5">Trailer URL <span class="text-[#555]">(optional)</span></label>
                <input class="cinput" type="url" id="fTrailerUrl" placeholder="https://youtube.com/watch?v=..." />
                <div class="text-xs text-[#555] mt-1.5">Paste a YouTube link</div>
            </div>
        </div>

        <!-- Delete confirm (edit mode) -->
        <div id="deleteConfirm" class="hidden mt-5 bg-[#E50914]/8 border border-[#E50914]/20 rounded-xl p-4">
            <div class="text-sm font-semibold text-[#f87171] mb-2">⚠ Delete Movie</div>
            <div class="text-xs text-[#888] mb-3">This will soft delete the movie. Data is preserved.</div>
            <button onclick="deleteMovie()" class="w-full bg-red-700 hover:bg-red-800 text-white font-semibold text-sm py-2.5 rounded-lg transition-colors">Confirm Delete</button>
        </div>
    </div>

    <div class="p-4 border-t border-[#2a2a2a] flex gap-3 flex-shrink-0">
        <button onclick="closePanel()" class="flex-1 text-[#888] border border-[#2a2a2a] hover:border-[#555] hover:text-white rounded-lg py-2.5 text-sm font-medium transition-all">Cancel</button>
        <button id="saveBtn" onclick="saveMovie()" class="flex-[2] bg-[#E50914] hover:bg-[#b20710] text-white font-semibold text-sm py-2.5 rounded-lg transition-colors">Save Movie</button>
    </div>
</div>

<script>
function showToast(message, type = 'info', duration = 4000) {
    const icons = { success:'✓', error:'✕', info:'ℹ', warning:'⚠' };
    const colors = { success:'#22c55e', error:'#E50914', info:'#3b82f6', warning:'#f59e0b' };
    const c = document.getElementById('toast-container');
    const t = document.createElement('div');
    t.className = `toast toast-${type}`;
    t.innerHTML = `<div style="width:22px;height:22px;border-radius:50%;background:${colors[type]}20;border:1px solid ${colors[type]}50;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px;color:${colors[type]};font-weight:700;">${icons[type]}</div><div style="flex:1;line-height:1.5;">${message}</div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#555;cursor:pointer;font-size:18px;padding:0;flex-shrink:0;">✕</button>`;
    c.appendChild(t);
    setTimeout(() => { t.classList.add('removing'); setTimeout(() => t.remove(), 250); }, duration);
}

function toggleSidebar() {
    const s = document.getElementById('sidebar');
    const o = document.getElementById('sidebarOverlay');
    const open = !s.classList.contains('-translate-x-full');
    s.classList.toggle('-translate-x-full', open);
    o.classList.toggle('show', !open);
}

const token = localStorage.getItem('token');
if (!token) window.location.href = '/Auth/Login';
const user = JSON.parse(localStorage.getItem('user') || '{}');
if (user.role !== 'Admin') window.location.href = '/Home/Index';
document.getElementById('adminName').textContent = user.fullName || 'Admin';

let allMovies = [], editingId = null;
const statusMap = { 'ComingSoon':0, 'NowShowing':1, 'Archived':2 };
const statusReverseMap = { 0:'ComingSoon', 1:'NowShowing', 2:'Archived' };
const statusLabels = { 'NowShowing':'Now Showing', 'ComingSoon':'Coming Soon', 'Archived':'Archived' };
const statusColors = { 'NowShowing':'text-green-400 bg-green-400/10 border-green-400/20', 'ComingSoon':'text-blue-400 bg-blue-400/10 border-blue-400/20', 'Archived':'text-[#888] bg-[#888]/10 border-[#888]/20' };

// ── Pagination state ──
let currentPage = 1;
const PAGE_SIZE = 10;
let totalPages = 1;
let totalCount = 0;
const activeFilters = { search: '', status: '' };

function authHeaders() { return { 'Content-Type':'application/json', 'Authorization':`Bearer ${token}` }; }

// ── Upload Poster ─────────────────────────────────────
async function uploadPoster() {
    const input = document.getElementById('posterFileInput');
    const file = input.files[0];
    if (!file) return;

    if (file.size > 5 * 1024 * 1024) {
        showToast('File too large. Max 5MB.', 'error');
        input.value = '';
        return;
    }

    const reader = new FileReader();
    reader.onload = e => {
        document.getElementById('posterPreviewImg').src = e.target.result;
        document.getElementById('posterPreviewWrap').style.display = 'flex';
        document.getElementById('posterPreviewName').textContent = file.name;
    };
    reader.readAsDataURL(file);

    const progress = document.getElementById('uploadProgress');
    const progressBar = document.getElementById('uploadProgressBar');
    progress.style.display = 'block';
    progressBar.style.width = '30%';

    document.getElementById('uploadBtnIcon').textContent = '⏳';
    document.getElementById('uploadBtnText').textContent = 'Uploading...';

    try {
        const formData = new FormData();
        formData.append('file', file);

        progressBar.style.width = '60%';

        const res = await fetch('/api/images/upload', {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
            body: formData
        });

        const data = await res.json();
        progressBar.style.width = '100%';

        if (data.success) {
            document.getElementById('fPosterUrl').value = data.url;
            document.getElementById('posterPreviewImg').src = data.url;
            showToast('✅ Poster uploaded successfully!', 'success');
        } else {
            showToast(data.message || 'Upload failed', 'error');
            clearPoster();
        }
    } catch {
        showToast('Upload failed. Check your connection.', 'error');
        clearPoster();
    } finally {
        setTimeout(() => { progress.style.display = 'none'; progressBar.style.width = '0%'; }, 800);
        document.getElementById('uploadBtnIcon').textContent = '📁';
        document.getElementById('uploadBtnText').textContent = 'Upload';
        input.value = '';
    }
}

function onPosterUrlInput() {
    const url = document.getElementById('fPosterUrl').value.trim();
    if (url.startsWith('http')) {
        document.getElementById('posterPreviewImg').src = url;
        document.getElementById('posterPreviewImg').onerror = () => {
            document.getElementById('posterPreviewWrap').style.display = 'none';
        };
        document.getElementById('posterPreviewImg').onload = () => {
            document.getElementById('posterPreviewWrap').style.display = 'flex';
            document.getElementById('posterPreviewName').textContent = 'From URL';
        };
    } else if (!url) {
        document.getElementById('posterPreviewWrap').style.display = 'none';
    }
}

function clearPoster() {
    document.getElementById('fPosterUrl').value = '';
    document.getElementById('posterPreviewImg').src = '';
    document.getElementById('posterPreviewWrap').style.display = 'none';
    document.getElementById('posterFileInput').value = '';
}

// ── Movies ────────────────────────────────────────────
async function loadMovies(page = 1) {
    if (page === 1) {
        document.getElementById('movieList').innerHTML = `<div class="text-center py-16 text-[#555]"><div class="text-4xl mb-3">🎬</div><div>Loading movies...</div></div>`;
        document.getElementById('paginationBar').innerHTML = '';
    }

    try {
        const params = new URLSearchParams({ page, pageSize: PAGE_SIZE });
        if (activeFilters.search) params.set('search', activeFilters.search);
        if (activeFilters.status) params.set('status', activeFilters.status);

        const res = await fetch(`/api/movies/paged?${params}`, { headers: authHeaders() });
        const data = await res.json();

        if (data.success) {
            const paged = data.data;
            currentPage = paged.page;
            totalPages = paged.totalPages;
            totalCount = paged.totalCount;
            allMovies = paged.items.map(m => ({
                ...m,
                status: statusReverseMap[m.status] || m.status
            }));
            updateStats();
            renderMovies(allMovies);
            renderPagination();
        } else {
            showToast(data.message || 'Failed to load movies', 'error');
        }
    } catch (err) {
        console.error(err);
        showToast('Failed to load movies', 'error');
    }
}

function updateStats() {
    document.getElementById('totalCount').textContent = totalCount;
    document.getElementById('showingCount').textContent = allMovies.filter(m => m.status === 'NowShowing').length;
    document.getElementById('comingCount').textContent = allMovies.filter(m => m.status === 'ComingSoon').length;
}

function renderMovies(movies) {
    const list = document.getElementById('movieList');
    if (!movies.length) {
        list.innerHTML = `<div class="text-center py-16 text-[#555]"><div class="text-4xl mb-3">🎬</div><div class="text-base font-medium mb-1">No movies found</div><div class="text-sm">Add your first movie above</div></div>`;
        return;
    }
    list.innerHTML = movies.map(m => {
        const s = m.status; const clr = statusColors[s] || statusColors.Archived;
        return `<div class="fade-in bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 mb-3 flex gap-4 cursor-pointer hover:border-[#3a3a3a] hover:bg-[#1a1a1a] transition-all" onclick="selectMovie('${m.id}')" id="card-${m.id}">
            <div class="w-12 h-16 rounded-lg bg-[#222] flex-shrink-0 flex items-center justify-center overflow-hidden">
                ${m.posterUrl ? `<img src="${m.posterUrl}" class="w-full h-full object-cover rounded-lg" onerror="this.parentElement.innerHTML='🎬'" />` : '🎬'}
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2 mb-1">
                    <div class="font-semibold text-sm sm:text-base truncate">${m.title}</div>
                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full border flex-shrink-0 ${clr}">${statusLabels[s] || s}</span>
                </div>
                <div class="text-xs text-[#888]">${m.director} • ${m.durationTime} min • ${m.certificateRating}</div>
                <div class="text-xs text-[#555] mt-0.5 truncate">${m.genre}</div>
            </div>
        </div>`;
    }).join('');
}

// ── Pagination ────────────────────────────────────────
function renderPagination() {
    const bar = document.getElementById('paginationBar');
    if (totalPages <= 1) { bar.innerHTML = ''; return; }

    const pages = [];
    if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) pages.push(i);
    } else {
        pages.push(1);
        if (currentPage > 3) pages.push('…');
        for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) pages.push(i);
        if (currentPage < totalPages - 2) pages.push('…');
        pages.push(totalPages);
    }

    bar.innerHTML = `
        <button class="page-btn" onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>
            ← Prev
        </button>
        ${pages.map(p => p === '…'
            ? `<span class="page-btn" style="cursor:default;color:#444;border-color:#1a1a1a">…</span>`
            : `<button class="page-btn ${p === currentPage ? 'active' : ''}" onclick="goToPage(${p})">${p}</button>`
        ).join('')}
        <button class="page-btn" onclick="goToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>
            Next →
        </button>`;
}

function goToPage(page) {
    if (page < 1 || page > totalPages || page === currentPage) return;
    currentPage = page;
    loadMovies(page);
}

// ── Search & Filter ───────────────────────────────────
let searchTimeout = null;
function handleSearch() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
        activeFilters.search = document.getElementById('searchInput').value.trim();
        currentPage = 1;
        loadMovies(1);
    }, 400);
}

function handleFilter() {
    activeFilters.status = document.getElementById('statusFilter').value;
    currentPage = 1;
    loadMovies(1);
}

// ── Form Management ───────────────────────────────────
function openPanel(movie = null) {
    clearForm(); editingId = null;
    if (movie) {
        editingId = movie.id;
        document.getElementById('panelTitle').textContent = 'Edit Movie';
        document.getElementById('panelSubtitle').textContent = 'Update movie details';
        document.getElementById('saveBtn').textContent = 'Update Movie';
        document.getElementById('deleteConfirm').classList.remove('hidden');
        fillForm(movie);
    } else {
        document.getElementById('panelTitle').textContent = 'Add Movie';
        document.getElementById('panelSubtitle').textContent = 'Fill in the movie details';
        document.getElementById('saveBtn').textContent = 'Save Movie';
        document.getElementById('deleteConfirm').classList.add('hidden');
    }
    document.getElementById('slidePanel').classList.add('open');
    const ov = document.getElementById('overlay');
    ov.classList.remove('opacity-0','pointer-events-none');
    ov.classList.add('opacity-100');
}

function closePanel() {
    document.getElementById('slidePanel').classList.remove('open');
    const ov = document.getElementById('overlay');
    ov.classList.add('opacity-0','pointer-events-none');
    ov.classList.remove('opacity-100');
    document.querySelectorAll('[id^="card-"]').forEach(c => c.classList.remove('border-[#E50914]','bg-[#E50914]/5'));
    editingId = null;
}

function selectMovie(id) {
    const m = allMovies.find(x => x.id === id);
    if (!m) return;
    document.querySelectorAll('[id^="card-"]').forEach(c => c.classList.remove('border-[#E50914]','bg-[#E50914]/5'));
    document.getElementById(`card-${id}`)?.classList.add('border-[#E50914]','bg-[#E50914]/5');
    openPanel(m);
}

function clearForm() {
    ['fTitle','fDescription','fLanguage','fGenre','fDirector','fCast','fTrailerUrl'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('fCertificate').value = '';
    document.getElementById('fStatus').value = 'ComingSoon';
    document.getElementById('fDuration').value = '';
    document.getElementById('fReleaseDate').value = '';
    document.getElementById('formError').classList.add('hidden');
    document.getElementById('formSuccess').classList.add('hidden');
    clearPoster();
}

function fillForm(m) {
    document.getElementById('fTitle').value = m.title || '';
    document.getElementById('fDescription').value = m.description || '';
    document.getElementById('fLanguage').value = m.language || '';
    document.getElementById('fGenre').value = m.genre || '';
    document.getElementById('fCertificate').value = m.certificateRating || '';
    document.getElementById('fDirector').value = m.director || '';
    document.getElementById('fDuration').value = m.durationTime || '';
    document.getElementById('fCast').value = m.cast || '';
    document.getElementById('fStatus').value = statusReverseMap[m.status] || 'ComingSoon';
    document.getElementById('fPosterUrl').value = m.posterUrl || '';
    document.getElementById('fTrailerUrl').value = m.trailerUrl || '';
    if (m.releaseDate) document.getElementById('fReleaseDate').value = new Date(m.releaseDate).toISOString().split('T')[0];

    if (m.posterUrl) {
        document.getElementById('posterPreviewImg').src = m.posterUrl;
        document.getElementById('posterPreviewWrap').style.display = 'flex';
        document.getElementById('posterPreviewName').textContent = 'Current poster';
    }
}

function getFormData() {
    return {
        title: document.getElementById('fTitle').value.trim(),
        description: document.getElementById('fDescription').value.trim(),
        language: document.getElementById('fLanguage').value.trim(),
        genre: document.getElementById('fGenre').value.trim(),
        certificateRating: document.getElementById('fCertificate').value,
        director: document.getElementById('fDirector').value.trim(),
        durationTime: parseInt(document.getElementById('fDuration').value),
        cast: document.getElementById('fCast').value.trim(),
        releaseDate: document.getElementById('fReleaseDate').value,
        status: statusMap[document.getElementById('fStatus').value],
        posterUrl: document.getElementById('fPosterUrl').value.trim(),
        trailerUrl: document.getElementById('fTrailerUrl').value.trim() || null
    };
}

function validate(d) {
    if (!d.title) return 'Title is required';
    if (!d.description) return 'Description is required';
    if (!d.language) return 'Language is required';
    if (!d.genre) return 'Genre is required';
    if (!d.certificateRating) return 'Certificate rating is required';
    if (!d.director) return 'Director is required';
    if (!d.durationTime || d.durationTime < 1) return 'Valid duration required';
    if (!d.cast) return 'Cast is required';
    if (!d.releaseDate) return 'Release date is required';
    if (!d.posterUrl) return 'Poster is required — upload or paste a URL';
    return null;
}

async function saveMovie() {
    const data = getFormData();
    const err = validate(data);
    if (err) { showError(err); showToast(err, 'error'); return; }
    document.getElementById('formError').classList.add('hidden');
    const btn = document.getElementById('saveBtn');
    btn.disabled = true; btn.textContent = editingId ? 'Updating...' : 'Saving...';
    try {
        const url = editingId ? `/api/movies/${editingId}` : '/api/movies';
        const method = editingId ? 'PUT' : 'POST';
        const res = await fetch(url, { method, headers: authHeaders(), body: JSON.stringify(data) });
        const result = await res.json();
        if (result.success) {
            showToast(editingId ? '✅ Movie updated!' : '✅ Movie added!', 'success');
            await loadMovies(1);
            setTimeout(closePanel, 800);
        } else {
            showError(result.message || 'API Error');
            showToast(result.message || 'Failed to save movie', 'error');
        }
    } catch (e) {
        showError('Network error: ' + e.message);
        showToast('Network error. Please try again.', 'error');
    } finally {
        btn.disabled = false;
        btn.textContent = editingId ? 'Update Movie' : 'Save Movie';
    }
}

async function deleteMovie() {
    if (!editingId) return;
    if (!confirm('Are you sure you want to delete this movie?')) return;
    try {
        const res = await fetch(`/api/movies/${editingId}`, { method:'DELETE', headers: authHeaders() });
        const result = await res.json();
        if (result.success) { showToast('🗑 Movie deleted', 'info'); await loadMovies(1); closePanel(); }
        else showToast(result.message || 'Failed to delete', 'error');
    } catch { showToast('Failed to delete movie', 'error'); }
}

function showError(msg) {
    const el = document.getElementById('formError');
    el.textContent = msg; el.classList.remove('hidden');
}

function logout() { localStorage.clear(); window.location.href = '/Auth/Login'; }
loadMovies(1);
</script>
</body>
