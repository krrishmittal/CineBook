@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Forgot Password</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --red: #E50914;
            --red-dark: #b20710;
            --bg: #0a0a0a;
            --surface: #141414;
            --surface2: #1e1e1e;
            --border: #2a2a2a;
            --text: #ffffff;
            --muted: #888888;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }
        .brand { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.05em; }
        .bg-cinematic {
            position: fixed; inset: 0; z-index: 0;
            background:
                radial-gradient(ellipse 80% 60% at 70% 40%, rgba(229,9,20,0.12) 0%, transparent 70%),
                radial-gradient(ellipse 60% 80% at 20% 80%, rgba(229,9,20,0.06) 0%, transparent 60%),
                #0a0a0a;
        }
        .film-strip {
            position: fixed; left: 0; top: 0; bottom: 0; width: 48px;
            background: #111; border-right: 1px solid #1f1f1f;
            display: flex; flex-direction: column; align-items: center;
            padding: 12px 0; gap: 8px; z-index: 1;
        }
        .film-hole {
            width: 20px; height: 14px; background: #0a0a0a;
            border-radius: 3px; border: 1px solid #222; flex-shrink: 0;
        }
        .cinput {
            width: 100%; background: var(--surface2);
            border: 1px solid var(--border); border-radius: 6px;
            padding: 14px 16px; color: var(--text);
            font-family: 'DM Sans', sans-serif; font-size: 15px;
            transition: border-color 0.2s, box-shadow 0.2s; outline: none;
        }
        .cinput:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(229,9,20,0.15); }
        .cinput::placeholder { color: var(--muted); }
        .cbtn {
            width: 100%; background: var(--red); color: white;
            font-family: 'DM Sans', sans-serif; font-weight: 600;
            font-size: 15px; padding: 14px; border: none; border-radius: 6px;
            cursor: pointer; letter-spacing: 0.03em;
            transition: background 0.2s, transform 0.1s;
            position: relative; overflow: hidden;
        }
        .cbtn:hover { background: var(--red-dark); }
        .cbtn:active { transform: scale(0.99); }
        .cbtn:disabled { opacity: 0.7; cursor: not-allowed; }
        .cbtn::after {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(to bottom, rgba(255,255,255,0.08), transparent);
        }
        .card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 12px; padding: 40px; width: 100%; max-width: 420px;
            position: relative; z-index: 2;
        }
        .card::before {
            content: ''; position: absolute; top: 0; left: 24px; right: 24px;
            height: 2px; background: var(--red); border-radius: 0 0 4px 4px;
        }
        label {
            display: block; font-size: 13px; font-weight: 500;
            color: #aaa; margin-bottom: 6px; letter-spacing: 0.02em;
        }
        .alert {
            border-radius: 6px; padding: 12px 16px;
            font-size: 14px; display: none; margin-bottom: 16px;
        }
        .alert-error { background: rgba(229,9,20,0.1); border: 1px solid rgba(229,9,20,0.3); color: #ff6b6b; }
        .alert-success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: #4ade80; }
        .spinner {
            width: 18px; height: 18px;
            border: 2px solid rgba(255,255,255,0.3); border-top-color: white;
            border-radius: 50%; animation: spin 0.7s linear infinite;
            display: none; margin: 0 auto;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .card { animation: fadeUp 0.5s ease forwards; }

        /* Step indicator */
        .steps {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 28px;
        }
        .step {
            width: 28px; height: 28px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600;
            border: 1px solid var(--border);
            color: var(--muted);
            background: var(--surface2);
            transition: all 0.3s;
        }
        .step.active { background: var(--red); border-color: var(--red); color: white; }
        .step.done { background: #22c55e; border-color: #22c55e; color: white; }
        .step-line { flex: 1; height: 1px; background: var(--border); max-width: 40px; }
    </style>
</head>
<body>
    <div class="bg-cinematic"></div>
    <div class="film-strip">
        @for (int i = 0; i < 40; i++) { <div class="film-hole"></div> }
    </div>

    <div style="margin-left:48px; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px 20px; position:relative; z-index:2;">

        <div style="margin-bottom:28px; text-align:center;">
            <a href="/Auth/Login" style="text-decoration:none;">
                <div class="brand" style="font-size:42px; color:var(--red); line-height:1;">CINEBOOK</div>
                <div style="font-size:12px; color:var(--muted); letter-spacing:0.15em; margin-top:2px;">YOUR SEAT AWAITS</div>
            </a>
        </div>

        <div class="card">

            <!-- Step Indicator -->
            <div class="steps">
                <div class="step active" id="step1">1</div>
                <div class="step-line"></div>
                <div class="step" id="step2">2</div>
                <div class="step-line"></div>
                <div class="step" id="step3">✓</div>
            </div>

            <!-- Step 1: Enter Phone -->
            <div id="phoneStep">
                <h2 style="font-size:22px; font-weight:600; margin-bottom:6px;">Forgot password?</h2>
                <p style="font-size:14px; color:var(--muted); margin-bottom:24px;">Enter your phone number and we'll send an OTP on WhatsApp</p>

                <div class="alert alert-error" id="phoneError"></div>
                <div class="alert alert-success" id="phoneSuccess"></div>

                <div style="margin-bottom:18px;">
                    <label>Phone Number</label>
                    <input class="cinput" type="tel" id="phoneNumber"
                           placeholder="Enter your registered phone number"
                           maxlength="10" />
                </div>

                <button class="cbtn" id="sendOtpBtn" onclick="sendOtp()">
                    <span id="sendBtnText">Send OTP on WhatsApp</span>
                    <div class="spinner" id="sendSpinner"></div>
                </button>
            </div>

            <!-- Step 2: Enter OTP + New Password (hidden initially) -->
            <div id="resetStep" style="display:none;">
                <h2 style="font-size:22px; font-weight:600; margin-bottom:6px;">Reset password</h2>
                <p style="font-size:14px; color:var(--muted); margin-bottom:24px;">Enter the OTP sent to your WhatsApp and set a new password</p>

                <div class="alert alert-error" id="resetError"></div>

                <div style="display:flex; flex-direction:column; gap:16px;">
                    <div>
                        <label>OTP Code</label>
                        <input class="cinput" type="text" id="otp"
                               placeholder="Enter 6-digit OTP" maxlength="6" />
                    </div>
                    <div>
                        <label>New Password</label>
                        <input class="cinput" type="password" id="newPassword"
                               placeholder="Enter new password" />
                    </div>
                    <div>
                        <label>Confirm Password</label>
                        <input class="cinput" type="password" id="confirmPassword"
                               placeholder="Re-enter new password" />
                    </div>

                    <button class="cbtn" id="resetBtn" onclick="resetPassword()">
                        <span id="resetBtnText">Reset Password</span>
                        <div class="spinner" id="resetSpinner"></div>
                    </button>

                    <button onclick="goBack()"
                        style="background:none; border:none; color:var(--muted); font-family:'DM Sans',sans-serif; font-size:14px; cursor:pointer; text-align:center; padding:4px;">
                        ← Back to phone number
                    </button>
                </div>
            </div>

            <!-- Step 3: Success (hidden initially) -->
            <div id="successStep" style="display:none; text-align:center;">
                <div style="font-size:48px; margin-bottom:16px;">✅</div>
                <h2 style="font-size:22px; font-weight:600; margin-bottom:8px;">Password Reset!</h2>
                <p style="font-size:14px; color:var(--muted); margin-bottom:28px;">Your password has been updated successfully.</p>
                <a href="/Auth/Login" class="cbtn" style="display:block; text-decoration:none; text-align:center;">
                    Go to Login
                </a>
            </div>

        </div>

        <p style="margin-top:32px; font-size:12px; color:#444;">© 2026 CineBook. All rights reserved.</p>
    </div>

    <script>
        let phoneNum = '';

        function setLoading(btnId, spinnerId, textId, loading) {
            document.getElementById(textId).style.display = loading ? 'none' : 'block';
            document.getElementById(spinnerId).style.display = loading ? 'block' : 'none';
            document.getElementById(btnId).disabled = loading;
        }

        function showAlert(id, msg) {
            const el = document.getElementById(id);
            el.textContent = msg;
            el.style.display = 'block';
        }

        function hideAlert(id) {
            document.getElementById(id).style.display = 'none';
        }

        async function sendOtp() {
            const phone = document.getElementById('phoneNumber').value.trim();
            if (!phone || phone.length !== 10) {
                showAlert('phoneError', 'Please enter a valid 10-digit phone number');
                return;
            }

            hideAlert('phoneError');
            hideAlert('phoneSuccess');
            setLoading('sendOtpBtn', 'sendSpinner', 'sendBtnText', true);

            try {
                const res = await fetch('/api/Auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phoneNumber: phone })
                });

                const data = await res.json();

                if (data.success) {
                    phoneNum = phone;
                    showAlert('phoneSuccess', 'OTP sent to your WhatsApp!');

                    setTimeout(() => {
                        document.getElementById('phoneStep').style.display = 'none';
                        document.getElementById('resetStep').style.display = 'block';
                        document.getElementById('step1').classList.remove('active');
                        document.getElementById('step1').classList.add('done');
                        document.getElementById('step2').classList.add('active');
                    }, 1000);
                } else {
                    showAlert('phoneError', data.message || 'Failed to send OTP');
                }
            } catch {
                showAlert('phoneError', 'Something went wrong. Please try again.');
            } finally {
                setLoading('sendOtpBtn', 'sendSpinner', 'sendBtnText', false);
            }
        }

        async function resetPassword() {
            const otp = document.getElementById('otp').value.trim();
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (!otp || otp.length !== 6) {
                showAlert('resetError', 'Please enter the 6-digit OTP');
                return;
            }

            if (newPassword !== confirmPassword) {
                showAlert('resetError', 'Passwords do not match');
                return;
            }

            if (newPassword.length < 6) {
                showAlert('resetError', 'Password must be at least 6 characters');
                return;
            }

            hideAlert('resetError');
            setLoading('resetBtn', 'resetSpinner', 'resetBtnText', true);

            try {
                const res = await fetch('/api/Auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        phoneNumber: phoneNum,
                        otp: otp,
                        newPassword: newPassword,
                        confirmPassword: confirmPassword
                    })
                });

                const data = await res.json();

                if (data.success) {
                    document.getElementById('resetStep').style.display = 'none';
                    document.getElementById('successStep').style.display = 'block';
                    document.getElementById('step2').classList.remove('active');
                    document.getElementById('step2').classList.add('done');
                    document.getElementById('step3').classList.add('active');
                } else {
                    showAlert('resetError', data.message || 'Failed to reset password');
                }
            } catch {
                showAlert('resetError', 'Something went wrong. Please try again.');
            } finally {
                setLoading('resetBtn', 'resetSpinner', 'resetBtnText', false);
            }
        }

        function goBack() {
            document.getElementById('resetStep').style.display = 'none';
            document.getElementById('phoneStep').style.display = 'block';
            document.getElementById('step2').classList.remove('active');
            document.getElementById('step1').classList.remove('done');
            document.getElementById('step1').classList.add('active');
        }
    </script>
</body>
</html>
