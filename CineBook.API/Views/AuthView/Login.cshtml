@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --red: #E50914;
            --red-dark: #b20710;
            --bg: #0a0a0a;
            --surface: #141414;
            --surface2: #1e1e1e;
            --border: #2a2a2a;
            --text: #ffffff;
            --muted: #888888;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .brand {
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 0.05em;
        }

        /* Cinematic background */
        .bg-cinematic {
            position: fixed;
            inset: 0;
            z-index: 0;
            background:
                radial-gradient(ellipse 80% 60% at 70% 40%, rgba(229,9,20,0.12) 0%, transparent 70%),
                radial-gradient(ellipse 60% 80% at 20% 80%, rgba(229,9,20,0.06) 0%, transparent 60%),
                #0a0a0a;
        }

        /* Film strip decoration */
        .film-strip {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: 48px;
            background: #111;
            border-right: 1px solid #1f1f1f;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 12px 0;
            gap: 8px;
            z-index: 1;
        }

        .film-hole {
            width: 20px;
            height: 14px;
            background: #0a0a0a;
            border-radius: 3px;
            border: 1px solid #222;
            flex-shrink: 0;
        }

        /* Input styling */
        .cinput {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 14px 16px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .cinput:focus {
            border-color: var(--red);
            box-shadow: 0 0 0 3px rgba(229,9,20,0.15);
        }

        .cinput::placeholder { color: var(--muted); }

        /* Button */
        .cbtn {
            width: 100%;
            background: var(--red);
            color: white;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            font-size: 15px;
            padding: 14px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            letter-spacing: 0.03em;
            transition: background 0.2s, transform 0.1s;
            position: relative;
            overflow: hidden;
        }

        .cbtn:hover { background: var(--red-dark); }
        .cbtn:active { transform: scale(0.99); }

        .cbtn::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(255,255,255,0.08), transparent);
        }

        /* Card */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            position: relative;
            z-index: 2;
        }

        /* Red accent line on card */
        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 24px; right: 24px;
            height: 2px;
            background: var(--red);
            border-radius: 0 0 4px 4px;
        }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--muted);
            font-size: 13px;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        /* Alert */
        .alert {
            background: rgba(229,9,20,0.1);
            border: 1px solid rgba(229,9,20,0.3);
            border-radius: 6px;
            padding: 12px 16px;
            font-size: 14px;
            color: #ff6b6b;
            display: none;
        }

        /* Label */
        label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #aaa;
            margin-bottom: 6px;
            letter-spacing: 0.02em;
        }

        /* Loading spinner */
        .spinner {
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            display: none;
            margin: 0 auto;
        }

        @@keyframes spin { to { transform: rotate(360deg); } }

        /* Fade in animation */
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .card { animation: fadeUp 0.5s ease forwards; }

        /* Password toggle */
        .input-wrap { position: relative; }
        .toggle-pw {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--muted);
            cursor: pointer;
            padding: 0;
            font-size: 18px;
            line-height: 1;
        }
        .toggle-pw:hover { color: #ccc; }
    </style>
</head>
<body>

    <!-- Cinematic background -->
    <div class="bg-cinematic"></div>

    <!-- Film strip left -->
    <div class="film-strip">
        @for (int i = 0; i < 40; i++)
        {
            <div class="film-hole"></div>
        }
    </div>

    <!-- Main content -->
    <div style="margin-left: 48px; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; position: relative; z-index: 2;">

        <!-- Logo -->
        <div style="margin-bottom: 32px; text-align: center;">
            <div class="brand" style="font-size: 42px; color: var(--red); line-height: 1;">CINEBOOK</div>
            <div style="font-size: 12px; color: var(--muted); letter-spacing: 0.15em; margin-top: 2px;">YOUR SEAT AWAITS</div>
        </div>

        <!-- Card -->
        <div class="card">
            <h2 style="font-size: 22px; font-weight: 600; margin-bottom: 6px;">Welcome back</h2>
            <p style="font-size: 14px; color: var(--muted); margin-bottom: 28px;">Sign in to continue booking</p>

            <!-- Error alert -->
            <div class="alert" id="errorAlert"></div>

            <!-- Form -->
            <form id="loginForm" style="display: flex; flex-direction: column; gap: 18px; margin-top: 8px;">

                <div>
                    <label>Username or Phone</label>
                    <input class="cinput" type="text" id="userNameOrPhone"
                           placeholder="Enter username or phone number" required />
                </div>

                <div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                        <label style="margin-bottom: 0;">Password</label>
                        <a href="/Auth/ForgotPassword"
                           style="font-size: 13px; color: var(--red); text-decoration: none;">
                            Forgot password?
                        </a>
                    </div>
                    <div class="input-wrap">
                        <input class="cinput" type="password" id="password"
                               placeholder="Enter your password" required style="padding-right: 44px;" />
                        <button type="button" class="toggle-pw" onclick="togglePassword()">👁</button>
                    </div>
                </div>

                <button type="submit" class="cbtn" id="submitBtn">
                    <span id="btnText">Sign In</span>
                    <div class="spinner" id="spinner"></div>
                </button>

            </form>

            <!-- Divider -->
            <div class="divider" style="margin: 24px 0;">or</div>

            <!-- Register link -->
            <p style="text-align: center; font-size: 14px; color: var(--muted);">
                New to CineBook?
                <a href="/Auth/Register"
                   style="color: var(--red); text-decoration: none; font-weight: 500;">
                    Create an account
                </a>
            </p>
        </div>

        <!-- Footer -->
        <p style="margin-top: 32px; font-size: 12px; color: #444;">
            © 2026 CineBook. All rights reserved.
        </p>
    </div>

    <script>
        function togglePassword() {
            const pw = document.getElementById('password');
            pw.type = pw.type === 'password' ? 'text' : 'password';
        }

        function showError(msg) {
            const el = document.getElementById('errorAlert');
            el.textContent = msg;
            el.style.display = 'block';
        }

        function hideError() {
            document.getElementById('errorAlert').style.display = 'none';
        }

        function setLoading(loading) {
            document.getElementById('btnText').style.display = loading ? 'none' : 'block';
            document.getElementById('spinner').style.display = loading ? 'block' : 'none';
            document.getElementById('submitBtn').disabled = loading;
        }

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideError();
            setLoading(true);

            const payload = {
                userNameorPhone: document.getElementById('userNameOrPhone').value.trim(),
                password: document.getElementById('password').value
            };

            try {
                const res = await fetch('/api/Auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await res.json();

                if (data.success) {
                    localStorage.setItem('token', data.data.token);
                    localStorage.setItem('refreshToken', data.data.refreshToken);
                    localStorage.setItem('user', JSON.stringify({
                        userId: data.data.userId,
                        fullName: data.data.fullName,
                        role: data.data.role
                    }));

                    // Redirect based on role
                    const role = data.data.role;
                    if (role === 'Admin') window.location.href = '/Admin/Dashboard';
                    else if (role === 'CinemaManager') window.location.href = '/Manager/Dashboard';
                    else window.location.href = '/Home/Index';
                } else {
                    showError(data.message || 'Login failed. Please try again.');
                }
            } catch (err) {
                showError('Something went wrong. Please try again.');
            } finally {
                setLoading(false);
            }
        });
    </script>
</body>
</html>
