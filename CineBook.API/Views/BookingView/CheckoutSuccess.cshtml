@* ─────── BookingConfirmed.cshtml ─────── *@
@{
    ViewData["Title"] = "Booking Confirmed";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Booking Confirmed!</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body{font-family:'Outfit',sans-serif;}
        #toast-container{position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none;}
        .toast{pointer-events:all;min-width:260px;max-width:340px;background:#141414;border:1px solid #2a2a2a;border-radius:12px;padding:14px 18px;display:flex;align-items:flex-start;gap:12px;box-shadow:0 8px 32px rgba(0,0,0,.6);animation:tIn .35s cubic-bezier(.34,1.56,.64,1) forwards;font-size:14px;color:#fff;}
        .toast.removing{animation:tOut .25s ease forwards;}
        .toast-success{border-left:3px solid #22c55e;}.toast-error{border-left:3px solid #E50914;}
        @@keyframes tIn{from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)}}
        @@keyframes tOut{from{opacity:1;transform:translateX(0)}to{opacity:0;transform:translateX(100px)}}
        @@keyframes pop{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}
        .pop{animation:pop .5s cubic-bezier(.175,.885,.32,1.275);}
        @@keyframes spin{to{transform:rotate(360deg)}}
        .spinner{width:36px;height:36px;border:3px solid rgba(255,255,255,.1);border-top-color:#E50914;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto;}
    </style>
</head>
<body class="bg-[#080808] text-[#f5f5f5] min-h-screen flex items-center justify-center p-4">
<div id="toast-container"></div>

<!-- Loading -->
<div id="loadingCard" class="w-full max-w-md bg-[#111] border border-[#282828] rounded-2xl p-12 text-center">
    <div class="spinner mb-5"></div>
    <div class="text-lg font-semibold mb-2">Confirming your booking...</div>
    <div class="text-sm text-[#777]">Please wait while we process your payment</div>
</div>

<!-- Success -->
<div id="successCard" class="hidden w-full max-w-md bg-[#111] border border-[#282828] rounded-2xl p-8 sm:p-12 text-center">
    <div class="pop w-20 h-20 rounded-full bg-green-500/15 border-2 border-green-500/30 flex items-center justify-center text-4xl mx-auto mb-6">🎉</div>
    <h1 class="text-2xl sm:text-3xl font-bold mb-2">Booking Confirmed!</h1>
    <p class="text-sm text-[#777] mb-6">Your tickets have been booked successfully. Enjoy the movie!</p>
    <div class="bg-[#E50914]/8 border border-[#E50914]/20 rounded-xl p-4 mb-5">
        <div class="text-xs text-[#888] tracking-widest mb-1.5">BOOKING REFERENCE</div>
        <div class="text-2xl font-bold text-[#E50914] tracking-widest" id="bookingRef">--</div>
    </div>
    <div class="text-sm text-[#777] leading-loose mb-8" id="bookingDetails"></div>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/Bookings" class="flex-1 bg-[#1a1a1a] hover:bg-[#222] border border-[#282828] hover:border-[#444] text-white font-semibold text-sm py-3 rounded-xl transition-all text-center">🎟 My Bookings</a>
        <a href="/" class="flex-1 bg-[#E50914] hover:bg-[#b20710] text-white font-semibold text-sm py-3 rounded-xl transition-all text-center">🎬 Browse More</a>
    </div>
</div>

<!-- Error -->
<div id="errorCard" class="hidden w-full max-w-md bg-[#111] border border-[#282828] rounded-2xl p-12 text-center">
    <div class="text-6xl mb-5">⚠️</div>
    <h1 class="text-2xl font-bold mb-2 text-[#f87171]">Confirmation Failed</h1>
    <p class="text-sm text-[#777] mb-7" id="errorMsg">Payment was received but booking confirmation failed. Please contact support.</p>
    <a href="/Bookings" class="bg-[#E50914] hover:bg-[#b20710] text-white font-semibold text-sm px-7 py-3 rounded-xl inline-block transition-all">Check My Bookings</a>
</div>

<script>
function showToast(msg,type='info',duration=4000){const icons={success:'✓',error:'✕'};const colors={success:'#22c55e',error:'#E50914'};const c=document.getElementById('toast-container');const t=document.createElement('div');t.className=`toast toast-${type}`;t.innerHTML=`<div style="width:22px;height:22px;border-radius:50%;background:${colors[type]}20;border:1px solid ${colors[type]}50;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px;color:${colors[type]};font-weight:700;">${icons[type]||'ℹ'}</div><div style="flex:1;line-height:1.5;">${msg}</div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#555;cursor:pointer;font-size:18px;padding:0;">✕</button>`;c.appendChild(t);setTimeout(()=>{t.classList.add('removing');setTimeout(()=>t.remove(),250);},duration);}

const token=localStorage.getItem('token');
const params=new URLSearchParams(window.location.search);
const bookingId=params.get('bookingId');const sessionId=params.get('session_id');
if(!token||!bookingId||!sessionId)window.location.href='/';

async function confirmPayment(){
    try{
        const res=await fetch('/api/checkout/confirm-payment',{method:'POST',headers:{'Content-Type':'application/json','Authorization':`Bearer ${token}`},body:JSON.stringify({bookingId,sessionId})});
        const data=await res.json();
        document.getElementById('loadingCard').style.display='none';
        if(data.success){
            const b=data.data;
            document.getElementById('bookingRef').textContent=b.bookingReference;
            const startParts=b.showtimeStart?.split('T');const datePart=startParts?.[0]??'';const timePart=startParts?.[1]?.substring(0,5)??'';
            const[h,m]=timePart.split(':');const hour=parseInt(h);const ampm=hour>=12?'pm':'am';const h12=hour%12||12;
            const[yr,mo,dy]=datePart.split('-');
            const dateStr=datePart?new Date(parseInt(yr),parseInt(mo)-1,parseInt(dy)).toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long'}):'';
            document.getElementById('bookingDetails').innerHTML=`🎬 ${b.movieTitle}<br>🏟 ${b.cinemaName} • ${b.hallName}<br>📅 ${dateStr}<br>⏰ ${h12}:${m} ${ampm}<br>🪑 ${b.seats.map(s=>`${s.row}${s.seatNumber}`).join(', ')}<br><strong style="color:#E50914;">₹${b.totalAmount} Paid</strong>`;
            document.getElementById('successCard').classList.remove('hidden');
            showToast('🎉 Booking confirmed!','success',5000);
        }else{document.getElementById('errorMsg').textContent=data.message||'Booking confirmation failed';document.getElementById('errorCard').classList.remove('hidden');showToast('Booking confirmation failed','error');}
    }catch{document.getElementById('loadingCard').style.display='none';document.getElementById('errorMsg').textContent='Something went wrong';document.getElementById('errorCard').classList.remove('hidden');showToast('Something went wrong','error');}
}
confirmPayment();
</script>
</body>
</html>
