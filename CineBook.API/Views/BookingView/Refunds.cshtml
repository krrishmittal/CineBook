@{
    ViewData["Title"] = "Refunds";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Refunds</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
    <style>
        body{font-family:'DM Sans',sans-serif;}.brand{font-family:'Bebas Neue',sans-serif;letter-spacing:.05em;}
        .cinput{width:100%;background:#1e1e1e;border:1px solid #2a2a2a;border-radius:8px;padding:10px 14px;color:#fff;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color .2s;}
        .cinput:focus{border-color:#E50914;}
        textarea.cinput{resize:none;min-height:70px;}
        .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:80;}
        .sidebar-overlay.show{display:block;}
        #toast-container{position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none;}
        .toast{pointer-events:all;min-width:260px;max-width:340px;background:#141414;border:1px solid #2a2a2a;border-radius:12px;padding:14px 18px;display:flex;align-items:flex-start;gap:12px;box-shadow:0 8px 32px rgba(0,0,0,.6);animation:tIn .35s cubic-bezier(.34,1.56,.64,1) forwards;font-size:14px;color:#fff;}
        .toast.removing{animation:tOut .25s ease forwards;}
        .toast-success{border-left:3px solid #22c55e;}.toast-error{border-left:3px solid #E50914;}.toast-info{border-left:3px solid #3b82f6;}
        @@keyframes tIn{from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)}}
        @@keyframes tOut{from{opacity:1;transform:translateX(0)}to{opacity:0;transform:translateX(100px)}}
        @@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
        .fade-in{animation:fadeIn .3s ease forwards;}
    </style>
</head>
<body class="bg-[#0a0a0a] text-white min-h-screen">
<div id="toast-container"></div>

<nav class="fixed top-0 left-0 right-0 h-14 bg-[#0a0a0a]/95 border-b border-[#2a2a2a] flex items-center px-4 sm:px-6 gap-4 z-50 backdrop-blur-sm">
    <button onclick="toggleSidebar()" class="sm:hidden text-[#888] text-xl p-1">☰</button>
    <span class="brand text-2xl text-[#E50914]">CINEBOOK</span>
    <span class="hidden sm:block text-xs text-[#2a2a2a]">|</span>
    <span class="hidden sm:block text-sm text-[#888]">Cinema Manager</span>
    <div class="flex-1"></div>
    <span id="managerName" class="hidden sm:block text-sm text-[#888]"></span>
    <button onclick="logout()" class="text-sm text-[#888] border border-[#2a2a2a] rounded-md px-3 py-1.5 hover:border-[#555] hover:text-white transition-all">Sign Out</button>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
<aside id="sidebar" class="fixed left-0 top-14 bottom-0 w-56 bg-[#141414] border-r border-[#2a2a2a] px-3 py-5 z-[100] flex flex-col gap-1 -translate-x-full sm:translate-x-0 transition-transform duration-300">
    <div class="text-xs text-[#555] tracking-widest px-3 pb-3">MANAGE</div>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/Manager/Cinema">🏟 My Cinema</a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/Manager/Halls">🪑 Halls</a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/Manager/Showtimes">🎬 Showtimes</a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/Booking/CinemaBookings">📋 Bookings</a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#E50914] bg-[#E50914]/10" href="/Booking/Refunds">↩ Refunds</a>
    <div class="flex-1"></div>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[#888] hover:bg-[#1e1e1e] hover:text-white transition-all" href="/">🏠 Dashboard</a>
</aside>

<div class="sm:ml-56 pt-14 min-h-screen">
    <div class="p-4 sm:p-6">

        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
            <div>
                <h1 class="text-xl font-bold">Refunds</h1>
                <p class="text-sm text-[#888] mt-0.5">Manage cancelled booking refunds</p>
            </div>
            <a href="/Booking/CinemaBookings" class="text-sm text-[#888] hover:text-white transition-colors flex items-center gap-1">← Back to Bookings</a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
            <div class="bg-[#141414] border border-[#2a2a2a] rounded-xl p-4 flex items-center gap-3"><div class="text-2xl">↩</div><div><div class="text-xl font-bold" id="totalCancelled">0</div><div class="text-xs text-[#888]">Total Cancelled</div></div></div>
            <div class="bg-[#141414] border border-red-400/20 rounded-xl p-4 flex items-center gap-3"><div class="text-2xl">⏳</div><div><div class="text-xl font-bold text-red-400" id="pendingRefunds">0</div><div class="text-xs text-[#888]">Pending</div></div></div>
            <div class="bg-[#141414] border border-green-400/20 rounded-xl p-4 flex items-center gap-3"><div class="text-2xl">✅</div><div><div class="text-xl font-bold text-green-400" id="processedRefunds">0</div><div class="text-xs text-[#888]">Processed</div></div></div>
            <div class="bg-red-400/5 border border-red-400/15 rounded-xl p-4 flex items-center gap-3"><div class="text-2xl">💸</div><div><div class="text-xl font-bold text-red-400" id="totalRefundAmount">₹0</div><div class="text-xs text-[#888]">Pending Amount</div></div></div>
        </div>

        <!-- Filter tabs -->
        <div class="flex gap-2 mb-5 flex-wrap">
            <button class="filter-tab px-4 py-1.5 rounded-full text-sm font-medium bg-[#E50914] text-white border border-[#E50914]" onclick="setFilter('all',this)">All</button>
            <button class="filter-tab px-4 py-1.5 rounded-full text-sm font-medium text-[#888] border border-[#2a2a2a] bg-[#141414] hover:border-[#444] hover:text-white transition-all" onclick="setFilter('pending',this)">⏳ Pending Refund</button>
            <button class="filter-tab px-4 py-1.5 rounded-full text-sm font-medium text-[#888] border border-[#2a2a2a] bg-[#141414] hover:border-[#444] hover:text-white transition-all" onclick="setFilter('processed',this)">✅ Processed</button>
        </div>

        <div id="refundsList">
            <div class="text-center py-16 text-[#555]"><div class="text-4xl mb-3">↩</div><div>Loading refunds...</div></div>
        </div>
    </div>
</div>

<script>
function showToast(msg,type='info',duration=4000){const icons={success:'✓',error:'✕',info:'ℹ',warning:'⚠'};const colors={success:'#22c55e',error:'#E50914',info:'#3b82f6',warning:'#f59e0b'};const c=document.getElementById('toast-container');const t=document.createElement('div');t.className=`toast toast-${type}`;t.innerHTML=`<div style="width:22px;height:22px;border-radius:50%;background:${colors[type]}20;border:1px solid ${colors[type]}50;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px;color:${colors[type]};font-weight:700;">${icons[type]}</div><div style="flex:1;line-height:1.5;">${msg}</div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#555;cursor:pointer;font-size:18px;padding:0;">✕</button>`;c.appendChild(t);setTimeout(()=>{t.classList.add('removing');setTimeout(()=>t.remove(),250);},duration);}
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('-translate-x-full');document.getElementById('sidebarOverlay').classList.toggle('show');}
function logout(){localStorage.clear();window.location.href='/Auth/Login';}
const token=localStorage.getItem('token');const user=JSON.parse(localStorage.getItem('user')||'{}');
if(!token)window.location.href='/Auth/Login';if(user.role!=='CinemaManager')window.location.href='/';
document.getElementById('managerName').textContent=user.fullName||'Manager';
function authHeaders(){return{'Content-Type':'application/json','Authorization':`Bearer ${token}`};}

let allRefunds=[],currentFilter='all';

async function loadRefunds(){
    try{const res=await fetch('/api/bookings/cinema/cancelled',{headers:authHeaders()});const data=await res.json();
        if(data.success){allRefunds=data.data;updateStats();renderRefunds(allRefunds);}
        else{document.getElementById('refundsList').innerHTML=`<div class="text-center py-16 text-[#555]"><div class="text-4xl mb-3">✅</div><div>No cancelled bookings found</div></div>`;}
    }catch{showToast('Failed to load refunds','error');}
}

function updateStats(){
    const pending=allRefunds.filter(r=>!r.refundProcessed);const processed=allRefunds.filter(r=>r.refundProcessed);const totalAmt=pending.reduce((s,r)=>s+r.totalAmount,0);
    document.getElementById('totalCancelled').textContent=allRefunds.length;document.getElementById('pendingRefunds').textContent=pending.length;
    document.getElementById('processedRefunds').textContent=processed.length;document.getElementById('totalRefundAmount').textContent=`₹${totalAmt.toLocaleString('en-IN')}`;
}

function setFilter(f,el){
    currentFilter=f;document.querySelectorAll('.filter-tab').forEach(t=>{t.classList.remove('bg-[#E50914]','text-white','border-[#E50914]');t.classList.add('text-[#888]','border-[#2a2a2a]','bg-[#141414]');});
    el.classList.add('bg-[#E50914]','text-white','border-[#E50914]');el.classList.remove('text-[#888]','border-[#2a2a2a]','bg-[#141414]');
    let filtered=allRefunds;
    if(f==='pending')filtered=allRefunds.filter(r=>!r.refundProcessed);else if(f==='processed')filtered=allRefunds.filter(r=>r.refundProcessed);
    renderRefunds(filtered);
}

function seatTag(s){const color=(s.seatType==='Standard'||s.seatType===0)?'#60a5fa':(s.seatType==='Premium'||s.seatType===1)?'#c084fc':'#facc15';return`<span style="display:inline-flex;align-items:center;gap:3px;background:#222;border:1px solid #2a2a2a;padding:2px 6px;border-radius:4px;font-size:11px;font-weight:600;margin:1px;"><span style="color:${color}">●</span>${s.row}${s.seatNumber}</span>`;}

function fmtIST(isoStr){if(!isoStr)return'';const d=isoStr.split('T');const datePart=d[0]||'';const timePart=d[1]?.substring(0,5)||'';const[h,m]=(timePart||'').split(':');const hour=parseInt(h);const ampm=hour>=12?'pm':'am';const h12=hour%12||12;const[yr,mo,dy]=(datePart||'').split('-');const dateStr=datePart?new Date(parseInt(yr),parseInt(mo)-1,parseInt(dy)).toLocaleDateString('en-IN',{day:'numeric',month:'short'}):'';return`${dateStr} • ${h12}:${m} ${ampm}`;}

function renderRefunds(refunds){
    const list=document.getElementById('refundsList');
    if(!refunds.length){list.innerHTML=`<div class="text-center py-16 text-[#555]"><div class="text-5xl mb-4">✅</div><div class="text-base font-semibold mb-1">${currentFilter==='pending'?'No pending refunds!':'No refunds found'}</div><div class="text-sm">${currentFilter==='pending'?'All cancelled bookings have been processed.':'No cancelled bookings yet.'}</div></div>`;return;}
    list.innerHTML=refunds.map(r=>{
        const isProcessed=r.refundProcessed;
        const seats=(r.seats||[]).map(s=>seatTag(s)).join('');
        return`<div class="fade-in bg-[#141414] border border-[#2a2a2a] ${isProcessed?'border-l-green-500':'border-l-red-500'} border-l-4 rounded-2xl p-5 mb-4">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                <img src="${r.moviePoster||''}" onerror="this.style.display='none'" class="w-10 h-14 rounded-lg object-cover flex-shrink-0 bg-[#222]" />
                <div class="flex-1 min-w-0">
                    <!-- Header row -->
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
                        <div>
                            <div class="font-bold text-base mb-0.5">${r.movieTitle}</div>
                            <div class="text-xs text-[#888]">🏟 ${r.cinemaName} • ${r.hallName} • 📅 ${new Date(r.showtimeStart).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})}</div>
                        </div>
                        <span class="text-xs font-bold px-3 py-1 rounded-full border w-fit flex-shrink-0 ${isProcessed?'text-green-400 bg-green-400/10 border-green-400/20':'text-red-400 bg-red-400/10 border-red-400/20'}">${isProcessed?'✅ Refund Processed':'⏳ Pending Refund'}</span>
                    </div>
                    <!-- Info grid -->
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
                        <div><div class="text-xs text-[#888] mb-0.5">BOOKING REF</div><div class="text-sm font-bold text-[#E50914]">${r.bookingReference}</div></div>
                        <div><div class="text-xs text-[#888] mb-0.5">CUSTOMER</div><div class="text-sm font-semibold">${r.userName||'User'}</div></div>
                        <div><div class="text-xs text-[#888] mb-0.5">BOOKED AT</div><div class="text-xs text-[#888]">${fmtIST(r.bookedAt)}</div></div>
                        <div><div class="text-xs text-[#888] mb-1">SEATS</div><div class="flex flex-wrap gap-0.5">${seats}</div></div>
                    </div>
                    <!-- Amount + action -->
                    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                        <div class="bg-[#1e1e1e] border border-[#2a2a2a] rounded-xl px-4 py-3">
                            <div class="text-xs text-[#888] mb-1">REFUND AMOUNT</div>
                            <div class="text-xl font-bold text-red-400">₹${r.totalAmount}</div>
                            <div class="text-xs text-[#888]">Subtotal ₹${r.subTotal} + Fee ₹${r.convenienceFee}</div>
                        </div>
                        ${isProcessed?`<div class="text-right"><div class="text-sm font-semibold text-green-400">✅ Refund Processed</div><div class="text-xs text-[#888] mt-0.5">${fmtIST(r.refundedAt)}</div>${r.refundNote?`<div class="text-xs text-[#555] mt-0.5">Note: ${r.refundNote}</div>`:''}</div>`
                        :`<button onclick="toggleNoteBox('${r.id}')" class="text-green-400 border border-green-400/30 bg-green-400/5 hover:bg-green-400/12 font-semibold text-sm px-5 py-2.5 rounded-xl transition-all">↩ Mark as Refunded</button>`}
                    </div>
                    <!-- Note box (hidden) -->
                    ${!isProcessed?`<div id="note-${r.id}" class="hidden mt-4 bg-[#1e1e1e] border border-[#2a2a2a] rounded-xl p-4">
                        <div class="text-xs font-bold text-[#888] tracking-widest mb-3">ADD REFUND NOTE (optional)</div>
                        <textarea id="noteText-${r.id}" class="cinput text-sm" placeholder="e.g. Refunded via UPI to customer's account..."></textarea>
                        <div class="flex gap-2 mt-3">
                            <button onclick="processRefund('${r.id}')" class="bg-green-600 hover:bg-green-700 text-black font-bold text-sm px-5 py-2 rounded-lg transition-colors">✅ Confirm Refund</button>
                            <button onclick="toggleNoteBox('${r.id}')" class="text-[#888] border border-[#2a2a2a] text-sm px-4 py-2 rounded-lg hover:border-[#555] transition-all">Cancel</button>
                        </div>
                    </div>`:``}
                </div>
            </div>
        </div>`;
    }).join('');
}

function toggleNoteBox(id){document.getElementById(`note-${id}`)?.classList.toggle('hidden');}

async function processRefund(bookingId){
    const note=document.getElementById(`noteText-${bookingId}`)?.value?.trim();
    try{
        const res=await fetch(`/api/bookings/${bookingId}/refund`,{method:'PUT',headers:authHeaders(),body:JSON.stringify({note:note||null})});
        const data=await res.json();
        if(data.success){showToast('✅ Refund marked as processed!','success');await loadRefunds();}
        else showToast(data.message||'Failed to process refund','error');
    }catch{showToast('Something went wrong','error');}
}

loadRefunds();
</script>
</body>
</html>
