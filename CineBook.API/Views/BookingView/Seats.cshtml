@{
    ViewData["Title"] = "Select Seats";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Select Seats</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- SignalR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Outfit', sans-serif; }
        .brand { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.06em; }

        /* ── Toast ── */
        #toast-container { position:fixed; top:20px; right:20px; z-index:9999; display:flex; flex-direction:column; gap:10px; pointer-events:none; }
        .toast { pointer-events:all; min-width:260px; max-width:340px; background:#141414; border:1px solid #2a2a2a; border-radius:12px; padding:14px 18px; display:flex; align-items:flex-start; gap:12px; box-shadow:0 8px 32px rgba(0,0,0,.6); animation:tIn .35s cubic-bezier(.34,1.56,.64,1) forwards; font-size:14px; color:#fff; }
        .toast.removing { animation:tOut .25s ease forwards; }
        .toast-success { border-left:3px solid #22c55e; }
        .toast-error   { border-left:3px solid #E50914; }
        .toast-warning { border-left:3px solid #f59e0b; }
        .toast-info    { border-left:3px solid #3b82f6; }
        @@keyframes tIn  { from{opacity:0;transform:translateX(100px)} to{opacity:1;transform:translateX(0)} }
        @@keyframes tOut { from{opacity:1;transform:translateX(0)} to{opacity:0;transform:translateX(100px)} }

        /* ── Seat styles — match original exactly ── */
        .seat {
            width:32px; height:28px; border-radius:4px 4px 2px 2px;
            display:flex; align-items:center; justify-content:center;
            font-size:9px; font-weight:600; cursor:pointer;
            transition:all 0.15s; border:1px solid transparent;
            flex-shrink:0; user-select:none; position:relative;
        }
        .seat:hover:not(.seat-booked):not(.seat-locked) { transform:scale(1.15); z-index:1; }

        .seat-std  { background:rgba(59,130,246,.25); border-color:rgba(59,130,246,.5);  color:#93c5fd; }
        .seat-prem { background:rgba(168,85,247,.25); border-color:rgba(168,85,247,.5); color:#d8b4fe; }
        .seat-vip  { background:rgba(245,158,11,.25); border-color:rgba(245,158,11,.5); color:#fcd34d; }

        .seat-std:hover  { background:rgba(59,130,246,.5); }
        .seat-prem:hover { background:rgba(168,85,247,.5); }
        .seat-vip:hover  { background:rgba(245,158,11,.5); }

        /* Selected */
        .seat-selected { transform:scale(1.1); box-shadow:0 0 0 2px white; }
        .seat-selected.seat-std { background:#3b82f6; border-color:#3b82f6; color:white; }
        .seat-selected.seat-prem { background:#a855f7; border-color:#a855f7; color:white; }
        .seat-selected.seat-vip { background:#f59e0b; border-color:#f59e0b; color:white; }

        .seat-booked  { background:#222222; border-color:#333; color:#444; cursor:not-allowed; }
        .seat-locked  { background:rgba(239,68,68,.15); border-color:rgba(239,68,68,.3); color:#f87171; cursor:not-allowed; }
        .seat-mylock  { background:rgba(34,197,94,.2);  border-color:rgba(34,197,94,.5);  color:#4ade80; cursor:pointer; }

        /* ── Seat row ── */
        .seat-row { display:flex; align-items:center; gap:5px; margin-bottom:6px; justify-content:center; }
        .row-label { width:22px; font-size:12px; color:#555555; text-align:center; flex-shrink:0; font-weight:600; }

        /* ── Seat map — horizontal scroll for wide halls ── */
        .seat-map-wrap { overflow-x:auto; padding-bottom:8px; }
        .seat-map-inner { display:inline-block; min-width:100%; }

        /* ── Summary panel — sticky right sidebar (desktop) ── */
        .summary-panel {
            width:320px; flex-shrink:0;
            background:#111111; border-left:1px solid #282828;
            position:sticky; top:56px;
            height:calc(100vh - 56px);
            display:flex; flex-direction:column; overflow:hidden;
        }

        /* ── Mobile: hide sidebar, show fixed bottom bar ── */
        @@media (max-width:767px) {
            .summary-panel { display:none; }
            .mobile-footer { display:flex !important; }
            body { padding-bottom:72px; }
        }
        .mobile-footer {
            display:none;
            position:fixed; bottom:0; left:0; right:0;
            background:#111111; border-top:1px solid #282828;
            z-index:100; padding:12px 16px;
            align-items:center; gap:12px;
        }

        /* ── Price rows ── */
        .price-row { display:flex; justify-content:space-between; align-items:center; padding:8px 0; font-size:13px; border-bottom:1px solid #1e1e1e; }
        .price-row:last-child { border-bottom:none; }

        /* ── Badges ── */
        .badge-2d   { background:rgba(59,130,246,.15); color:#60a5fa; border:1px solid rgba(59,130,246,.3); }
        .badge-3d   { background:rgba(168,85,247,.15); color:#c084fc; border:1px solid rgba(168,85,247,.3); }
        .badge-imax { background:rgba(234,179,8,.15);  color:#facc15; border:1px solid rgba(234,179,8,.3);  }

        /* ── Timer ── */
        .timer-badge { display:inline-flex; align-items:center; gap:6px; background:rgba(251,191,36,.1); border:1px solid rgba(251,191,36,.3); color:#fbbf24; font-size:13px; font-weight:600; padding:6px 12px; border-radius:20px; }
        @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }
        .pulse { animation:pulse 2s infinite; }

        @@keyframes spin { to{transform:rotate(360deg)} }
        .spinner { width:16px; height:16px; border:2px solid rgba(255,255,255,.3); border-top-color:white; border-radius:50%; animation:spin .7s linear infinite; display:inline-block; }
    </style>
</head>
<body class="bg-[#080808] text-[#f5f5f5] min-h-screen">

<div id="toast-container"></div>

<!-- ── Navbar ── -->
<nav class="fixed top-0 left-0 right-0 h-14 z-50 bg-[#080808]/97 border-b border-[#282828] flex items-center px-4 sm:px-6 gap-3 backdrop-blur-xl">
    <button onclick="history.back()" class="text-[#888] hover:text-white text-xl p-1 transition-colors flex-shrink-0">←</button>
    <span class="brand text-xl text-[#E50914]">CINEBOOK</span>
    <span class="hidden sm:block text-xs text-[#282828]">|</span>
    <span class="hidden sm:block text-sm text-[#888] truncate" id="navMovieTitle">Select Seats</span>
    <div class="flex-1"></div>
    <div class="timer-badge hidden" id="lockTimer">⏱ <span id="timerDisplay" class="pulse">10:00</span></div>
</nav>

<!-- ── Main layout: seat area + summary sidebar ── -->
<div class="flex pt-14 min-h-screen">

    <!-- Seat area -->
    <div class="flex-1 p-4 sm:p-6 overflow-y-auto" style="max-height:calc(100vh - 56px);">

        <!-- Showtime info bar -->
        <div class="bg-[#191919] border border-[#282828] rounded-xl px-5 py-4 mb-6 flex flex-wrap items-center gap-4 sm:gap-6" id="showtimeBar">
            <div class="text-sm text-[#777]">Loading...</div>
        </div>

        <!-- Legend -->
        <div class="flex flex-wrap gap-4 justify-center bg-[#111] border border-[#282828] rounded-xl px-5 py-3 mb-6 text-xs text-[#777]">
            <div class="flex items-center gap-2"><div class="w-5 h-4 rounded-sm" style="background:rgba(59,130,246,.25);border:1px solid rgba(59,130,246,.5)"></div>Standard</div>
            <div class="flex items-center gap-2"><div class="w-5 h-4 rounded-sm" style="background:rgba(168,85,247,.25);border:1px solid rgba(168,85,247,.5)"></div>Premium</div>
            <div class="flex items-center gap-2"><div class="w-5 h-4 rounded-sm" style="background:rgba(245,158,11,.25);border:1px solid rgba(245,158,11,.5)"></div>VIP</div>
            <div class="flex items-center gap-2"><div class="w-5 h-4 rounded-sm" style="background:#222;border:1px solid #333"></div>Booked</div>
            <div class="flex items-center gap-2"><div class="w-5 h-4 rounded-sm" style="background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3)"></div>Locked</div>
            <div class="flex items-center gap-2"><div class="w-5 h-4 rounded-sm bg-blue-500 border border-blue-500"></div>Selected</div>
        </div>

        <!-- Screen -->
        <div class="text-center mb-8">
            <div class="w-3/5 sm:w-2/5 mx-auto h-2 rounded-full" style="background:linear-gradient(to right,transparent,#888,transparent)"></div>
            <div class="text-xs text-[#444] tracking-widest mt-2 font-semibold">SCREEN</div>
        </div>

        <!-- Seat grid -->
        <div class="seat-map-wrap">
            <div class="seat-map-inner" id="seatGrid">
                <div class="text-center py-16 text-[#555]">Loading seats...</div>
            </div>
        </div>
    </div>

    <!-- ── Summary panel (desktop right sidebar) ── -->
    <div class="summary-panel">
        <div class="px-5 py-5 border-b border-[#282828] flex-shrink-0">
            <div class="text-base font-bold" id="summaryTitle">Select Seats</div>
            <div class="text-xs text-[#777] mt-0.5" id="summarySubtitle">Tap seats to select</div>
        </div>

        <div class="flex-1 overflow-y-auto px-5 py-5">
            <!-- Selected seats -->
            <div class="mb-5">
                <div class="text-xs font-bold text-[#777] tracking-widest mb-3">SELECTED SEATS</div>
                <div id="selectedSeatTags"><div class="text-sm text-[#444]">No seats selected</div></div>
            </div>

            <!-- Price breakdown -->
            <div id="priceBreakdown" class="hidden mb-5">
                <div class="text-xs font-bold text-[#777] tracking-widest mb-3">PRICE BREAKDOWN</div>
                <div id="priceRows"></div>
                <div class="flex justify-between items-center font-bold text-base pt-3 mt-1 border-t border-[#1e1e1e]">
                    <span>Total</span>
                    <span class="text-[#E50914]" id="totalAmount">₹0</span>
                </div>
            </div>

            <!-- Ticket prices reference -->
            <div class="bg-[#191919] rounded-xl px-4 py-4">
                <div class="text-xs font-bold text-[#777] tracking-widest mb-3">TICKET PRICES</div>
                <div id="priceRefContent"></div>
            </div>
        </div>

        <div class="px-5 py-4 border-t border-[#282828] flex-shrink-0">
            <button id="proceedBtn" onclick="proceedToBooking()" disabled
                class="w-full bg-[#E50914] hover:bg-[#b20710] text-white font-bold text-sm py-4 rounded-xl transition-all disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                <span id="proceedBtnText">Select seats to continue</span>
                <div class="spinner hidden" id="proceedSpinner"></div>
            </button>
        </div>
    </div>
</div>

<!-- ── Mobile bottom bar ── -->
<div class="mobile-footer" id="mobileFooter">
    <div class="flex-1 min-w-0">
        <div class="text-sm font-semibold truncate" id="mobileSeatInfo">No seats selected</div>
        <div class="text-xs text-[#777]" id="mobilePriceInfo"></div>
    </div>
    <button id="mobileProceedBtn" onclick="proceedToBooking()" disabled
        class="bg-[#E50914] hover:bg-[#b20710] text-white font-bold text-sm px-6 py-3 rounded-xl transition-all disabled:opacity-40 disabled:cursor-not-allowed flex items-center gap-2 flex-shrink-0">
        <span id="mobileBtnText">Book Now</span>
        <div class="spinner hidden" id="mobileSpinner"></div>
    </button>
</div>

<script>
// ── Toast ────────────────────────────────────────────
function showToast(msg, type = 'info', duration = 4000) {
    const icons  = { success:'✓', error:'✕', info:'ℹ', warning:'⚠' };
    const colors = { success:'#22c55e', error:'#E50914', info:'#3b82f6', warning:'#f59e0b' };
    const c = document.getElementById('toast-container');
    const t = document.createElement('div');
    t.className = `toast toast-${type}`;
    t.innerHTML = `<div style="width:22px;height:22px;border-radius:50%;background:${colors[type]}20;border:1px solid ${colors[type]}50;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px;color:${colors[type]};font-weight:700;">${icons[type]}</div><div style="flex:1;line-height:1.5;">${msg}</div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#555;cursor:pointer;font-size:18px;padding:0;">✕</button>`;
    c.appendChild(t);
    setTimeout(() => { t.classList.add('removing'); setTimeout(() => t.remove(), 250); }, duration);
}

// ── Auth / params ────────────────────────────────────
const token = localStorage.getItem('token');
if (!token) window.location.href = '/Auth/Login';
const params     = new URLSearchParams(window.location.search);
const showtimeId = params.get('showtimeId');
const movieId    = params.get('movieId');
if (!showtimeId) window.location.href = '/';
function authHeaders() { return { 'Content-Type':'application/json', 'Authorization':`Bearer ${token}` }; }

// ── State ────────────────────────────────────────────
let layout = null, selectedSeats = [], lockTimerInterval = null, lockSecondsLeft = 600;

// ── SignalR Real-time Seat Sync ───────────────────────
let connection = null;

async function connectSignalR() {
    connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/seats', {
            accessTokenFactory: () => token
        })
        .withAutomaticReconnect()
        .build();

    // ── Someone locked seats ─────────────────────────
    connection.on('SeatsLocked', (data) => {
        const { seatIds, lockedByUserId } = data;
        const myUserId = JSON.parse(localStorage.getItem('user') || '{}').userId;

        seatIds.forEach(seatId => {
            // Don't update your own seats
            if (lockedByUserId === myUserId) return;

            // Remove from selected if someone else locked it
            const idx = selectedSeats.findIndex(s => s.seatId === seatId);
            if (idx >= 0) {
                selectedSeats.splice(idx, 1);
                updateSummary();
                showToast('⚠️ One of your selected seats was just taken!', 'warning', 5000);
            }

            // Update seat UI to locked
            const seatEl = document.getElementById(`seat-${seatId}`);
            if (seatEl) {
                seatEl.className = 'seat seat-locked';
                seatEl.onclick = null;
                seatEl.title = 'Locked by another user';
            }

            // Update layout data
            const seat = layout?.seats?.find(s => s.seatId === seatId);
            if (seat) {
                seat.status = 'Locked';
                seat.isMyLock = false;
            }
        });
    });

    // ── Someone booked seats (confirmed) ─────────────
    connection.on('SeatsBooked', (data) => {
        const { seatIds } = data;

        (seatIds || []).forEach(s => {
            const seatId = s.seatId || s;

            // Remove from selected if it got booked by someone else
            const idx = selectedSeats.findIndex(sel => sel.seatId === seatId);
            if (idx >= 0) {
                selectedSeats.splice(idx, 1);
                updateSummary();
                showToast('❌ A seat you selected has been booked by someone else!', 'error', 5000);
            }

            // Update seat UI to booked
            const seatEl = document.getElementById(`seat-${seatId}`);
            if (seatEl) {
                seatEl.className = 'seat seat-booked';
                seatEl.onclick = null;
                seatEl.title = 'Booked';
            }

            // Update layout data
            const seat = layout?.seats?.find(s => s.seatId === seatId);
            if (seat) seat.status = 'Booked';
        });
    });

    // ── Someone released seats (cancelled/expired) ────
    connection.on('SeatsReleased', async (data) => {
        // Reload entire layout to show fresh availability
        showToast('🔄 Seat availability updated', 'info', 2000);
        await loadLayout();
    });

    // ── Connection events ────────────────────────────
    connection.onreconnecting(() => {
        showToast('Reconnecting...', 'warning', 2000);
    });

    connection.onreconnected(() => {
        showToast('Reconnected ✓', 'success', 2000);
        // Rejoin the showtime group after reconnect
        connection.invoke('JoinShowtime', showtimeId).catch(console.error);
    });

    try {
        await connection.start();
        // Join this showtime's group
        await connection.invoke('JoinShowtime', showtimeId);
        console.log('✅ SignalR connected to showtime:', showtimeId);
    } catch (err) {
        console.error('SignalR connection failed:', err);
        // Don't block user — app works without realtime too
    }
}

// Disconnect when leaving page
window.addEventListener('beforeunload', () => {
    if (connection) {
        connection.invoke('LeaveShowtime', showtimeId).catch(() => {});
        connection.stop();
    }
});

// Connect SignalR after layout loads
loadLayout().then(() => connectSignalR());

// ── Load layout ──────────────────────────────────────
async function loadLayout() {
    try {
        const res  = await fetch(`/api/bookings/seat-layout/${showtimeId}`, { headers: authHeaders() });
        const data = await res.json();
        if (data.success) {
            layout = data.data;
            renderShowtimeBar();
            renderSeatGrid();
            renderPriceRef();
        } else {
            document.getElementById('seatGrid').innerHTML = `<div class="text-center py-16 text-red-400">${data.message}</div>`;
            showToast(data.message || 'Failed to load seats', 'error');
        }
    } catch {
        document.getElementById('seatGrid').innerHTML = `<div class="text-center py-16 text-red-400">Failed to load seats</div>`;
        showToast('Failed to load seat layout', 'error');
    }
}

// ── Showtime bar ─────────────────────────────────────
function renderShowtimeBar() {
    const start = new Date(layout.startTime);
    const time  = start.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', hour12:true });
    const date  = start.toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long' });
    const hallBadge =
        (layout.hallType === 'TwoD'   || layout.hallType === 0) ? '<span class="text-xs font-bold px-2 py-0.5 rounded badge-2d">2D</span>'   :
        (layout.hallType === 'ThreeD' || layout.hallType === 1) ? '<span class="text-xs font-bold px-2 py-0.5 rounded badge-3d">3D</span>'  :
                                                                   '<span class="text-xs font-bold px-2 py-0.5 rounded badge-imax">IMAX</span>';
    document.getElementById('navMovieTitle').textContent      = layout.movieTitle;
    document.getElementById('summaryTitle').textContent       = layout.movieTitle;
    document.getElementById('summarySubtitle').textContent    = `${time} • ${layout.hallName}`;
    document.getElementById('showtimeBar').innerHTML = `
        <div>
            <div class="font-bold text-sm sm:text-base">${layout.movieTitle}</div>
            <div class="text-xs text-[#777] mt-0.5">${layout.cinemaName}</div>
        </div>
        <div class="flex items-center gap-2">${hallBadge} <span class="text-sm text-[#777]">${layout.hallName}</span></div>
        <div class="text-sm font-semibold">📅 ${date}</div>
        <div class="text-base font-bold text-[#E50914]">⏰ ${time}</div>`;
}

// ── Seat grid ────────────────────────────────────────
function renderSeatGrid() {
    const rows = {};
    layout.seats.forEach(s => { if (!rows[s.row]) rows[s.row] = []; rows[s.row].push(s); });

    const stdRows = [], premRows = [], vipRows = [];
    Object.entries(rows).forEach(([row, seats]) => {
        const t = seats[0].seatType;
        if      (t === 'Standard' || t == 0) stdRows.push([row, seats]);
        else if (t === 'Premium'  || t == 1) premRows.push([row, seats]);
        else                                  vipRows.push([row, seats]);
    });

    let html = '';
    if (stdRows.length)  html += buildSection('STANDARD', layout.priceStandard, 'text-blue-400 bg-blue-400/10 border border-blue-400/20',     stdRows);
    if (premRows.length) html += buildSection('PREMIUM',  layout.pricePremium,  'text-purple-400 bg-purple-400/10 border border-purple-400/20', premRows);
    if (vipRows.length)  html += buildSection('VIP',      layout.priceVIP,      'text-yellow-400 bg-yellow-400/10 border border-yellow-400/20', vipRows);

    document.getElementById('seatGrid').innerHTML = html;
}

function buildSection(label, price, cls, rowEntries) {
    return `<div class="mb-7">
        <div class="mb-3"><span class="text-xs font-bold tracking-widest px-3 py-1 rounded-full ${cls}">${label} — ₹${price}</span></div>
        ${buildRows(rowEntries)}
    </div>`;
}

function buildRows(rowEntries) {
    return rowEntries.map(([rowLabel, seats]) => {
        const mid = Math.floor(seats.length / 2);
        return `<div class="seat-row">
            <div class="row-label">${rowLabel}</div>
            ${seats.slice(0, mid).map(buildSeat).join('')}
            <div style="width:16px;flex-shrink:0;"></div>
            ${seats.slice(mid).map(buildSeat).join('')}
        </div>`;
    }).join('');
}

function getSeatClass(s) {
    if (s.status === 'Booked')                        return 'seat-booked';
    if (s.status === 'Locked' && !s.isMyLock)         return 'seat-locked';
    if (s.isMyLock)                                   return 'seat-mylock';
    if (s.seatType === 'Standard' || s.seatType == 0) return 'seat-std';
    if (s.seatType === 'Premium'  || s.seatType == 1) return 'seat-prem';
    return 'seat-vip';
}

function buildSeat(s) {
    const isSelected = selectedSeats.some(sel => sel.seatId === s.seatId);
    const base       = getSeatClass(s);
    const selCls     = isSelected ? ' seat-selected' : '';
    const clickable  = s.status === 'Available' || s.isMyLock;
    return `<div class="seat ${base}${selCls}"
        id="seat-${s.seatId}"
        ${clickable ? `onclick="toggleSeat('${s.seatId}','${s.row}',${s.seatNumber},'${s.seatType}',${s.price})"` : ''}
        title="${s.row}${s.seatNumber} — ₹${s.price}">
        ${s.seatNumber}
    </div>`;
}

// ── Toggle seat ──────────────────────────────────────
function toggleSeat(seatId, row, seatNumber, seatType, price) {
    const idx = selectedSeats.findIndex(s => s.seatId === seatId);
    if (idx >= 0) {
        selectedSeats.splice(idx, 1);
        document.getElementById(`seat-${seatId}`)?.classList.remove('seat-selected');
    } else {
        if (selectedSeats.length >= 10) { showToast('Maximum 10 seats per booking', 'warning'); return; }
        selectedSeats.push({ seatId, row, seatNumber, seatType, price });
        document.getElementById(`seat-${seatId}`)?.classList.add('seat-selected');
    }
    updateSummary();
}

function removeSeat(seatId) {
    const idx = selectedSeats.findIndex(s => s.seatId === seatId);
    if (idx >= 0) {
        selectedSeats.splice(idx, 1);
        document.getElementById(`seat-${seatId}`)?.classList.remove('seat-selected');
        updateSummary();
    }
}

// ── Summary ──────────────────────────────────────────
function seatColor(t) {
    return (t === 'Standard' || t == 0) ? '#60a5fa' : (t === 'Premium' || t == 1) ? '#c084fc' : '#facc15';
}

function updateSummary() {
    const btn     = document.getElementById('proceedBtn');
    const btnText = document.getElementById('proceedBtnText');
    const mBtn    = document.getElementById('mobileProceedBtn');
    const mText   = document.getElementById('mobileBtnText');

    if (!selectedSeats.length) {
        document.getElementById('selectedSeatTags').innerHTML = `<div class="text-sm text-[#444]">No seats selected</div>`;
        document.getElementById('priceBreakdown').classList.add('hidden');
        btn.disabled = true;  btnText.textContent = 'Select seats to continue';
        mBtn.disabled = true; mText.textContent   = 'Book Now';
        document.getElementById('mobileSeatInfo').textContent  = 'No seats selected';
        document.getElementById('mobilePriceInfo').textContent = '';
        return;
    }

    // Seat tags
    document.getElementById('selectedSeatTags').innerHTML = selectedSeats.map(s => `
        <span class="inline-flex items-center gap-1.5 bg-[#191919] border border-[#282828] rounded-lg px-2.5 py-1 text-sm font-semibold mr-1 mb-1">
            <span style="color:${seatColor(s.seatType)};font-size:14px;">●</span>
            ${s.row}${s.seatNumber}
            <button onclick="removeSeat('${s.seatId}')" class="text-[#555] hover:text-[#E50914] transition-colors text-base leading-none ml-0.5">✕</button>
        </span>`).join('');

    // Price calc
    const subTotal = selectedSeats.reduce((sum, s) => sum + s.price, 0);
    const fee      = Math.round(subTotal * 0.02 * 100) / 100;
    const total    = subTotal + fee;

    // Group by type
    const groups = {};
    selectedSeats.forEach(s => {
        const label = (s.seatType === 'Standard' || s.seatType == 0) ? 'Standard'
                    : (s.seatType === 'Premium'  || s.seatType == 1) ? 'Premium' : 'VIP';
        if (!groups[label]) groups[label] = { count:0, total:0 };
        groups[label].count++; groups[label].total += s.price;
    });

    document.getElementById('priceRows').innerHTML =
        Object.entries(groups).map(([type, g]) =>
            `<div class="price-row"><span>${type} × ${g.count}</span><span>₹${Math.round(g.total)}</span></div>`
        ).join('') +
        `<div class="price-row"><span class="text-[#777]">Convenience Fee</span><span class="text-[#777]">₹${fee.toFixed(2)}</span></div>`;

    document.getElementById('totalAmount').textContent = `₹${total.toFixed(0)}`;
    document.getElementById('priceBreakdown').classList.remove('hidden');

    const payLabel = `Pay ₹${total.toFixed(0)} for ${selectedSeats.length} seat${selectedSeats.length > 1 ? 's' : ''}`;
    btn.disabled  = false; btnText.textContent = payLabel;
    mBtn.disabled = false; mText.textContent   = `₹${total.toFixed(0)}`;
    document.getElementById('mobileSeatInfo').textContent  = `${selectedSeats.length} seat${selectedSeats.length > 1 ? 's' : ''} selected`;
    document.getElementById('mobilePriceInfo').textContent = `Total ₹${total.toFixed(0)} (incl. convenience fee)`;
}

// ── Price reference ──────────────────────────────────
function renderPriceRef() {
    document.getElementById('priceRefContent').innerHTML = `
        <div class="space-y-2.5 text-sm">
            <div class="flex justify-between"><span class="text-blue-400">● Standard</span><span class="font-semibold">₹${layout.priceStandard}</span></div>
            <div class="flex justify-between"><span class="text-purple-400">● Premium</span><span class="font-semibold">₹${layout.pricePremium}</span></div>
            <div class="flex justify-between"><span class="text-yellow-400">● VIP</span><span class="font-semibold">₹${layout.priceVIP}</span></div>
        </div>`;
}

// ── Proceed to booking ───────────────────────────────
async function proceedToBooking() {
    if (!selectedSeats.length) return;

    // Disable both desktop + mobile buttons
    const btn   = document.getElementById('proceedBtn');
    const mBtn  = document.getElementById('mobileProceedBtn');
    const spin  = document.getElementById('proceedSpinner');
    const mSpin = document.getElementById('mobileSpinner');
    btn.disabled = true; mBtn.disabled = true;
    document.getElementById('proceedBtnText').classList.add('hidden');  spin.classList.remove('hidden');
    document.getElementById('mobileBtnText').classList.add('hidden');   mSpin.classList.remove('hidden');

    showToast('Locking your seats...', 'info', 3000);

    try {
        // Step 1 — Initiate booking (lock seats)
        const initRes  = await fetch('/api/bookings/initiate', {
            method: 'POST', headers: authHeaders(),
            body: JSON.stringify({ showtimeId, seatIds: selectedSeats.map(s => s.seatId) })
        });
        const initData = await initRes.json();

        if (!initData.success) {
            showToast(initData.message || 'Failed to lock seats — they may have just been taken', 'error', 5000);
            btn.disabled = false; mBtn.disabled = false;
            document.getElementById('proceedBtnText').classList.remove('hidden'); spin.classList.add('hidden');
            document.getElementById('mobileBtnText').classList.remove('hidden');  mSpin.classList.add('hidden');
            selectedSeats = []; updateSummary(); await loadLayout();
            return;
        }

        startLockTimer();
        showToast('Seats locked! Redirecting to payment...', 'success', 2500);
        document.getElementById('proceedBtnText').classList.remove('hidden');
        document.getElementById('proceedBtnText').textContent = 'Redirecting...';
        spin.classList.add('hidden');

        // Step 2 — Create Stripe Checkout Session
        const sessionRes  = await fetch('/api/checkout/create-session', {
            method: 'POST', headers: authHeaders(),
            body: JSON.stringify({ bookingId: initData.data.id })
        });
        const sessionData = await sessionRes.json();

        if (!sessionData.success) {
            showToast(sessionData.message || 'Payment setup failed', 'error');
            btn.disabled = false; mBtn.disabled = false; updateSummary();
            return;
        }

        // Step 3 — Redirect to Stripe
        window.location.href = sessionData.url;

    } catch {
        showToast('Something went wrong. Please try again.', 'error');
        btn.disabled = false; mBtn.disabled = false;
        document.getElementById('proceedBtnText').classList.remove('hidden'); spin.classList.add('hidden');
        document.getElementById('mobileBtnText').classList.remove('hidden');  mSpin.classList.add('hidden');
        updateSummary();
    }
}

// ── Lock timer ───────────────────────────────────────
function startLockTimer() {
    document.getElementById('lockTimer').classList.remove('hidden');
    lockSecondsLeft = 600;
    lockTimerInterval = setInterval(() => {
        lockSecondsLeft--;
        const m = Math.floor(lockSecondsLeft / 60);
        const s = lockSecondsLeft % 60;
        document.getElementById('timerDisplay').textContent = `${m}:${s.toString().padStart(2, '0')}`;
        if (lockSecondsLeft <= 0) {
            clearInterval(lockTimerInterval);
            showToast('Seat lock expired! Please select seats again.', 'error', 5000);
            selectedSeats = []; loadLayout(); updateSummary();
            document.getElementById('lockTimer').classList.add('hidden');
        }
    }, 1000);
}

</script>
