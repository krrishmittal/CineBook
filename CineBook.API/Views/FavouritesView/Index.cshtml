@{
    ViewData["Title"] = "My Favourites";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — My Favourites</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --red: #E50914; --red-dark: #b20710;
            --bg: #080808; --surface: #111111;
            --surface2: #191919; --surface3: #222222;
            --border: #282828; --text: #f5f5f5;
            --muted: #777777;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: var(--text); font-family: 'Outfit', sans-serif; min-height: 100vh; }
        .brand { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.06em; }

        .navbar {
            position: fixed; top: 0; left: 0; right: 0; height: 62px; z-index: 100;
            background: rgba(8,8,8,0.97); border-bottom: 1px solid var(--border);
            backdrop-filter: blur(16px);
            display: flex; align-items: center; padding: 0 32px; gap: 24px;
        }

        .main { padding-top: 62px; max-width: 1200px; margin: 0 auto; padding: 82px 32px 80px; }

        /* Movie grid */
        .movies-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 20px;
        }

        .movie-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 12px; overflow: hidden; cursor: pointer;
            transition: all 0.2s; position: relative;
        }
        .movie-card:hover { border-color: #3a3a3a; transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.5); }

        .movie-poster {
            width: 100%; aspect-ratio: 2/3; object-fit: cover;
            background: var(--surface3); display: block;
        }
        .movie-poster-placeholder {
            width: 100%; aspect-ratio: 2/3;
            background: var(--surface3); display: flex;
            align-items: center; justify-content: center; font-size: 40px;
        }

        .movie-info { padding: 12px; }

        /* Heart button on card */
        .heart-btn {
            position: absolute; top: 10px; right: 10px;
            width: 32px; height: 32px; border-radius: 50%;
            background: rgba(0,0,0,0.7); border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 16px; transition: all 0.2s;
            backdrop-filter: blur(4px);
        }
        .heart-btn:hover { background: rgba(229,9,20,0.8); transform: scale(1.1); }
        .heart-btn.hearted { background: rgba(229,9,20,0.9); }

        /* Status badge */
        .status-badge {
            display: inline-flex; padding: 2px 8px; border-radius: 20px;
            font-size: 10px; font-weight: 700; letter-spacing: 0.04em;
        }
        .status-NowShowing { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.2); }
        .status-ComingSoon { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.2); }
        .status-Archived { background: rgba(100,100,100,0.15); color: #888; border: 1px solid rgba(100,100,100,0.2); }

        .user-menu { position: relative; }
        .user-avatar {
            width: 34px; height: 34px; border-radius: 50%; background: var(--red);
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700; cursor: pointer;
        }
        .user-dropdown {
            position: absolute; top: calc(100% + 10px); right: 0; width: 200px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 10px; padding: 8px; display: none; z-index: 200;
            box-shadow: 0 16px 40px rgba(0,0,0,0.6);
        }
        .user-dropdown.show { display: block; }
        .dropdown-item {
            display: flex; align-items: center; gap: 10px; padding: 9px 12px;
            border-radius: 6px; font-size: 14px; color: var(--muted);
            cursor: pointer; transition: all 0.15s; text-decoration: none;
        }
        .dropdown-item:hover { background: var(--surface2); color: var(--text); }

        .login-btn {
            background: var(--red); color: white; font-family: 'Outfit', sans-serif;
            font-weight: 600; font-size: 13px; padding: 8px 18px;
            border: none; border-radius: 7px; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center;
        }

        .empty { text-align: center; padding: 80px 20px; color: var(--muted); }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .movie-card { animation: fadeIn 0.3s ease forwards; }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/" style="text-decoration:none;">
            <span class="brand" style="font-size:26px; color:var(--red);">CINEBOOK</span>
        </a>
        <div style="flex:1;"></div>
        <a href="/" style="font-size:14px; color:var(--muted); text-decoration:none; font-weight:500;">Home</a>
        <div id="guestNav"><a href="/Auth/Login" class="login-btn">Sign In</a></div>
        <div id="userNav" style="display:none;">
            <div class="user-menu">
                <div class="user-avatar" id="userAvatar" onclick="toggleDropdown()">?</div>
                <div class="user-dropdown" id="userDropdown">
                    <div style="padding:10px 12px 8px; border-bottom:1px solid var(--border); margin-bottom:6px;">
                        <div style="font-size:14px; font-weight:600;" id="dropdownName"></div>
                    </div>
                    <a class="dropdown-item" href="/Profile">👤 My Profile</a>
                    <a class="dropdown-item" href="/Bookings">🎟 My Bookings</a>
                    <a class="dropdown-item" href="/Favourites" style="color:var(--red);">❤️ My Favourites</a>
                    <div class="dropdown-item" onclick="logout()" style="color:#f87171;">🚪 Sign Out</div>
                </div>
            </div>
        </div>
    </nav>

    <div class="main">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:28px;">
            <div>
                <h1 style="font-size:28px; font-weight:700; display:flex; align-items:center; gap:10px;">
                    ❤️ My Favourites
                </h1>
                <p style="font-size:14px; color:var(--muted); margin-top:6px;" id="favCount">Loading...</p>
            </div>
            <a href="/" style="font-size:13px; color:var(--muted); text-decoration:none;">← Browse Movies</a>
        </div>

        <div id="favGrid">
            <div style="text-align:center; padding:40px; color:var(--muted);">Loading...</div>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');

        if (!token) window.location.href = '/Auth/Login';

        if (user.fullName) {
            document.getElementById('guestNav').style.display = 'none';
            document.getElementById('userNav').style.display = 'block';
            const initials = user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2);
            document.getElementById('userAvatar').textContent = initials;
            document.getElementById('dropdownName').textContent = user.fullName;
        }

        function toggleDropdown() { document.getElementById('userDropdown').classList.toggle('show'); }
        document.addEventListener('click', e => {
            if (!e.target.closest('.user-menu')) document.getElementById('userDropdown')?.classList.remove('show');
        });
        function logout() { localStorage.clear(); window.location.href = '/Auth/Login'; }

        function authHeaders() {
            return { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` };
        }

        async function loadFavourites() {
            try {
                const res = await fetch('/api/favourites/my', { headers: authHeaders() });
                const data = await res.json();

                if (data.success) {
                    renderFavourites(data.data);
                } else {
                    showEmpty('Failed to load favourites');
                }
            } catch {
                showEmpty('Something went wrong');
            }
        }

        function renderFavourites(favs) {
            const grid = document.getElementById('favGrid');

            document.getElementById('favCount').textContent =
                favs.length > 0
                    ? `${favs.length} movie${favs.length > 1 ? 's' : ''} saved`
                    : 'No favourites yet';

            if (!favs.length) {
                grid.innerHTML = `
                    <div class="empty">
                        <div style="font-size:64px; margin-bottom:16px;">🎬</div>
                        <div style="font-size:20px; font-weight:600; margin-bottom:8px;">No favourites yet</div>
                        <div style="font-size:14px; margin-bottom:24px;">Heart movies you love and they'll appear here</div>
                        <a href="/" style="background:var(--red); color:white; font-family:'Outfit',sans-serif;
                           font-weight:600; font-size:14px; padding:12px 28px; border-radius:8px; text-decoration:none;">
                            Browse Movies
                        </a>
                    </div>`;
                return;
            }

            grid.innerHTML = `<div class="movies-grid">${favs.map(f => {
                const statusCls = f.status === 'NowShowing' ? 'status-NowShowing'
                                : f.status === 'ComingSoon' ? 'status-ComingSoon'
                                : 'status-Archived';
                const statusLabel = f.status === 'NowShowing' ? 'Now Showing'
                                  : f.status === 'ComingSoon' ? 'Coming Soon'
                                  : 'Archived';

                return `
                <div class="movie-card" onclick="window.location.href='/Movies/${f.movieId}'">
                    ${f.posterUrl
                        ? `<img class="movie-poster" src="${f.posterUrl}" alt="${f.title}" loading="lazy"
                               onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'" />
                           <div class="movie-poster-placeholder" style="display:none;">🎬</div>`
                        : `<div class="movie-poster-placeholder">🎬</div>`}

                    <!-- Heart remove button -->
                    <button class="heart-btn hearted" onclick="removeFav(event, '${f.movieId}')" title="Remove from favourites">
                        ❤️
                    </button>

                    <div class="movie-info">
                        <div style="font-size:13px; font-weight:600; margin-bottom:6px;
                                    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            ${f.title}
                        </div>
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:6px; margin-bottom:6px;">
                            <span class="status-badge ${statusCls}">${statusLabel}</span>
                            <span style="font-size:11px; color:var(--muted);">${f.durationTime}m</span>
                        </div>
                        <div style="font-size:11px; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            ${f.genre.split(',')[0].trim()}
                        </div>
                        ${f.status === 'NowShowing' ? `
                        <button onclick="event.stopPropagation(); window.location.href='/Movies/${f.movieId}/Book'"
                            style="width:100%; margin-top:10px; background:var(--red); color:white;
                                   font-family:'Outfit',sans-serif; font-weight:600; font-size:12px;
                                   padding:8px; border:none; border-radius:6px; cursor:pointer;">
                            🎟 Book Now
                        </button>` : ''}
                    </div>
                </div>`;
            }).join('')}</div>`;
        }

        async function removeFav(event, movieId) {
            event.stopPropagation();
            try {
                const res = await fetch(`/api/favourites/toggle/${movieId}`, {
                    method: 'POST',
                    headers: authHeaders()
                });
                const data = await res.json();
                if (data.success) await loadFavourites();
            } catch {}
        }

        function showEmpty(msg) {
            document.getElementById('favGrid').innerHTML = `
                <div class="empty">
                    <div style="font-size:40px; margin-bottom:12px;">❤️</div>
                    <div style="font-size:18px;">${msg}</div>
                </div>`;
        }

        loadFavourites();
    </script>
</body>
</html>
