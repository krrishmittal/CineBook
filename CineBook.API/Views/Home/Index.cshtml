@{
    ViewData["Title"] = "CineBook — Movies";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Book Movie Tickets</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family:'Outfit',sans-serif; }
        .brand { font-family:'Bebas Neue',sans-serif; letter-spacing:0.06em; }

        /* ── Toast ── */
        #toast-container { position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none; }
        .toast { pointer-events:all;min-width:260px;max-width:340px;background:#141414;border:1px solid #2a2a2a;border-radius:12px;padding:14px 18px;display:flex;align-items:flex-start;gap:12px;box-shadow:0 8px 32px rgba(0,0,0,.6);animation:tIn .35s cubic-bezier(.34,1.56,.64,1) forwards;font-size:14px;color:#fff; }
        .toast.removing { animation:tOut .25s ease forwards; }
        .toast-success { border-left:3px solid #22c55e; }
        .toast-error   { border-left:3px solid #E50914; }
        .toast-info    { border-left:3px solid #3b82f6; }
        @@keyframes tIn  { from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)} }
        @@keyframes tOut { from{opacity:1;transform:translateX(0)}to{opacity:0;transform:translateX(100px)} }

        /* ── Hero ── */
        .hero-wrap {
            position: relative;
            height: 380px;
            overflow: hidden;
            background: #141414;
        }
        @@media (min-width: 640px)  { .hero-wrap { height: 460px; } }
        @@media (min-width: 768px)  { .hero-wrap { height: 520px; } }
        @@media (min-width: 1024px) { .hero-wrap { height: 580px; } }

        .hero-slide { position:absolute;inset:0;opacity:0;transition:opacity .8s ease;pointer-events:none; }
        .hero-slide.active { opacity:1;pointer-events:all; }

        .trailer-box { position:relative;border-radius:12px;overflow:hidden;background:#000;border:1px solid rgba(255,255,255,.15);box-shadow:0 24px 64px rgba(0,0,0,.6); }
        .trailer-iframe { position:absolute;inset:0;width:100%;height:100%;border:none;display:none; }

        .play-btn { width:56px;height:56px;border-radius:50%;background:rgba(229,9,20,.9);border:3px solid white;display:flex;align-items:center;justify-content:center;transition:all .2s;backdrop-filter:blur(4px); }
        .play-btn:hover { background:#E50914;transform:scale(1.1);box-shadow:0 0 40px rgba(229,9,20,.5); }

        .hero-dot { width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.25);border:none;cursor:pointer;transition:all .3s;padding:0; }
        .hero-dot.active { width:20px;border-radius:3px;background:#E50914; }

        /* ── Movie cards ── */
        .movie-card { transition:transform .3s,box-shadow .3s; }
        .movie-card:hover { transform:translateY(-6px);box-shadow:0 20px 40px rgba(0,0,0,.6); }
        .movie-card:hover .card-poster { filter:brightness(.7); }
        .card-poster { transition:filter .3s; }
        .wishlist-btn { opacity:0;transition:opacity .2s; }
        .movie-card:hover .wishlist-btn { opacity:1; }

        /* ── Pagination ── */
        .page-btn { min-width:36px;height:36px;border-radius:8px;font-size:13px;font-weight:600;border:1px solid #282828;background:#111;color:#777;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;padding:0 10px; }
        .page-btn:hover:not(:disabled) { border-color:#444;color:#fff;background:#1a1a1a; }
        .page-btn.active { background:#E50914;border-color:#E50914;color:#fff; }
        .page-btn:disabled { opacity:0.3;cursor:not-allowed; }

        /* ── Misc ── */
        .genre-scroll { scrollbar-width:none; }
        .genre-scroll::-webkit-scrollbar { display:none; }
        .user-dropdown { display:none; }
        .user-dropdown.show { display:block; }
        .nav-search-input { background:#1a1a1a;border:1px solid #2a2a2a;border-radius:8px;padding:8px 16px 8px 38px;color:#fff;font-size:14px;outline:none;transition:border-color .2s;width:100%; }
        .nav-search-input:focus { border-color:rgba(229,9,20,.5); }
        .nav-search-input::placeholder { color:#555; }
        @@keyframes fadeUp { from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)} }
        .fade-up { animation:fadeUp .4s ease forwards;opacity:0; }
    </style>
</head>
<body class="bg-[#080808] text-[#f5f5f5] min-h-screen overflow-x-hidden">

<div id="toast-container"></div>

<!-- ── Navbar ── -->
<nav class="fixed top-0 left-0 right-0 h-16 z-50 bg-[#080808]/92 border-b border-[#282828] flex items-center px-4 sm:px-8 gap-4 sm:gap-6 backdrop-blur-xl">
    <a href="/" class="flex-shrink-0"><span class="brand text-2xl sm:text-3xl text-[#E50914]">CINEBOOK</span></a>
    <div class="hidden sm:flex gap-1">
        <a class="text-sm font-medium text-white px-3 py-1.5 rounded-lg bg-white/5" href="/">Movies</a>
        <a class="text-sm font-medium text-[#777] px-3 py-1.5 rounded-lg hover:bg-white/5 hover:text-white transition-all" href="#">Events</a>
    </div>
    <div class="hidden sm:block relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[#555] text-sm">🔍</span>
        <input class="nav-search-input" type="text" id="navSearch" placeholder="Search movies..." oninput="handleSearch(this.value)" />
    </div>
    <button onclick="toggleMobileSearch()" class="sm:hidden text-[#888] text-xl p-1">🔍</button>
    <div class="flex-1"></div>
    <div id="guestNav"><a href="/Auth/Login" class="bg-[#E50914] hover:bg-[#b20710] text-white font-semibold text-sm px-4 py-2 rounded-lg transition-colors">Sign In</a></div>
    <div id="userNav" class="hidden">
        <div class="relative">
            <div id="userAvatar" onclick="toggleDropdown()" class="w-9 h-9 rounded-full bg-[#E50914] flex items-center justify-center text-sm font-bold cursor-pointer select-none hover:bg-[#b20710] transition-colors">?</div>
            <div id="userDropdown" class="user-dropdown absolute top-[calc(100%+10px)] right-0 w-48 bg-[#141414] border border-[#282828] rounded-xl p-2 z-50 shadow-2xl">
                <div class="px-3 py-2 border-b border-[#282828] mb-2"><div class="text-sm font-semibold" id="dropdownName"></div></div>
                <a class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-[#777] hover:bg-[#1a1a1a] hover:text-white transition-all" href="/Profile">👤 My Profile</a>
                <a class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-[#777] hover:bg-[#1a1a1a] hover:text-white transition-all" href="/Bookings">🎟 My Bookings</a>
                <a class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-[#777] hover:bg-[#1a1a1a] hover:text-white transition-all" href="/Favourites">❤️ My Favourites</a>
                <button onclick="logout()" class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-[#f87171] hover:bg-[#1a1a1a] transition-all">🚪 Sign Out</button>
            </div>
        </div>
    </div>
</nav>

<!-- Mobile search -->
<div id="mobileSearch" class="hidden fixed top-16 left-0 right-0 z-40 bg-[#0a0a0a] border-b border-[#282828] p-3">
    <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[#555] text-sm">🔍</span>
        <input class="nav-search-input" type="text" placeholder="Search movies..." oninput="handleSearch(this.value)" />
    </div>
</div>

<!-- ── Hero ── -->
<div class="hero-wrap mt-16" id="heroBanner">
    <div class="flex items-center justify-center h-full text-[#555]">
        <div class="text-center"><div class="text-4xl mb-3">🎬</div><div>Loading...</div></div>
    </div>
</div>

<!-- Dots outside hero -->
<div class="flex gap-2 justify-end px-6 sm:px-10 py-3 bg-[#080808]" id="heroDots"></div>

<!-- ── Content ── -->
<div class="max-w-[1400px] mx-auto px-4 sm:px-8 py-8">

    <!-- Genre Scroll -->
    <div class="mb-10">
        <div class="text-lg font-bold mb-4 flex items-center gap-2 before:content-[''] before:w-0.5 before:h-5 before:bg-[#E50914] before:rounded">Browse by Genre</div>
        <div class="genre-scroll flex gap-3 overflow-x-auto pb-2">
            <div class="flex-shrink-0 w-28 h-[72px] rounded-xl relative overflow-hidden cursor-pointer hover:scale-105 transition-transform border border-[#282828]" onclick="filterByGenre('Action')" style="background:linear-gradient(135deg,#1a1a2e,#16213e)"><div class="flex items-center justify-center h-full text-3xl">💥</div><div class="absolute bottom-2 left-2 text-xs font-semibold">Action</div></div>
            <div class="flex-shrink-0 w-28 h-[72px] rounded-xl relative overflow-hidden cursor-pointer hover:scale-105 transition-transform border border-[#282828]" onclick="filterByGenre('Drama')" style="background:linear-gradient(135deg,#1a1a1a,#2d1b1b)"><div class="flex items-center justify-center h-full text-3xl">🎭</div><div class="absolute bottom-2 left-2 text-xs font-semibold">Drama</div></div>
            <div class="flex-shrink-0 w-28 h-[72px] rounded-xl relative overflow-hidden cursor-pointer hover:scale-105 transition-transform border border-[#282828]" onclick="filterByGenre('Comedy')" style="background:linear-gradient(135deg,#1a2a1a,#1e3a1e)"><div class="flex items-center justify-center h-full text-3xl">😂</div><div class="absolute bottom-2 left-2 text-xs font-semibold">Comedy</div></div>
            <div class="flex-shrink-0 w-28 h-[72px] rounded-xl relative overflow-hidden cursor-pointer hover:scale-105 transition-transform border border-[#282828]" onclick="filterByGenre('Horror')" style="background:linear-gradient(135deg,#1a0a0a,#2d0d0d)"><div class="flex items-center justify-center h-full text-3xl">👻</div><div class="absolute bottom-2 left-2 text-xs font-semibold">Horror</div></div>
            <div class="flex-shrink-0 w-28 h-[72px] rounded-xl relative overflow-hidden cursor-pointer hover:scale-105 transition-transform border border-[#282828]" onclick="filterByGenre('Thriller')" style="background:linear-gradient(135deg,#0d0d1a,#1a1a2e)"><div class="flex items-center justify-center h-full text-3xl">🔪</div><div class="absolute bottom-2 left-2 text-xs font-semibold">Thriller</div></div>
            <div class="flex-shrink-0 w-28 h-[72px] rounded-xl relative overflow-hidden cursor-pointer hover:scale-105 transition-transform border border-[#282828]" onclick="filterByGenre('Sci-Fi')" style="background:linear-gradient(135deg,#001a1a,#003333)"><div class="flex items-center justify-center h-full text-3xl">🚀</div><div class="absolute bottom-2 left-2 text-xs font-semibold">Sci-Fi</div></div>
            <div class="flex-shrink-0 w-28 h-[72px] rounded-xl relative overflow-hidden cursor-pointer hover:scale-105 transition-transform border border-[#282828]" onclick="filterByGenre('Romance')" style="background:linear-gradient(135deg,#1a0a10,#2d1020)"><div class="flex items-center justify-center h-full text-3xl">❤️</div><div class="absolute bottom-2 left-2 text-xs font-semibold">Romance</div></div>
            <div class="flex-shrink-0 w-28 h-[72px] rounded-xl relative overflow-hidden cursor-pointer hover:scale-105 transition-transform border border-[#282828]" onclick="filterByGenre('Adventure')" style="background:linear-gradient(135deg,#0d1a0d,#1a2d0d)"><div class="flex items-center justify-center h-full text-3xl">🗺️</div><div class="absolute bottom-2 left-2 text-xs font-semibold">Adventure</div></div>
        </div>
    </div>

    <!-- Movie list -->
    <div id="nowShowingSection">
        <div class="flex items-center justify-between mb-4">
            <div class="text-lg font-bold flex items-center gap-2 before:content-[''] before:w-0.5 before:h-5 before:bg-[#E50914] before:rounded">Now Showing</div>
            <!-- Results info -->
            <div id="resultsInfo" class="text-sm text-[#555]"></div>
        </div>
        <div class="flex gap-2 mb-5 flex-wrap">
            <button class="filter-pill px-4 py-1.5 rounded-full text-sm font-medium bg-[#E50914] text-white border border-[#E50914]" onclick="setFilter('all',this)">🎬 All Movies</button>
            <button class="filter-pill px-4 py-1.5 rounded-full text-sm font-medium text-[#777] border border-[#282828] bg-[#111] hover:border-[#444] hover:text-white transition-all" onclick="setFilter('NowShowing',this)">🟢 Now Showing</button>
            <button class="filter-pill px-4 py-1.5 rounded-full text-sm font-medium text-[#777] border border-[#282828] bg-[#111] hover:border-[#444] hover:text-white transition-all" onclick="setFilter('ComingSoon',this)">🔵 Coming Soon</button>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4" id="movieGrid">
            <div class="col-span-full text-center py-10 text-[#555]"><div class="text-4xl mb-2">🎬</div><div>Loading movies...</div></div>
        </div>

        <!-- ── Pagination Bar ── -->
        <div id="paginationBar" class="flex items-center justify-center gap-2 mt-10 flex-wrap"></div>
    </div>
</div>

<script>
/* ══════════════════════════════════════════
   TOAST
══════════════════════════════════════════ */
function showToast(msg, type = 'info', duration = 4000) {
    const icons  = { success: '✓', error: '✕', info: 'ℹ', warning: '⚠' };
    const colors = { success: '#22c55e', error: '#E50914', info: '#3b82f6', warning: '#f59e0b' };
    const c = document.getElementById('toast-container');
    const t = document.createElement('div');
    t.className = `toast toast-${type}`;
    t.innerHTML = `<div style="width:22px;height:22px;border-radius:50%;background:${colors[type]}20;border:1px solid ${colors[type]}50;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px;color:${colors[type]};font-weight:700;">${icons[type]}</div><div style="flex:1;line-height:1.5;">${msg}</div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#555;cursor:pointer;font-size:18px;padding:0;">✕</button>`;
    c.appendChild(t);
    setTimeout(() => { t.classList.add('removing'); setTimeout(() => t.remove(), 250); }, duration);
}

/* ══════════════════════════════════════════
   AUTH
══════════════════════════════════════════ */
const token = localStorage.getItem('token');
const user   = JSON.parse(localStorage.getItem('user') || '{}');

function initAuthUI() {
    if (token && user.fullName) {
        document.getElementById('guestNav').style.display = 'none';
        document.getElementById('userNav').classList.remove('hidden');
        document.getElementById('userAvatar').textContent = user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
        document.getElementById('dropdownName').textContent = user.fullName;
    }
}
function toggleDropdown() { document.getElementById('userDropdown').classList.toggle('show'); }
document.addEventListener('click', e => { if (!e.target.closest('#userNav')) document.getElementById('userDropdown')?.classList.remove('show'); });
function logout() { localStorage.clear(); window.location.href = '/Auth/Login'; }
function toggleMobileSearch() { document.getElementById('mobileSearch').classList.toggle('hidden'); }

/* ══════════════════════════════════════════
   STATE
══════════════════════════════════════════ */
let heroSlideData = [];
let heroInterval  = null;
let currentSlide  = 0;

// Pagination state
let currentPage   = 1;
const PAGE_SIZE   = 18;
let totalPages    = 1;
let totalCount    = 0;

// Active filters
const activeFilters = { search: '', genre: '', status: '' };

/* ══════════════════════════════════════════
   HERO
══════════════════════════════════════════ */
function parseYouTube(url) {
    if (!url) return { videoId: null, embedUrl: null };
    let vid = null;
    try {
        if (url.includes('youtu.be/'))           vid = url.split('youtu.be/')[1].split(/[?&]/)[0];
        else if (url.includes('youtube.com/watch'))  vid = new URL(url).searchParams.get('v');
        else if (url.includes('youtube.com/embed/')) vid = url.split('/embed/')[1].split(/[?&]/)[0];
    } catch {}
    if (!vid) return { videoId: null, embedUrl: url };
    return { videoId: vid, embedUrl: `https://www.youtube.com/embed/${vid}?autoplay=1&rel=0&modestbranding=1` };
}

function buildHero(movies) {
    if (!movies.length) return;
    heroSlideData = [];
    const hero   = document.getElementById('heroBanner');
    const dotsEl = document.getElementById('heroDots');

    hero.innerHTML = movies.map((m, i) => {
        const { videoId, embedUrl } = parseYouTube(m.trailerUrl || '');
        heroSlideData[i] = { movieId: m.id, embedUrl: embedUrl || null };
        const thumbUrl = videoId
            ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
            : (m.posterUrl || '');

        const trailerWidget = embedUrl ? `
            <div class="hidden sm:block trailer-box flex-shrink-0 w-[340px] md:w-[420px] lg:w-[480px] h-[200px] md:h-[250px] lg:h-[280px]" id="trailerBox-${i}">
                <img id="trailerThumb-${i}" src="${thumbUrl}" class="w-full h-full object-cover opacity-70" onerror="this.src='${m.posterUrl || ''}'" />
                <div id="trailerOverlay-${i}" class="absolute inset-0 flex items-center justify-center cursor-pointer bg-black/30 hover:bg-black/50 transition-all" onclick="playHeroTrailer(${i})">
                    <div class="play-btn"><svg viewBox="0 0 24 24" width="28" height="28" fill="white"><path d="M8 5v14l11-7z"/></svg></div>
                </div>
                <div class="absolute bottom-3 left-3 text-[10px] font-bold text-white/60 tracking-widest pointer-events-none">OFFICIAL TRAILER</div>
                <iframe id="trailerIframe-${i}" class="trailer-iframe" allow="autoplay;encrypted-media;fullscreen" allowfullscreen></iframe>
            </div>` : '';

        return `<div class="hero-slide ${i === 0 ? 'active' : ''}" id="slide-${i}">
            ${m.posterUrl ? `<img class="absolute inset-0 w-full h-full object-cover" style="filter:brightness(.2);transform:scale(1.05)" src="${m.posterUrl}" alt="${m.title}" />` : ''}
            <div class="absolute inset-0" style="background:linear-gradient(to right,rgba(8,8,8,.99) 0%,rgba(8,8,8,.75) 50%,transparent 100%),linear-gradient(to top,rgba(8,8,8,1) 0%,transparent 60%)"></div>
            <div class="absolute inset-0 flex items-center px-5 sm:px-12 lg:px-16 gap-6 lg:gap-12">
                <div class="flex-1 flex flex-col min-w-0">
                    <div class="inline-flex items-center gap-2 bg-[#E50914] text-white text-xs font-bold tracking-widest px-3 py-1 rounded-sm mb-2 w-fit">▶ NOW SHOWING</div>
                    <h1 class="brand text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-none mb-2 sm:mb-3">${m.title}</h1>
                    <div class="flex items-center gap-2 text-xs sm:text-sm text-[#aaa] mb-2 sm:mb-3 flex-wrap">
                        <span>${m.certificateRating || ''}</span>
                        <span class="w-1 h-1 rounded-full bg-[#555]"></span>
                        <span>${m.durationTime} min</span>
                        <span class="w-1 h-1 rounded-full bg-[#555]"></span>
                        <span>${(m.genre || '').split(',')[0]}</span>
                    </div>
                    <p class="hidden sm:block text-xs sm:text-sm text-[#999] leading-relaxed mb-4 line-clamp-2 md:line-clamp-3 max-w-lg">${m.description || ''}</p>
                    <div class="flex items-center gap-3 flex-wrap">
                        <a href="/Movies/${m.id}" class="bg-[#E50914] hover:bg-[#b20710] text-white font-bold text-sm sm:text-base px-5 sm:px-7 py-2.5 sm:py-3 rounded-xl transition-all hover:shadow-[0_8px_24px_rgba(229,9,20,.3)] hover:-translate-y-0.5">🎟 Book Tickets</a>
                        <button id="heroHeart-${m.id}" onclick="toggleHeroFav(event,'${m.id}')"
                            class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white/10 border-2 border-white/20 text-xl sm:text-2xl flex items-center justify-center hover:bg-white/20 transition-all">🤍</button>
                    </div>
                </div>
                ${trailerWidget}
            </div>
        </div>`;
    }).join('');

    dotsEl.innerHTML = movies.map((_, i) =>
        `<button class="hero-dot ${i === 0 ? 'active' : ''}" onclick="goToSlide(${i})"></button>`
    ).join('');

    if (heroInterval) clearInterval(heroInterval);
    if (movies.length > 1) heroInterval = setInterval(() => goToSlide((currentSlide + 1) % movies.length), 6000);
}

function playHeroTrailer(i) {
    const slide = heroSlideData[i]; if (!slide?.embedUrl) return;
    document.getElementById(`trailerThumb-${i}`).style.display = 'none';
    document.getElementById(`trailerOverlay-${i}`).style.display = 'none';
    const iframe = document.getElementById(`trailerIframe-${i}`);
    iframe.src = slide.embedUrl; iframe.style.display = 'block';
    if (heroInterval) { clearInterval(heroInterval); heroInterval = null; }
}

function stopSlideTrailer(i) {
    const iframe   = document.getElementById(`trailerIframe-${i}`);
    const thumb    = document.getElementById(`trailerThumb-${i}`);
    const overlay  = document.getElementById(`trailerOverlay-${i}`);
    if (iframe)   { iframe.src = ''; iframe.style.display = 'none'; }
    if (thumb)    thumb.style.display = 'block';
    if (overlay)  overlay.style.display = 'flex';
}

function goToSlide(index) {
    stopSlideTrailer(currentSlide);
    document.querySelectorAll('.hero-slide').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.hero-dot').forEach(d => d.classList.remove('active'));
    document.getElementById(`slide-${index}`)?.classList.add('active');
    document.querySelectorAll('.hero-dot')[index]?.classList.add('active');
    currentSlide = index;
}

/* ══════════════════════════════════════════
   MOVIE CARD BUILDER
══════════════════════════════════════════ */
function buildMovieCard(m, i) {
    return `
    <div class="movie-card bg-[#111] rounded-xl overflow-hidden cursor-pointer border border-transparent hover:border-[#282828] fade-up"
         style="animation-delay:${i * 0.04}s"
         onclick="window.location.href='/Movies/${m.id}'">
        <div class="relative" style="padding-top:148%">
            ${m.posterUrl
                ? `<img class="card-poster absolute inset-0 w-full h-full object-cover" src="${m.posterUrl}" alt="${m.title}" onerror="this.style.display='none'" />`
                : ''}
            <div class="absolute inset-0 ${!m.posterUrl ? 'flex items-center justify-center text-5xl' : ''}"
                 style="${!m.posterUrl ? 'background:#222' : ''}">
                ${!m.posterUrl ? '🎬' : ''}
            </div>
            <div class="absolute top-2 left-2 bg-black/75 text-white text-[10px] font-bold px-1.5 py-0.5 rounded border border-white/10">${m.certificateRating || ''}</div>
            <button class="wishlist-btn absolute top-2 right-2 w-7 h-7 rounded-full bg-black/60 flex items-center justify-center text-sm"
                    data-movie-id="${m.id}"
                    onclick="event.stopPropagation();toggleWishlist(event,'${m.id}',this)">🤍</button>
        </div>
        <div class="p-3">
            <div class="font-semibold text-sm truncate mb-1">${m.title}</div>
            <div class="flex items-center gap-1.5 text-xs text-[#777]">
                ${m.status === 'NowShowing' || m.status === 1
                    ? '<span class="w-1.5 h-1.5 rounded-full bg-green-500 shadow-[0_0_6px_#22c55e]"></span> Now Showing'
                    : '<span class="text-blue-400">Coming Soon</span>'}
                <span class="text-[#333]">•</span><span>${m.durationTime}m</span>
            </div>
            <div class="text-[11px] text-[#555] mt-0.5 truncate">${m.genre || ''}</div>
        </div>
    </div>`;
}

/* ══════════════════════════════════════════
   RENDER MOVIES
══════════════════════════════════════════ */
function renderMovies(movies) {
    const grid = document.getElementById('movieGrid');
    if (!movies.length) {
        grid.innerHTML = `<div class="col-span-full text-center py-16 text-[#555]">
            <div class="text-4xl mb-2">🎬</div>
            <div class="font-medium">No movies found</div>
            <div class="text-xs mt-1">Try a different search or filter</div>
        </div>`;
        return;
    }
    grid.innerHTML = movies.map((m, i) => buildMovieCard(m, i)).join('');
}

/* ══════════════════════════════════════════
   PAGINATION
══════════════════════════════════════════ */
function renderPagination() {
    const bar = document.getElementById('paginationBar');

    // Update results info
    const info = document.getElementById('resultsInfo');
    if (totalCount > 0) {
        const from = (currentPage - 1) * PAGE_SIZE + 1;
        const to   = Math.min(currentPage * PAGE_SIZE, totalCount);
        info.textContent = `Showing ${from}–${to} of ${totalCount} movies`;
    } else {
        info.textContent = '';
    }

    if (totalPages <= 1) { bar.innerHTML = ''; return; }

    // Build page number array with ellipsis
    const pages = [];
    if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) pages.push(i);
    } else {
        pages.push(1);
        if (currentPage > 3)        pages.push('…');
        for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) pages.push(i);
        if (currentPage < totalPages - 2) pages.push('…');
        pages.push(totalPages);
    }

    bar.innerHTML = `
        <!-- Prev -->
        <button class="page-btn" onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>
            ← Prev
        </button>

        <!-- Page numbers -->
        ${pages.map(p => p === '…'
            ? `<span class="page-btn" style="cursor:default;color:#444;border-color:#1a1a1a">…</span>`
            : `<button class="page-btn ${p === currentPage ? 'active' : ''}" onclick="goToPage(${p})">${p}</button>`
        ).join('')}

        <!-- Next -->
        <button class="page-btn" onclick="goToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>
            Next →
        </button>`;
}

function goToPage(page) {
    if (page < 1 || page > totalPages || page === currentPage) return;
    currentPage = page;
    loadMovies(page);
    // Scroll to movie grid
    document.getElementById('nowShowingSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

/* ══════════════════════════════════════════
   LOAD MOVIES (PAGED)
══════════════════════════════════════════ */
let heroLoaded = false;

async function loadMovies(page = 1) {
    // Show skeleton while loading
    if (page === 1) {
        document.getElementById('movieGrid').innerHTML = `
            <div class="col-span-full text-center py-10 text-[#555]">
                <div class="text-4xl mb-2">🎬</div><div>Loading movies...</div>
            </div>`;
        document.getElementById('paginationBar').innerHTML = '';
        document.getElementById('resultsInfo').textContent = '';
    }

    try {
        const params = new URLSearchParams({ page, pageSize: PAGE_SIZE });
        if (activeFilters.search) params.set('search', activeFilters.search);
        if (activeFilters.genre)  params.set('genre',  activeFilters.genre);
        if (activeFilters.status) params.set('status', activeFilters.status);

        const res  = await fetch(`/api/movies/paged?${params}`);
        const data = await res.json();

        if (!data.success) {
            showToast(data.message || 'Failed to load movies', 'error');
            return;
        }

        const paged   = data.data;          // PagedResponse<MovieResponse>
        currentPage   = paged.page;
        totalPages    = paged.totalPages;
        totalCount    = paged.totalCount;

        renderMovies(paged.items);
        renderPagination();

        // Build hero only once on first load with no filters
        if (!heroLoaded && !activeFilters.search && !activeFilters.genre && !activeFilters.status) {
            heroLoaded = true;
            try {
                const heroRes  = await fetch('/api/movies/paged?status=NowShowing&page=1&pageSize=5');
                const heroData = await heroRes.json();
                if (heroData.success) buildHero(heroData.data.items);
            } catch {}
        }

        await loadFavouriteStatus();

    } catch (err) {
        console.error(err);
        showToast('Failed to load movies', 'error');
    }
}

/* ══════════════════════════════════════════
   FILTERS
══════════════════════════════════════════ */
async function setFilter(filter, el) {
    // Update pill styles
    document.querySelectorAll('.filter-pill').forEach(p => {
        p.classList.remove('bg-[#E50914]', 'text-white', 'border-[#E50914]');
        p.classList.add('text-[#777]', 'border-[#282828]', 'bg-[#111]');
    });
    el.classList.add('bg-[#E50914]', 'text-white', 'border-[#E50914]');
    el.classList.remove('text-[#777]', 'border-[#282828]', 'bg-[#111]');

    activeFilters.status = filter === 'all' ? '' : filter;
    activeFilters.genre  = '';
    activeFilters.search = '';
    // Also clear search inputs
    document.getElementById('navSearch').value = '';
    currentPage = 1;
    await loadMovies(1);
}

async function filterByGenre(genre) {
    document.getElementById('nowShowingSection').scrollIntoView({ behavior: 'smooth' });
    activeFilters.genre  = genre;
    activeFilters.status = '';
    activeFilters.search = '';
    currentPage = 1;
    await loadMovies(1);
}

let searchTimeout = null;
function handleSearch(q) {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(async () => {
        activeFilters.search = q.trim();
        activeFilters.genre  = '';
        activeFilters.status = '';
        currentPage = 1;
        await loadMovies(1);
    }, 400);
}

/* ══════════════════════════════════════════
   FAVOURITES
══════════════════════════════════════════ */
async function toggleHeroFav(event, movieId) {
    event.preventDefault(); event.stopPropagation();
    if (!token) { window.location.href = '/Auth/Login'; return; }
    try {
        const res = await fetch(`/api/favourites/toggle/${movieId}`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }
        });
        if (res.ok) {
            const data = await res.json();
            const btn  = document.getElementById(`heroHeart-${movieId}`);
            if (btn) {
                btn.textContent       = data.data.isFavourited ? '❤️' : '🤍';
                btn.style.background  = data.data.isFavourited ? 'rgba(229,9,20,.25)' : 'rgba(255,255,255,.1)';
            }
            showToast(data.data.isFavourited ? 'Added to favourites ❤️' : 'Removed from favourites',
                data.data.isFavourited ? 'success' : 'info', 2500);
        }
    } catch {}
}

async function toggleWishlist(event, movieId, btn) {
    event.stopPropagation();
    if (!token) { window.location.href = '/Auth/Login'; return; }
    try {
        const res  = await fetch(`/api/favourites/toggle/${movieId}`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }
        });
        if (res.ok) {
            const data = await res.json();
            btn.textContent = data.data.isFavourited ? '❤️' : '🤍';
            showToast(data.data.isFavourited ? 'Added to favourites ❤️' : 'Removed from favourites',
                data.data.isFavourited ? 'success' : 'info', 2500);
        }
    } catch {}
}

async function loadFavouriteStatus() {
    if (!token) return;
    try {
        const res = await fetch('/api/favourites/ids', { headers: { 'Authorization': `Bearer ${token}` } });
        if (res.ok) {
            const data   = await res.json();
            const favIds = data.data || [];
            document.querySelectorAll('[data-movie-id]').forEach(btn => {
                if (favIds.includes(btn.dataset.movieId)) btn.textContent = '❤️';
            });
            // Update hero hearts
            heroSlideData.forEach(s => {
                const btn = document.getElementById(`heroHeart-${s.movieId}`);
                if (btn && favIds.includes(s.movieId)) {
                    btn.textContent      = '❤️';
                    btn.style.background = 'rgba(229,9,20,.25)';
                }
            });
        }
    } catch {}
}

/* ══════════════════════════════════════════
   BOOTSTRAP
══════════════════════════════════════════ */
if (token && user.role === 'Admin')          window.location.href = '/Admin/Movies';
else if (token && user.role === 'CinemaManager') window.location.href = '/Manager/Cinema';
else {
    initAuthUI();
    loadMovies(1);
}
</script>
