@{
    ViewData["Title"] = "Hall Management";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Hall Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --red: #E50914; --red-dark: #b20710;
            --bg: #0a0a0a; --surface: #141414;
            --surface2: #1e1e1e; --surface3: #242424;
            --border: #2a2a2a; --text: #ffffff; --muted: #888888;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; overflow-x: hidden; }
        .brand { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.05em; }

        .navbar {
            position: fixed; top: 0; left: 0; right: 0; height: 56px;
            background: rgba(10,10,10,0.97); border-bottom: 1px solid var(--border);
            display: flex; align-items: center; padding: 0 24px; gap: 16px; z-index: 200;
        }
        .sidebar {
            position: fixed; left: 0; top: 56px; bottom: 0; width: 220px;
            background: var(--surface); border-right: 1px solid var(--border);
            padding: 20px 12px; z-index: 100; display: flex; flex-direction: column; gap: 4px;
        }
        .nav-item {
            display: flex; align-items: center; gap: 10px; padding: 10px 12px;
            border-radius: 6px; font-size: 14px; font-weight: 500; color: var(--muted);
            cursor: pointer; transition: all 0.2s; text-decoration: none;
            border: none; background: none; width: 100%;
        }
        .nav-item:hover { background: var(--surface2); color: var(--text); }
        .nav-item.active { background: rgba(229,9,20,0.12); color: var(--red); }

        .main { margin-left: 220px; padding-top: 56px; display: flex; min-height: 100vh; }
        .list-panel { flex: 1; padding: 24px; overflow-y: auto; max-height: calc(100vh - 56px); }

        /* Slide Panel */
        .slide-panel {
            width: 680px; background: var(--surface);
            border-left: 1px solid var(--border);
            position: fixed; right: -680px; top: 56px; bottom: 0;
            transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
            z-index: 150; display: flex; flex-direction: column;
        }
        .slide-panel.open { right: 0; }

        .overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.7);
            z-index: 140; opacity: 0; pointer-events: none; transition: opacity 0.3s;
        }
        .overlay.show { opacity: 1; pointer-events: all; }

        .panel-header {
            padding: 18px 24px; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
        }
        .panel-body { flex: 1; overflow-y: auto; padding: 20px 24px; }
        .panel-footer { padding: 14px 24px; border-top: 1px solid var(--border); display: flex; gap: 10px; flex-shrink: 0; }

        /* Hall Card */
        .hall-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 10px; padding: 18px; margin-bottom: 10px;
            cursor: pointer; transition: all 0.2s;
            display: flex; align-items: center; gap: 16px;
        }
        .hall-card:hover { border-color: #3a3a3a; background: var(--surface2); }
        .hall-card.selected { border-color: var(--red); background: rgba(229,9,20,0.05); }

        /* Inputs */
        label { display: block; font-size: 12px; font-weight: 500; color: #999; margin-bottom: 5px; }
        .cinput {
            width: 100%; background: var(--surface2); border: 1px solid var(--border);
            border-radius: 6px; padding: 10px 14px; color: var(--text);
            font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none;
            transition: border-color 0.2s;
        }
        .cinput:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(229,9,20,0.12); }
        .cinput::placeholder { color: #555; }
        select.cinput option { background: var(--surface2); }

        /* Buttons */
        .cbtn {
            background: var(--red); color: white; font-family: 'DM Sans', sans-serif;
            font-weight: 600; font-size: 14px; padding: 10px 20px;
            border: none; border-radius: 6px; cursor: pointer; transition: background 0.2s;
        }
        .cbtn:hover { background: var(--red-dark); }
        .cbtn:disabled { opacity: 0.6; cursor: not-allowed; }

        .cbtn-outline {
            background: transparent; color: var(--muted); font-family: 'DM Sans', sans-serif;
            font-weight: 500; font-size: 14px; padding: 10px 20px;
            border: 1px solid var(--border); border-radius: 6px;
            cursor: pointer; transition: all 0.2s; flex: 1;
        }
        .cbtn-outline:hover { border-color: #555; color: white; }

        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .form-full { grid-column: 1 / -1; }

        /* Badges */
        .badge { display: inline-flex; align-items: center; padding: 2px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge-2d { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.2); }
        .badge-3d { background: rgba(168,85,247,0.15); color: #c084fc; border: 1px solid rgba(168,85,247,0.2); }
        .badge-imax { background: rgba(234,179,8,0.15); color: #facc15; border: 1px solid rgba(234,179,8,0.2); }
        .badge-active { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.2); }
        .badge-inactive { background: rgba(100,100,100,0.15); color: #888; border: 1px solid rgba(100,100,100,0.2); }

        /* Stat cards */
        .stat-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 8px; padding: 16px 20px;
            display: flex; align-items: center; gap: 14px;
        }

        /* Alert */
        .alert { border-radius: 6px; padding: 10px 14px; font-size: 13px; display: none; margin-bottom: 14px; }
        .alert-error { background: rgba(229,9,20,0.1); border: 1px solid rgba(229,9,20,0.3); color: #ff6b6b; }
        .alert-success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: #4ade80; }

        /* ── SEAT DESIGNER ── */
        .designer-wrap {
            background: var(--surface2); border: 1px solid var(--border);
            border-radius: 10px; padding: 16px; margin-top: 16px;
        }

        /* Seat type selector toolbar */
        .type-toolbar {
            display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap;
        }
        .type-btn {
            display: flex; align-items: center; gap: 8px;
            padding: 8px 14px; border-radius: 8px; cursor: pointer;
            border: 2px solid transparent; transition: all 0.15s;
            font-size: 13px; font-weight: 600; font-family: 'DM Sans', sans-serif;
        }
        .type-btn .dot { width: 12px; height: 12px; border-radius: 3px; }
        .type-btn.active-tool { border-color: white; }

        .type-btn-standard { background: rgba(59,130,246,0.15); color: #60a5fa; }
        .type-btn-standard.active-tool { background: rgba(59,130,246,0.3); }
        .type-btn-premium { background: rgba(168,85,247,0.15); color: #c084fc; }
        .type-btn-premium.active-tool { background: rgba(168,85,247,0.3); }
        .type-btn-vip { background: rgba(245,158,11,0.15); color: #facc15; }
        .type-btn-vip.active-tool { background: rgba(245,158,11,0.3); }
        .type-btn-eraser { background: rgba(100,100,100,0.15); color: #888; }
        .type-btn-eraser.active-tool { background: rgba(100,100,100,0.3); }

        /* Row controls */
        .row-actions { display: flex; gap: 6px; align-items: center; margin-bottom: 12px; }
        .row-action-btn {
            padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 600;
            cursor: pointer; border: 1px solid var(--border); background: var(--surface3);
            color: var(--muted); transition: all 0.15s; font-family: 'DM Sans', sans-serif;
        }
        .row-action-btn:hover { color: var(--text); border-color: #555; }

        /* Screen bar */
        .screen-bar {
            text-align: center; margin-bottom: 20px;
        }
        .screen-line {
            width: 55%; margin: 0 auto; height: 5px; border-radius: 3px;
            background: linear-gradient(to right, transparent, #555, transparent);
        }
        .screen-label { font-size: 10px; color: #555; letter-spacing: 0.12em; margin-top: 4px; }

        /* Seat grid */
        .seat-grid-designer {
            overflow-x: auto; padding-bottom: 8px;
        }
        .seat-grid-inner { display: inline-block; min-width: 100%; }

        .designer-row {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-bottom: 5px;
            height: 32px !important;
            max-height: 32px !important;
            flex-wrap: nowrap;
            overflow: hidden;
        }
        .row-label-d {
            width: 24px; font-size: 11px; color: #555; text-align: center;
            flex-shrink: 0; font-weight: 700;
        }
        .row-select-all {
            width: 20px; height: 20px; border-radius: 4px; cursor: pointer;
            background: var(--surface3); border: 1px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            font-size: 10px; color: var(--muted); flex-shrink: 0; transition: all 0.15s;
        }
        .row-select-all:hover { border-color: #555; color: white; }

        /* Designer seat */
        .dseat {
            width: 28px ;
            height: 28px;
            /* min-width: 18px;
            max-width: 18px ;
            min-height: 8px ;
            max-height: 8px; */
            border-radius: 4px;
            cursor: pointer;
            border: 1px solid var(--border);
            background: var(--surface3);
            flex-shrink: 0;
            flex-basis: 28px;
            position: relative;
            user-select: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            color: transparent;
            overflow: hidden;
            padding: 0;
            margin: 0;
        }

        .dseat.standard { background: rgba(59,130,246,0.5); border-color: rgba(59,130,246,0.8); color: rgba(255,255,255,0.6); }
        .dseat.premium  { background: rgba(168,85,247,0.5); border-color: rgba(168,85,247,0.8); color: rgba(255,255,255,0.6); }
        .dseat.vip      { background: rgba(245,158,11,0.5); border-color: rgba(245,158,11,0.8); color: rgba(255,255,255,0.6); }
        .dseat:hover { border-color: #555; }
             .dseat.empty { 
            background: var(--surface3);
            height: 16px;
            width: 28px;
            flex-basis: auto;
            border-color: var(--border);
        }

        .dseat.gap { background: transparent; border-color: transparent; cursor: default; }
        .dseat.gap:hover { transform: none; }

        /* Seat counts summary */
        .seat-summary {
            display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;
            margin-top: 14px;
        }
        .seat-count-box {
            background: var(--surface3); border: 1px solid var(--border);
            border-radius: 6px; padding: 10px; text-align: center;
        }

        /* Delete confirm */
        .delete-confirm {
            background: rgba(229,9,20,0.08); border: 1px solid rgba(229,9,20,0.2);
            border-radius: 8px; padding: 16px; margin-top: 16px; display: none;
        }

        .empty { text-align: center; padding: 60px 20px; color: var(--muted); }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .hall-card { animation: fadeIn 0.3s ease forwards; }

        .warning-card {
            background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.2);
            border-radius: 10px; padding: 24px; text-align: center;
        }

        /* Aisle gap toggle */
        .aisle-btn {
            padding: 5px 10px; border-radius: 5px; font-size: 11px; font-weight: 600;
            cursor: pointer; border: 1px solid var(--border); background: var(--surface3);
            color: var(--muted); transition: all 0.15s; font-family: 'DM Sans', sans-serif;
        }
        .aisle-btn.active { background: rgba(229,9,20,0.15); border-color: var(--red); color: var(--red); }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <span class="brand" style="font-size:22px; color:var(--red);">CINEBOOK</span>
        <span style="font-size:12px; color:var(--border);">|</span>
        <span style="font-size:13px; color:var(--muted);">Cinema Manager</span>
        <div style="flex:1;"></div>
        <span id="managerName" style="font-size:13px; color:var(--muted);"></span>
        <button onclick="logout()" style="background:none; border:1px solid var(--border); color:var(--muted); font-family:'DM Sans',sans-serif; font-size:13px; padding:6px 14px; border-radius:6px; cursor:pointer;">Sign Out</button>
    </nav>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div style="font-size:11px; color:var(--muted); letter-spacing:0.1em; padding:4px 12px 12px;">MANAGE</div>
        <a class="nav-item" href="/Manager/Cinema">🏟 My Cinema</a>
        <a class="nav-item active" href="/Manager/Halls">🪑 Halls</a>
        <a class="nav-item" href="/Manager/Showtimes">🎬 Showtimes</a>
        <a class="nav-item" href="/Booking/CinemaBookings">📋 Bookings</a>
        <a class="nav-item" href="/Booking/Refunds">↩ Refunds</a>
        <div style="flex:1;"></div>
        <a class="nav-item" href="/Manager/Cinema">🏠 Dashboard</a>
    </aside>

    <div class="main">
        <div class="list-panel">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
                <div>
                    <h1 style="font-size:22px; font-weight:700;">Hall Management</h1>
                    <p style="font-size:13px; color:var(--muted); margin-top:2px;">Design halls with custom seat layouts</p>
                </div>
                <button class="cbtn" onclick="openAddPanel()">+ Add Hall</button>
            </div>

            <div class="warning-card" id="noCinemaWarning" style="display:none;">
                <div style="font-size:32px; margin-bottom:12px;">🏟</div>
                <div style="font-size:16px; font-weight:600; color:#fbbf24; margin-bottom:8px;">Cinema not approved yet</div>
                <div style="font-size:13px; color:var(--muted); margin-bottom:16px;">You need an approved cinema before adding halls.</div>
                <a href="/Manager/Cinema" style="background:var(--red); color:white; font-family:'DM Sans',sans-serif; font-weight:600; font-size:13px; padding:10px 20px; border-radius:6px; text-decoration:none;">Go to My Cinema →</a>
            </div>

            <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:24px;" id="statsSection">
                <div class="stat-card"><div style="font-size:26px;">🎭</div><div><div style="font-size:22px; font-weight:700;" id="totalHalls">0</div><div style="font-size:12px; color:var(--muted);">Total Halls</div></div></div>
                <div class="stat-card"><div style="font-size:26px;">🪑</div><div><div style="font-size:22px; font-weight:700;" id="totalSeats">0</div><div style="font-size:12px; color:var(--muted);">Total Seats</div></div></div>
                <div class="stat-card"><div style="font-size:26px;">✅</div><div><div style="font-size:22px; font-weight:700;" id="activeHalls">0</div><div style="font-size:12px; color:var(--muted);">Active Halls</div></div></div>
            </div>

            <div id="hallList">
                <div class="empty"><div style="font-size:40px; margin-bottom:12px;">🪑</div><div style="font-size:16px; font-weight:500;">Loading halls...</div></div>
            </div>
        </div>
    </div>

    <!-- Overlay -->
    <div class="overlay" id="overlay" onclick="closePanel()"></div>

    <!-- Slide Panel -->
    <div class="slide-panel" id="slidePanel">
        <div class="panel-header">
            <div>
                <div style="font-size:17px; font-weight:600;" id="panelTitle">Add Hall</div>
                <div style="font-size:12px; color:var(--muted); margin-top:2px;" id="panelSubtitle">Design your hall layout</div>
            </div>
            <button onclick="closePanel()" style="background:none; border:none; color:var(--muted); font-size:22px; cursor:pointer;">✕</button>
        </div>

        <div class="panel-body">
            <div class="alert alert-error" id="formError"></div>
            <div class="alert alert-success" id="formSuccess"></div>

            <!-- Add Form -->
            <div id="addForm">
                <div class="form-grid" style="margin-bottom:16px;">
                    <div class="form-full">
                        <label>Hall Name *</label>
                        <input class="cinput" type="text" id="fHallName" placeholder="e.g. Hall 1, Gold Class" />
                    </div>
                    <div>
                        <label>Hall Type *</label>
                        <select class="cinput" id="fHallType">
                            <option value="0">2D</option>
                            <option value="1">3D</option>
                            <option value="2">IMAX</option>
                        </select>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                        <div>
                            <label>Rows *</label>
                            <input class="cinput" type="number" id="fRows" placeholder="e.g. 10" min="1" max="26"
                                   oninput="generateGrid()" style="padding:10px 10px;" />
                        </div>
                        <div>
                            <label>Seats/Row *</label>
                            <input class="cinput" type="number" id="fSeats" placeholder="e.g. 12" min="1" max="30"
                                   oninput="generateGrid()" style="padding:10px 10px;" />
                        </div>
                    </div>
                </div>

                <!-- Seat Designer -->
                <div class="designer-wrap" id="designerWrap" style="display:none;">

                    <!-- Toolbar -->
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; flex-wrap:wrap; gap:8px;">
                        <div style="font-size:12px; font-weight:700; color:var(--muted); letter-spacing:0.06em;">SEAT DESIGNER</div>
                        <div style="display:flex; gap:6px; align-items:center;">
                            <div style="font-size:12px; color:var(--muted);">Aisle after col:</div>
                            <input class="cinput" type="number" id="aisleCol" placeholder="e.g. 6"
                                   style="width:64px; padding:5px 8px; font-size:12px;"
                                   oninput="generateGrid()" />
                        </div>
                    </div>

                    <!-- Type selector -->
                    <div class="type-toolbar">
                        <button class="type-btn type-btn-standard active-tool" onclick="setTool('standard', this)">
                            <div class="dot" style="background:#3b82f6;"></div> Standard
                        </button>
                        <button class="type-btn type-btn-premium" onclick="setTool('premium', this)">
                            <div class="dot" style="background:#a855f7;"></div> Premium
                        </button>
                        <button class="type-btn type-btn-vip" onclick="setTool('vip', this)">
                            <div class="dot" style="background:#f59e0b;"></div> VIP
                        </button>
                        <button class="type-btn type-btn-eraser" onclick="setTool('empty', this)">
                            ✕ Remove
                        </button>
                    </div>

                    <!-- Row actions -->
                    <div class="row-actions">
                        <div style="font-size:12px; color:var(--muted);">Paint row:</div>
                        <button class="row-action-btn" onclick="paintAllRows('standard')" style="color:#60a5fa; border-color:rgba(59,130,246,0.3);">All → Standard</button>
                        <button class="row-action-btn" onclick="paintAllRows('premium')" style="color:#c084fc; border-color:rgba(168,85,247,0.3);">All → Premium</button>
                        <button class="row-action-btn" onclick="paintAllRows('vip')" style="color:#facc15; border-color:rgba(245,158,11,0.3);">All → VIP</button>
                        <button class="row-action-btn" onclick="clearAll()" style="color:#f87171;">Clear All</button>
                    </div>

                    <!-- Screen -->
                    <div class="screen-bar">
                        <div class="screen-line"></div>
                        <div class="screen-label">SCREEN</div>
                    </div>

                    <!-- Grid -->
                    <div class="seat-grid-designer">
                        <div class="seat-grid-inner" id="designerGrid"></div>
                    </div>

                    <!-- Seat summary -->
                    <div class="seat-summary" id="seatSummary">
                        <div class="seat-count-box">
                            <div style="font-size:18px; font-weight:700; color:#60a5fa;" id="cntStandard">0</div>
                            <div style="font-size:11px; color:var(--muted);">Standard</div>
                        </div>
                        <div class="seat-count-box">
                            <div style="font-size:18px; font-weight:700; color:#c084fc;" id="cntPremium">0</div>
                            <div style="font-size:11px; color:var(--muted);">Premium</div>
                        </div>
                        <div class="seat-count-box">
                            <div style="font-size:18px; font-weight:700; color:#facc15;" id="cntVIP">0</div>
                            <div style="font-size:11px; color:var(--muted);">VIP</div>
                        </div>
                        <div class="seat-count-box">
                            <div style="font-size:18px; font-weight:700;" id="cntTotal">0</div>
                            <div style="font-size:11px; color:var(--muted);">Total</div>
                        </div>
                    </div>

                    <div style="font-size:11px; color:#555; margin-top:10px; text-align:center;">
                        💡 Click a seat to paint • Click row label to paint entire row • Drag to paint multiple
                    </div>
                </div>
            </div>

            <!-- Edit Form -->
            <div id="editForm" style="display:none;">
                <div class="form-grid">
                    <div class="form-full">
                        <label>Hall Name *</label>
                        <input class="cinput" type="text" id="eHallName" />
                    </div>
                    <div class="form-full">
                        <label>Hall Type *</label>
                        <select class="cinput" id="eHallType">
                            <option value="0">2D</option>
                            <option value="1">3D</option>
                            <option value="2">IMAX</option>
                        </select>
                    </div>
                    <div class="form-full">
                        <label>Status</label>
                        <select class="cinput" id="eIsActive">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>

                <div style="margin-top:20px;">
                    <div style="font-size:13px; font-weight:600; color:var(--muted); letter-spacing:0.06em; margin-bottom:10px;">SEAT INFO</div>
                    <div class="seat-summary">
                        <div class="seat-count-box"><div style="font-size:18px; font-weight:700; color:#60a5fa;" id="editStandard">0</div><div style="font-size:11px; color:var(--muted);">Standard</div></div>
                        <div class="seat-count-box"><div style="font-size:18px; font-weight:700; color:#c084fc;" id="editPremium">0</div><div style="font-size:11px; color:var(--muted);">Premium</div></div>
                        <div class="seat-count-box"><div style="font-size:18px; font-weight:700; color:#facc15;" id="editVIP">0</div><div style="font-size:11px; color:var(--muted);">VIP</div></div>
                        <div class="seat-count-box"><div style="font-size:18px; font-weight:700;" id="editTotal">0</div><div style="font-size:11px; color:var(--muted);">Total</div></div>
                    </div>
                </div>

                <div class="delete-confirm" id="deleteConfirm">
                    <div style="font-size:14px; font-weight:600; color:#f87171; margin-bottom:8px;">⚠ Delete Hall</div>
                    <div style="font-size:13px; color:var(--muted); margin-bottom:12px;">This will permanently delete the hall and all its seats.</div>
                    <button class="cbtn" onclick="deleteHall()" style="background:#dc2626; width:100%; font-size:13px; padding:10px;">Confirm Delete</button>
                </div>
                <button onclick="toggleDelete()" style="background:none; border:1px solid rgba(229,9,20,0.3); color:#f87171; font-family:'DM Sans',sans-serif; font-size:13px; padding:9px 16px; border-radius:6px; cursor:pointer; margin-top:16px; width:100%;">🗑 Delete This Hall</button>
            </div>
        </div>

        <div class="panel-footer">
            <button class="cbtn-outline" onclick="closePanel()">Cancel</button>
            <button class="cbtn" id="saveBtn" onclick="saveHall()" style="flex:2;">Create Hall</button>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');

        if (!token) window.location.href = '/Auth/Login';
        if (user.role !== 'CinemaManager') window.location.href = '/';

        document.getElementById('managerName').textContent = user.fullName || 'Manager';

        let allHalls = [];
        let editingId = null;
        let isEditMode = false;
        let currentTool = 'standard';

        // seatMap[row][col] = 'empty' | 'standard' | 'premium' | 'vip'
        let seatMap = [];
        let isDragging = false;

        function authHeaders() {
            return { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` };
        }

        // ── Load Halls ────────────────────────────────────────
        async function loadHalls() {
            try {
                const res = await fetch('/api/halls', { headers: authHeaders() });
                const data = await res.json();
                if (data.success) {
                    allHalls = data.data;
                    updateStats();
                    renderHalls(allHalls);
                } else {
                    document.getElementById('noCinemaWarning').style.display = 'block';
                    document.getElementById('statsSection').style.display = 'none';
                    document.getElementById('hallList').innerHTML = '';
                }
            } catch {
                document.getElementById('hallList').innerHTML =
                    `<div class="empty"><div style="font-size:32px">⚠</div><div>Failed to load halls</div></div>`;
            }
        }

        function updateStats() {
            document.getElementById('totalHalls').textContent = allHalls.length;
            document.getElementById('totalSeats').textContent = allHalls.reduce((s, h) => s + h.totalSeats, 0);
            document.getElementById('activeHalls').textContent = allHalls.filter(h => h.isActive).length;
        }

        function getHallTypeBadge(type) {
            if (type === 'TwoD' || type === 0) return '<span class="badge badge-2d">2D</span>';
            if (type === 'ThreeD' || type === 1) return '<span class="badge badge-3d">3D</span>';
            return '<span class="badge badge-imax">IMAX</span>';
        }

        function renderHalls(halls) {
            const list = document.getElementById('hallList');
            if (!halls.length) {
                list.innerHTML = `<div class="empty"><div style="font-size:40px; margin-bottom:12px;">🪑</div><div style="font-size:16px; font-weight:500; margin-bottom:6px;">No halls yet</div><div style="font-size:13px;">Click "+ Add Hall" to design your first hall</div></div>`;
                return;
            }
            list.innerHTML = halls.map(h => `
                <div class="hall-card" onclick="selectHall('${h.id}')" id="card-${h.id}">
                    <div style="width:52px; height:52px; border-radius:10px; background:var(--surface3); display:flex; align-items:center; justify-content:center; font-size:24px; flex-shrink:0;">🎭</div>
                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                            <div style="font-size:15px; font-weight:600;">${h.hallName}</div>
                            ${getHallTypeBadge(h.hallType)}
                            <span class="badge ${h.isActive ? 'badge-active' : 'badge-inactive'}">${h.isActive ? 'Active' : 'Inactive'}</span>
                        </div>
                        <div style="display:flex; gap:16px; font-size:12px; color:var(--muted);">
                            <span>🪑 ${h.totalSeats} seats</span>
                            <span style="color:#60a5fa;">● ${h.standardSeats} Std</span>
                            <span style="color:#c084fc;">● ${h.premiumSeats} Prem</span>
                            <span style="color:#facc15;">● ${h.vipSeats} VIP</span>
                        </div>
                    </div>
                    <div style="color:var(--muted); font-size:18px;">›</div>
                </div>`).join('');
        }

        // ── Seat Designer ─────────────────────────────────────
        function generateGrid() {
            const rows = parseInt(document.getElementById('fRows').value) || 0;
            const seatsPerRow = parseInt(document.getElementById('fSeats').value) || 0;

            if (rows < 1 || seatsPerRow < 1 || rows > 26 || seatsPerRow > 30) {
                document.getElementById('designerWrap').style.display = 'none';
                return;
            }

            document.getElementById('designerWrap').style.display = 'block';

            // Init seatMap — preserve existing values if same size
            const newMap = [];
            for (let r = 0; r < rows; r++) {
                newMap[r] = [];
                for (let c = 0; c < seatsPerRow; c++) {
                    newMap[r][c] = (seatMap[r] && seatMap[r][c]) ? seatMap[r][c] : 'standard';
                }
            }
            seatMap = newMap;

            renderDesignerGrid(rows, seatsPerRow);
            updateSeatCounts();
        }

        function renderDesignerGrid(rows, seatsPerRow) {
            const aisleCol = parseInt(document.getElementById('aisleCol').value) || 0;
            const grid = document.getElementById('designerGrid');
            let html = '';

            for (let r = 0; r < rows; r++) {
                const rowLabel = String.fromCharCode(65 + r);
                html += `<div class="designer-row">
                    <div class="row-label-d" onclick="paintRow(${r})" title="Paint entire row" style="cursor:pointer;">${rowLabel}</div>`;

                for (let c = 0; c < seatsPerRow; c++) {
                    if (aisleCol > 0 && c === aisleCol) {
                        html += `<div style="width:12px; flex-shrink:0;"></div>`;
                    }
                    const type = seatMap[r][c];
                    html += `<div class="dseat ${type}"
                        id="ds-${r}-${c}"
                        onmousedown="startPaint(${r},${c})"
                        onmouseenter="dragPaint(${r},${c})"
                        onmouseup="stopPaint()"
                        title="${rowLabel}${c+1}">
                        ${c + 1}
                    </div>`;
                }
                html += `</div>`;
            }

            grid.innerHTML = html;
        }

        // ── Paint Tools ───────────────────────────────────────
        function setTool(tool, el) {
            currentTool = tool;
            document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active-tool'));
            el.classList.add('active-tool');
        }

        function startPaint(r, c) {
            isDragging = true;
            paintSeat(r, c);
        }

        function dragPaint(r, c) {
            if (isDragging) paintSeat(r, c);
        }

        function stopPaint() { isDragging = false; }

        document.addEventListener('mouseup', () => isDragging = false);

        function paintSeat(r, c) {
            seatMap[r][c] = currentTool;
            const el = document.getElementById(`ds-${r}-${c}`);
            if (el) {
                el.className = `dseat ${currentTool}`;
            }
            updateSeatCounts();
        }

        function paintRow(r) {
            const seatsPerRow = parseInt(document.getElementById('fSeats').value) || 0;
            for (let c = 0; c < seatsPerRow; c++) {
                paintSeat(r, c);
            }
        }

        function paintAllRows(type) {
            const rows = parseInt(document.getElementById('fRows').value) || 0;
            const seatsPerRow = parseInt(document.getElementById('fSeats').value) || 0;
            const prevTool = currentTool;
            currentTool = type;
            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < seatsPerRow; c++) {
                    paintSeat(r, c);
                }
            }
            currentTool = prevTool;
        }

        function clearAll() {
            const rows = parseInt(document.getElementById('fRows').value) || 0;
            const seatsPerRow = parseInt(document.getElementById('fSeats').value) || 0;
            const prevTool = currentTool;
            currentTool = 'empty';
            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < seatsPerRow; c++) {
                    paintSeat(r, c);
                }
            }
            currentTool = prevTool;
        }

        function updateSeatCounts() {
            let std = 0, prem = 0, vip = 0;
            seatMap.forEach(row => row.forEach(s => {
                if (s === 'standard') std++;
                else if (s === 'premium') prem++;
                else if (s === 'vip') vip++;
            }));
            document.getElementById('cntStandard').textContent = std;
            document.getElementById('cntPremium').textContent = prem;
            document.getElementById('cntVIP').textContent = vip;
            document.getElementById('cntTotal').textContent = std + prem + vip;
        }

        // Build seat data for API from seatMap
        function buildSeatData() {
            const rows = parseInt(document.getElementById('fRows').value);
            const seatsPerRow = parseInt(document.getElementById('fSeats').value);
            const seats = [];

            for (let r = 0; r < rows; r++) {
                const rowLabel = String.fromCharCode(65 + r);
                for (let c = 0; c < seatsPerRow; c++) {
                    const type = seatMap[r]?.[c];
                    if (type && type !== 'empty') {
                        seats.push({
                            row: rowLabel,
                            seatNumber: c + 1,
                            seatType: type === 'standard' ? 0 : type === 'premium' ? 1 : 2
                        });
                    }
                }
            }
            return seats;
        }

        // ── Panel Controls ────────────────────────────────────
        function openAddPanel() {
            isEditMode = false; editingId = null;
            seatMap = [];
            document.getElementById('fHallName').value = '';
            document.getElementById('fHallType').value = '0';
            document.getElementById('fRows').value = '';
            document.getElementById('fSeats').value = '';
            document.getElementById('aisleCol').value = '';
            document.getElementById('designerWrap').style.display = 'none';
            document.getElementById('formError').style.display = 'none';
            document.getElementById('formSuccess').style.display = 'none';
            document.getElementById('panelTitle').textContent = 'Add Hall';
            document.getElementById('panelSubtitle').textContent = 'Design your hall layout';
            document.getElementById('saveBtn').textContent = 'Create Hall';
            document.getElementById('addForm').style.display = 'block';
            document.getElementById('editForm').style.display = 'none';
            document.getElementById('slidePanel').classList.add('open');
            document.getElementById('overlay').classList.add('show');
        }

        function selectHall(id) {
            const hall = allHalls.find(h => h.id === id);
            if (!hall) return;
            isEditMode = true; editingId = hall.id;
            document.querySelectorAll('.hall-card').forEach(c => c.classList.remove('selected'));
            document.getElementById(`card-${id}`)?.classList.add('selected');
            document.getElementById('panelTitle').textContent = hall.hallName;
            document.getElementById('panelSubtitle').textContent = 'Edit hall details';
            document.getElementById('saveBtn').textContent = 'Update Hall';
            document.getElementById('addForm').style.display = 'none';
            document.getElementById('editForm').style.display = 'block';
            document.getElementById('deleteConfirm').style.display = 'none';
            document.getElementById('eHallName').value = hall.hallName;
            document.getElementById('eHallType').value = hall.hallType === 'TwoD' ? 0 : hall.hallType === 'ThreeD' ? 1 : hall.hallType === 'IMAX' ? 2 : hall.hallType;
            document.getElementById('eIsActive').value = hall.isActive.toString();
            document.getElementById('editStandard').textContent = hall.standardSeats;
            document.getElementById('editPremium').textContent = hall.premiumSeats;
            document.getElementById('editVIP').textContent = hall.vipSeats;
            document.getElementById('editTotal').textContent = hall.totalSeats;
            document.getElementById('formError').style.display = 'none';
            document.getElementById('formSuccess').style.display = 'none';
            document.getElementById('slidePanel').classList.add('open');
            document.getElementById('overlay').classList.add('show');
        }

        function closePanel() {
            document.getElementById('slidePanel').classList.remove('open');
            document.getElementById('overlay').classList.remove('show');
            document.querySelectorAll('.hall-card').forEach(c => c.classList.remove('selected'));
            editingId = null; isEditMode = false;
        }

        function toggleDelete() {
            const box = document.getElementById('deleteConfirm');
            box.style.display = box.style.display === 'none' ? 'block' : 'none';
        }

        // ── Save Hall ─────────────────────────────────────────
        async function saveHall() {
            if (isEditMode) { await updateHall(); return; }

            const hallName = document.getElementById('fHallName').value.trim();
            const hallType = parseInt(document.getElementById('fHallType').value);
            const rows = parseInt(document.getElementById('fRows').value);
            const seatsPerRow = parseInt(document.getElementById('fSeats').value);

            if (!hallName) { showError('Hall name is required'); return; }
            if (!rows || !seatsPerRow) { showError('Set rows and seats per row first'); return; }

            const seats = buildSeatData();
            if (!seats.length) { showError('Please paint at least one seat in the designer'); return; }

            // Build request using new custom seat layout
            // We'll send rows/seatsPerRow/standardRows/premiumRows as derived from seatMap
            // Count rows by type
            let standardRows = 0, premiumRows = 0;
            let prevType = null;
            for (let r = 0; r < rows; r++) {
                const rowTypes = seatMap[r]?.filter(s => s !== 'empty') || [];
                const dominant = rowTypes.length ? rowTypes[0] : 'empty';
                if (dominant === 'standard') standardRows++;
                else if (dominant === 'premium') premiumRows++;
            }

            const data = {
                hallName,
                hallType,
                rows,
                seatsPerRow,
                standardRows,
                premiumRows,
                customSeats: seats  // pass custom layout
            };

            await submitHall('POST', '/api/halls', data);
        }

        async function updateHall() {
            const data = {
                hallName: document.getElementById('eHallName').value.trim(),
                hallType: parseInt(document.getElementById('eHallType').value),
                isActive: document.getElementById('eIsActive').value === 'true'
            };
            if (!data.hallName) { showError('Hall name is required'); return; }
            await submitHall('PUT', `/api/halls/${editingId}`, data);
        }

        async function submitHall(method, url, data) {
            const btn = document.getElementById('saveBtn');
            btn.disabled = true; btn.textContent = 'Saving...';
            document.getElementById('formError').style.display = 'none';
            try {
                const res = await fetch(url, { method, headers: authHeaders(), body: JSON.stringify(data) });
                const result = await res.json();
                if (result.success) {
                    document.getElementById('formSuccess').textContent = isEditMode ? 'Hall updated!' : `Hall created with ${data.customSeats?.length || 0} seats!`;
                    document.getElementById('formSuccess').style.display = 'block';
                    await loadHalls();
                    setTimeout(closePanel, 1200);
                } else {
                    showError(result.message || 'Failed');
                }
            } catch { showError('Something went wrong'); }
            finally { btn.disabled = false; btn.textContent = isEditMode ? 'Update Hall' : 'Create Hall'; }
        }

        async function deleteHall() {
            if (!editingId) return;
            try {
                const res = await fetch(`/api/halls/${editingId}`, { method: 'DELETE', headers: authHeaders() });
                const result = await res.json();
                if (result.success) { await loadHalls(); closePanel(); }
                else alert(result.message);
            } catch { alert('Failed to delete'); }
        }

        function showError(msg) {
            const el = document.getElementById('formError');
            el.textContent = msg; el.style.display = 'block';
        }

        function logout() { localStorage.clear(); window.location.href = '/Auth/Login'; }

        loadHalls();
    </script>
</body>
</html>
