@{
    ViewData["Title"] = "Book Tickets";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Book Tickets</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --red: #E50914; --red-dark: #b20710;
            --bg: #080808; --surface: #111111;
            --surface2: #191919; --surface3: #222222;
            --border: #282828; --text: #f5f5f5;
            --muted: #777777; --muted2: #555555;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: var(--text); font-family: 'Outfit', sans-serif; min-height: 100vh; }
        .brand { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.06em; }

        .navbar {
            position: fixed; top: 0; left: 0; right: 0; height: 62px; z-index: 100;
            background: rgba(8,8,8,0.97); border-bottom: 1px solid var(--border);
            display: flex; align-items: center; padding: 0 32px; gap: 24px;
        }

        .main { padding-top: 62px; max-width: 1000px; margin: 0 auto; padding: 82px 32px 80px; }

        /* Movie header */
        .movie-header {
            display: flex; gap: 20px; align-items: center;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 14px; padding: 20px; margin-bottom: 32px;
        }
        .movie-poster-sm {
            width: 60px; height: 84px; border-radius: 8px;
            object-fit: cover; flex-shrink: 0; background: var(--surface3);
        }

        .section-title {
            font-size: 18px; font-weight: 700; margin-bottom: 16px;
            display: flex; align-items: center; gap: 10px;
        }
        .section-title::before {
            content: ''; width: 3px; height: 18px;
            background: var(--red); border-radius: 2px;
        }

        /* Date pills */
        .date-scroll { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none; margin-bottom: 24px; }
        .date-scroll::-webkit-scrollbar { display: none; }
        .date-pill {
            flex-shrink: 0; text-align: center; min-width: 70px;
            padding: 12px 16px; border-radius: 10px;
            border: 1px solid var(--border); background: var(--surface);
            cursor: pointer; transition: all 0.2s;
        }
        .date-pill:hover { border-color: #444; }
        .date-pill.active { border-color: var(--red); background: rgba(229,9,20,0.1); }
        .date-pill .day { font-size: 11px; color: var(--muted); font-weight: 500; }
        .date-pill .date { font-size: 20px; font-weight: 700; line-height: 1.2; }
        .date-pill .month { font-size: 11px; color: var(--muted); }

        /* Format filter */
        .format-pill {
            padding: 7px 18px; border-radius: 20px; font-size: 13px; font-weight: 600;
            border: 1px solid var(--border); background: var(--surface);
            color: var(--muted); cursor: pointer; transition: all 0.2s;
        }
        .format-pill:hover { border-color: #444; color: var(--text); }
        .format-pill.active { background: var(--red); border-color: var(--red); color: white; }

        /* Cinema card */
        .cinema-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 14px; padding: 22px; margin-bottom: 14px;
            transition: border-color 0.2s;
        }
        .cinema-card:hover { border-color: #3a3a3a; }

        /* Showtime btn */
        .showtime-btn {
            display: inline-flex; flex-direction: column; align-items: center;
            padding: 12px 18px; border-radius: 10px; cursor: pointer;
            border: 1px solid rgba(229,9,20,0.4); background: rgba(229,9,20,0.08);
            transition: all 0.2s; min-width: 88px;
        }
        .showtime-btn:hover { border-color: var(--red); background: rgba(229,9,20,0.18); transform: translateY(-2px); }
        .showtime-btn.filling { border-color: #f59e0b; background: rgba(245,158,11,0.08); }
        .showtime-btn.almost-full { border-color: #ef4444; background: rgba(239,68,68,0.08); }
        .showtime-btn .time { font-size: 16px; font-weight: 700; color: var(--text); }
        .showtime-btn .avail { font-size: 10px; color: var(--muted); margin-top: 3px; }

        .badge-hall {
            display: inline-flex; padding: 2px 8px; border-radius: 4px;
            font-size: 11px; font-weight: 700;
        }
        .badge-2d { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); }
        .badge-3d { background: rgba(168,85,247,0.15); color: #c084fc; border: 1px solid rgba(168,85,247,0.3); }
        .badge-imax { background: rgba(234,179,8,0.15); color: #facc15; border: 1px solid rgba(234,179,8,0.3); }

        .login-btn {
            background: var(--red); color: white; font-family: 'Outfit', sans-serif;
            font-weight: 600; font-size: 13px; padding: 8px 18px;
            border: none; border-radius: 7px; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center;
        }

        .user-menu { position: relative; }
        .user-avatar {
            width: 34px; height: 34px; border-radius: 50%; background: var(--red);
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700; cursor: pointer;
        }
        .user-dropdown {
            position: absolute; top: calc(100% + 10px); right: 0; width: 200px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 10px; padding: 8px; display: none; z-index: 200;
            box-shadow: 0 16px 40px rgba(0,0,0,0.6);
        }
        .user-dropdown.show { display: block; }
        .dropdown-item {
            display: flex; align-items: center; gap: 10px; padding: 9px 12px;
            border-radius: 6px; font-size: 14px; color: var(--muted);
            cursor: pointer; transition: all 0.15s; text-decoration: none;
        }
        .dropdown-item:hover { background: var(--surface2); color: var(--text); }

        .empty { text-align: center; padding: 60px; color: var(--muted); }
    </style>
</head>
<body>

    <nav class="navbar">
        <button onclick="history.back()" style="background:none; border:none; color:var(--muted); font-size:22px; cursor:pointer; padding:4px 8px;">←</button>
        <a href="/" style="text-decoration:none;">
            <span class="brand" style="font-size:26px; color:var(--red);">CINEBOOK</span>
        </a>
        <div style="flex:1;"></div>
        <div id="guestNav"><a href="/Auth/Login" class="login-btn">Sign In</a></div>
        <div id="userNav" style="display:none;">
            <div class="user-menu">
                <div class="user-avatar" id="userAvatar" onclick="toggleDropdown()">?</div>
                <div class="user-dropdown" id="userDropdown">
                    <div style="padding:10px 12px 8px; border-bottom:1px solid var(--border); margin-bottom:6px;">
                        <div style="font-size:14px; font-weight:600;" id="dropdownName"></div>
                    </div>
                    <a class="dropdown-item" href="/Profile">👤 My Profile</a>
                    <a class="dropdown-item" href="/Bookings">🎟 My Bookings</a>
                    <div class="dropdown-item" onclick="logout()" style="color:#f87171;">🚪 Sign Out</div>
                </div>
            </div>
        </div>
    </nav>

    <div class="main">

        <!-- Movie header -->
        <div class="movie-header" id="movieHeader">
            <div style="font-size:32px;">🎬</div>
            <div>
                <div style="font-size:11px; color:var(--muted); letter-spacing:0.06em; margin-bottom:4px;">BOOKING FOR</div>
                <div style="font-size:20px; font-weight:700;" id="movieTitle">Loading...</div>
                <div style="font-size:13px; color:var(--muted); margin-top:4px;" id="movieMeta2"></div>
            </div>
        </div>

        <!-- Date Selector -->
        <div class="section-title">Select Date</div>
        <div class="date-scroll" id="dateSelector"></div>

        <!-- Format Filter -->
        <div style="display:flex; gap:8px; margin-bottom:28px; flex-wrap:wrap;" id="formatFilter"></div>

        <!-- Showtimes -->
        <div class="section-title">Available Shows</div>
        <div id="showtimesByCinema">
            <div class="empty">
                <div style="font-size:40px; margin-bottom:12px;">🎬</div>
                <div>Loading showtimes...</div>
            </div>
        </div>

    </div>

    <script>
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');
        const movieId = window.location.pathname.split('/').slice(-2)[0];

        if (token && user.fullName) {
            document.getElementById('guestNav').style.display = 'none';
            document.getElementById('userNav').style.display = 'block';
            const initials = user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2);
            document.getElementById('userAvatar').textContent = initials;
            document.getElementById('dropdownName').textContent = user.fullName;
        }

        function toggleDropdown() { document.getElementById('userDropdown').classList.toggle('show'); }
        document.addEventListener('click', e => {
            if (!e.target.closest('.user-menu')) document.getElementById('userDropdown')?.classList.remove('show');
        });
        function logout() { localStorage.clear(); window.location.href = '/Auth/Login'; }

        let allShowtimes = [];
        let selectedDate = '';
        let selectedFormat = 'all';

        function formatTime(isoStr) {
            if (!isoStr) return '';
            const timePart = isoStr.split('T')[1]?.substring(0, 5) || '';
            if (!timePart) return '';
            const [h, m] = timePart.split(':');
            const hour = parseInt(h);
            const ampm = hour >= 12 ? 'pm' : 'am';
            const hour12 = hour % 12 || 12;
            return `${hour12}:${m} ${ampm}`;
        }

        async function loadMovie() {
            try {
                const res = await fetch(`/api/movies/${movieId}`);
                const data = await res.json();
                if (data.success) {
                    const m = data.data;
                    document.getElementById('movieTitle').textContent = m.title;
                    document.getElementById('movieMeta2').textContent =
                        `${m.durationTime} min • ${m.language} • ${m.certificateRating}`;

                    const header = document.getElementById('movieHeader');
                    if (m.posterUrl) {
                        header.innerHTML = `
                            <img class="movie-poster-sm" src="${m.posterUrl}" onerror="this.style.display='none'" />
                            <div>
                                <div style="font-size:11px; color:var(--muted); letter-spacing:0.06em; margin-bottom:4px;">BOOKING FOR</div>
                                <div style="font-size:22px; font-weight:700;">${m.title}</div>
                                <div style="font-size:13px; color:var(--muted); margin-top:4px;">${m.durationTime} min • ${m.language} • ${m.certificateRating}</div>
                            </div>
                            <div style="margin-left:auto;">
                                <a href="/Movies/${movieId}" style="font-size:13px; color:var(--muted); text-decoration:none;">← Back to Movie</a>
                            </div>`;
                    }
                }
            } catch {}
        }

        async function loadShowtimes() {
            try {
                const res = await fetch(`/api/showtimes/movie/${movieId}`);
                const data = await res.json();
                if (data.success && data.data.length) {
                    allShowtimes = data.data;
                    buildDateSelector();
                    buildFormatFilter();
                    renderShowtimes();
                } else {
                    document.getElementById('showtimesByCinema').innerHTML = `
                        <div class="empty">
                            <div style="font-size:48px; margin-bottom:16px;">📭</div>
                            <div style="font-size:18px; font-weight:600; margin-bottom:8px;">No showtimes available</div>
                            <div style="font-size:14px;">Check back later for upcoming shows</div>
                        </div>`;
                    document.getElementById('dateSelector').innerHTML = '';
                    document.getElementById('formatFilter').innerHTML = '';
                }
            } catch {}
        }

        function buildDateSelector() {
            const dates = [...new Set(allShowtimes.map(s => s.startTime.split('T')[0]))].sort();
            if (!dates.length) return;
            selectedDate = dates[0];

            document.getElementById('dateSelector').innerHTML = dates.map((d, i) => {
                const [yr, mo, dy] = d.split('-');
                const date = new Date(parseInt(yr), parseInt(mo) - 1, parseInt(dy));
                const dayName = date.toLocaleDateString('en-IN', { weekday: 'short' });
                const monthName = date.toLocaleDateString('en-IN', { month: 'short' });
                const isToday = d === new Date().toISOString().split('T')[0];
                return `
                    <div class="date-pill ${i === 0 ? 'active' : ''}" onclick="selectDate('${d}', this)">
                        <div class="day">${isToday ? 'TODAY' : dayName.toUpperCase()}</div>
                        <div class="date">${parseInt(dy)}</div>
                        <div class="month">${monthName}</div>
                    </div>`;
            }).join('');
        }

        function selectDate(date, el) {
            selectedDate = date;
            document.querySelectorAll('.date-pill').forEach(p => p.classList.remove('active'));
            el.classList.add('active');
            renderShowtimes();
        }

        function buildFormatFilter() {
            const formats = [...new Set(allShowtimes.map(s => s.hallType))];
            const container = document.getElementById('formatFilter');
            container.innerHTML = `<div class="format-pill active" onclick="selectFormat('all', this)">All Formats</div>`;
            formats.forEach(f => {
                const label = f === 'TwoD' || f === 0 ? '2D' : f === 'ThreeD' || f === 1 ? '3D' : 'IMAX';
                container.innerHTML += `<div class="format-pill" onclick="selectFormat('${f}', this)">${label}</div>`;
            });
        }

        function selectFormat(format, el) {
            selectedFormat = format;
            document.querySelectorAll('.format-pill').forEach(p => p.classList.remove('active'));
            el.classList.add('active');
            renderShowtimes();
        }

        function renderShowtimes() {
            let filtered = allShowtimes;
            if (selectedDate) filtered = filtered.filter(s => s.startTime.split('T')[0] === selectedDate);
            if (selectedFormat !== 'all') filtered = filtered.filter(s => s.hallType === selectedFormat);

            const container = document.getElementById('showtimesByCinema');
            if (!filtered.length) {
                container.innerHTML = `<div class="empty"><div style="font-size:36px; margin-bottom:12px;">📭</div><div>No shows for selected date/format</div></div>`;
                return;
            }

            const groups = {};
            filtered.forEach(s => {
                if (!groups[s.cinemaId]) groups[s.cinemaId] = { name: s.cinemaName, halls: {} };
                if (!groups[s.cinemaId].halls[s.hallId])
                    groups[s.cinemaId].halls[s.hallId] = { name: s.hallName, type: s.hallType, showtimes: [] };
                groups[s.cinemaId].halls[s.hallId].showtimes.push(s);
            });

            container.innerHTML = Object.values(groups).map(cinema => `
                <div class="cinema-card">
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                        <div style="font-size:17px; font-weight:700;">🏟 ${cinema.name}</div>
                        <div style="font-size:12px; color:var(--muted);">Free cancellation available</div>
                    </div>
                    ${Object.values(cinema.halls).map(hall => `
                        <div style="margin-bottom:18px;">
                            <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                                ${getHallBadge(hall.type)}
                                <span style="font-size:13px; color:var(--muted);">${hall.name}</span>
                                <span style="font-size:12px; color:var(--muted2);">•</span>
                                <span style="font-size:12px; color:var(--muted);">
                                    <span style="color:#60a5fa;">Std ₹${hall.showtimes[0].priceStandard}</span> •
                                    <span style="color:#c084fc;">Prem ₹${hall.showtimes[0].pricePremium}</span> •
                                    <span style="color:#facc15;">VIP ₹${hall.showtimes[0].priceVIP}</span>
                                </span>
                            </div>
                            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                                ${hall.showtimes.map(s => {
                                    const timeStr = formatTime(s.startTime);
                                    const pct = s.totalSeats > 0 ? (s.availableSeats / s.totalSeats) * 100 : 0;
                                    const cls = pct > 50 ? '' : pct > 20 ? 'filling' : 'almost-full';
                                    const availLabel = pct > 50 ? 'Available' : pct > 20 ? 'Filling fast' : 'Almost full';
                                    return `
                                        <div class="showtime-btn ${cls}" onclick="goToSeats('${s.id}')">
                                            <div class="time">${timeStr}</div>
                                            <div class="avail" style="color:${pct > 50 ? '#22c55e' : pct > 20 ? '#f59e0b' : '#ef4444'}">
                                                ${availLabel}
                                            </div>
                                        </div>`;
                                }).join('')}
                            </div>
                        </div>`).join('')}
                </div>`).join('');
        }

        function getHallBadge(type) {
            if (type === 'TwoD' || type === 0) return '<span class="badge-hall badge-2d">2D</span>';
            if (type === 'ThreeD' || type === 1) return '<span class="badge-hall badge-3d">3D</span>';
            return '<span class="badge-hall badge-imax">IMAX</span>';
        }

        function goToSeats(showtimeId) {
            if (!token) { window.location.href = '/Auth/Login'; return; }   
            window.location.href = `/Booking/Seats?showtimeId=${showtimeId}&movieId=${movieId}`;
        }

        loadMovie();
        loadShowtimes();
    </script>
</body>
</html>