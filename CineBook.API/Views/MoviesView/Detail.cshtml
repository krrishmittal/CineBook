@{
    ViewData["Title"] = "Movie Detail";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Movie Detail</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --red: #E50914; --red-dark: #b20710;
            --bg: #080808; --surface: #111111;
            --surface2: #191919; --surface3: #222222;
            --border: #282828; --text: #f5f5f5;
            --muted: #777777; --muted2: #555555;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: var(--text); font-family: 'Outfit', sans-serif; min-height: 100vh; }
        .brand { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.06em; }

        .navbar {
            position: fixed; top: 0; left: 0; right: 0; height: 62px; z-index: 100;
            background: rgba(8,8,8,0.95); border-bottom: 1px solid var(--border);
            backdrop-filter: blur(16px);
            display: flex; align-items: center; padding: 0 32px; gap: 24px;
        }

        .hero {
            margin-top: 62px; position: relative;
            height: 500px; overflow: hidden;
        }
        .hero-bg {
            width: 100%; height: 100%; object-fit: cover;
            filter: brightness(0.2); transform: scale(1.05);
        }
        .hero-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to right, rgba(8,8,8,0.99) 0%, rgba(8,8,8,0.75) 50%, transparent 100%),
                        linear-gradient(to top, rgba(8,8,8,1) 0%, transparent 60%);
        }
        .hero-content {
            position: absolute; inset: 0;
            display: flex; align-items: center;
            padding: 0 60px; gap: 40px;
        }
        .movie-poster-large {
            width: 210px; height: 300px; border-radius: 12px;
            object-fit: cover; flex-shrink: 0;
            box-shadow: 0 24px 64px rgba(0,0,0,0.9);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .movie-poster-placeholder {
            width: 210px; height: 300px; border-radius: 12px;
            background: var(--surface3); display: flex; align-items: center;
            justify-content: center; font-size: 60px; flex-shrink: 0;
        }

        .cert-tag {
            display: inline-flex; align-items: center;
            background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
            color: #ccc; font-size: 11px; font-weight: 700;
            padding: 3px 10px; border-radius: 4px; letter-spacing: 0.06em;
        }
        .genre-tag {
            display: inline-flex; padding: 4px 12px; border-radius: 20px;
            background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);
            font-size: 12px; color: #bbb;
        }

        .main { max-width: 1200px; margin: 0 auto; padding: 40px 32px 80px; }

        .section-title {
            font-size: 18px; font-weight: 700; margin-bottom: 20px;
            display: flex; align-items: center; gap: 10px;
        }
        .section-title::before {
            content: ''; width: 3px; height: 18px;
            background: var(--red); border-radius: 2px;
        }

        .btn-primary {
            background: var(--red); color: white; font-family: 'Outfit', sans-serif;
            font-weight: 700; font-size: 16px; padding: 14px 32px;
            border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s;
            display: inline-flex; align-items: center; gap: 10px;
            text-decoration: none;
        }
        .btn-primary:hover { background: var(--red-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(229,9,20,0.3); }

        /* ── Trailer in Hero ── */
        .hero-trailer-container {
            flex: 1; height: 280px; position: relative;
            border-radius: 12px; overflow: hidden;
            background: #000; border: 1px solid rgba(255,255,255,0.15);
            box-shadow: 0 24px 64px rgba(0,0,0,0.6);
        }
        .hero-trailer-thumbnail {
            width: 100%; height: 100%; object-fit: cover;
            filter: brightness(0.6); transition: filter 0.3s;
        }
        .hero-trailer-thumbnail:hover { filter: brightness(0.5); }
        .hero-play-overlay {
            position: absolute; inset: 0;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; background: rgba(0,0,0,0.2);
            transition: background 0.3s;
        }
        .hero-play-overlay:hover { background: rgba(0,0,0,0.4); }
        .hero-play-btn {
            width: 64px; height: 64px; border-radius: 50%;
            background: rgba(229,9,20,0.9); border: 3px solid white;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s; backdrop-filter: blur(4px);
        }
        .hero-play-btn:hover { background: var(--red); transform: scale(1.1); box-shadow: 0 0 40px rgba(229,9,20,0.5); }
        .hero-play-btn svg { width: 26px; height: 26px; fill: white; margin-left: 3px; }

        .hero-trailer-iframe {
            position: absolute; inset: 0;
            width: 100%; height: 100%;
            border: none; display: none;
        }

        .cast-scroll { display: flex; gap: 14px; overflow-x: auto; padding-bottom: 8px; scrollbar-width: none; }
        .cast-scroll::-webkit-scrollbar { display: none; }
        .cast-card { flex-shrink: 0; width: 90px; text-align: center; }
        .cast-avatar {
            width: 70px; height: 70px; border-radius: 50%;
            background: var(--surface3); margin: 0 auto 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 26px; border: 2px solid var(--border);
        }

        .star {
            font-size: 28px; cursor: pointer; color: #333;
            transition: color 0.15s; user-select: none;
        }

        .empty { text-align: center; padding: 40px; color: var(--muted); }

        .user-menu { position: relative; }
        .user-avatar {
            width: 34px; height: 34px; border-radius: 50%; background: var(--red);
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700; cursor: pointer;
            font-family: 'Bebas Neue', sans-serif;
        }
        .user-dropdown {
            position: absolute; top: calc(100% + 10px); right: 0; width: 200px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 10px; padding: 8px; display: none; z-index: 200;
            box-shadow: 0 16px 40px rgba(0,0,0,0.6);
        }
        .user-dropdown.show { display: block; }
        .dropdown-item {
            display: flex; align-items: center; gap: 10px; padding: 9px 12px;
            border-radius: 6px; font-size: 14px; color: var(--muted);
            cursor: pointer; transition: all 0.15s; text-decoration: none;
        }
        .dropdown-item:hover { background: var(--surface2); color: var(--text); }

        .login-btn {
            background: var(--red); color: white; font-family: 'Outfit', sans-serif;
            font-weight: 600; font-size: 13px; padding: 8px 18px;
            border: none; border-radius: 7px; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.4s ease forwards; }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <button onclick="history.back()" style="background:none; border:none; color:var(--muted); font-size:22px; cursor:pointer; padding:4px 8px;">←</button>
        <a href="/" style="text-decoration:none;">
            <span class="brand" style="font-size:26px; color:var(--red);">CINEBOOK</span>
        </a>
        <div style="flex:1;"></div>
        <div id="guestNav"><a href="/Auth/Login" class="login-btn">Sign In</a></div>
        <div id="userNav" style="display:none;">
            <div class="user-menu">
                <div class="user-avatar" id="userAvatar" onclick="toggleDropdown()">?</div>
                <div class="user-dropdown" id="userDropdown">
                    <div style="padding:10px 12px 8px; border-bottom:1px solid var(--border); margin-bottom:6px;">
                        <div style="font-size:14px; font-weight:600;" id="dropdownName"></div>
                        <div style="font-size:12px; color:var(--muted);">🎬 Movie Fan</div>
                    </div>
                    <a class="dropdown-item" href="/Profile">👤 My Profile</a>
                    <a class="dropdown-item" href="/Bookings">🎟 My Bookings</a>
                    <div class="dropdown-item" onclick="logout()" style="color:#f87171;">🚪 Sign Out</div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <div class="hero" id="movieHero">
        <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);">
            <div style="font-size:40px;">🎬</div>
        </div>
    </div>

    <!-- Main -->
    <div class="main">

        <!-- Movie Info -->
        <div id="movieInfoSection" style="display:none; margin-bottom:48px;" class="fade-up">
            <div style="display:flex; gap:32px; align-items:flex-start;">
                <div style="flex:1;">
                    <div style="font-size:15px; color:#bbb; line-height:1.8; margin-bottom:24px;" id="movieDesc"></div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:24px;" id="movieMeta"></div>
                </div>
                <div style="width:300px; flex-shrink:0;">
                    <div style="font-size:12px; font-weight:600; color:var(--muted); letter-spacing:0.08em; margin-bottom:12px;">CAST</div>
                    <div class="cast-scroll" id="castSection"></div>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div id="reviewsSection" style="margin-bottom:48px;">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
                <div class="section-title" style="margin-bottom:0;">Reviews & Ratings</div>
                <div id="avgRatingBadge" style="display:none; align-items:baseline; gap:6px;">
                    <span style="font-size:28px; font-weight:700; color:#f59e0b;" id="avgRating">0.0</span>
                    <span style="font-size:14px; color:var(--muted);" id="totalReviews">0 reviews</span>
                </div>
            </div>

            <!-- Write Review -->
            <div id="writeReviewSection" style="display:none; margin-bottom:24px;">
                <div style="background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:20px;">
                    <div style="font-size:14px; font-weight:600; margin-bottom:14px;">✍ Write a Review</div>
                    <div style="margin-bottom:14px;">
                        <div style="font-size:12px; color:var(--muted); margin-bottom:8px; letter-spacing:0.06em;">YOUR RATING *</div>
                        <div id="starRating" style="display:flex; gap:4px;"></div>
                    </div>
                    <div style="margin-bottom:14px;">
                        <textarea id="reviewComment"
                            placeholder="Share your thoughts about this movie... (optional)"
                            style="width:100%; background:var(--surface2); border:1px solid var(--border);
                                   border-radius:8px; padding:12px; color:var(--text);
                                   font-family:'Outfit',sans-serif; font-size:14px; outline:none;
                                   resize:vertical; min-height:90px; transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='var(--red)'"
                            onblur="this.style.borderColor='var(--border)'"></textarea>
                    </div>
                    <div style="display:flex; align-items:center; gap:12px;">
                        <button onclick="submitReview()"
                            style="background:var(--red); color:white; font-family:'Outfit',sans-serif;
                                   font-weight:600; font-size:14px; padding:10px 24px;
                                   border:none; border-radius:8px; cursor:pointer;">
                            Submit Review
                        </button>
                        <div id="reviewAlert" style="font-size:13px; display:none;"></div>
                    </div>
                </div>
            </div>

            <!-- Login to review -->
            <div id="loginToReview" style="display:none; margin-bottom:24px;">
                <div style="background:var(--surface); border:1px solid var(--border); border-radius:12px;
                            padding:16px 20px; display:flex; align-items:center; justify-content:space-between;">
                    <div style="font-size:14px; color:var(--muted);">Sign in to write a review</div>
                    <a href="/Auth/Login" style="background:var(--red); color:white; font-family:'Outfit',sans-serif;
                       font-weight:600; font-size:13px; padding:8px 18px; border-radius:6px; text-decoration:none;">
                        Sign In
                    </a>
                </div>
            </div>

            <!-- Reviews List -->
            <div id="reviewsList">
                <div style="text-align:center; padding:30px; color:var(--muted);">Loading reviews...</div>
            </div>
        </div>

    </div>

    <script>
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');
        const movieId = window.location.pathname.split('/').pop();

        let selectedRating = 0;
        let myReviewId = null;
        let trailerEmbedUrl = '';

        // Auth UI
        if (token && user.fullName) {
            document.getElementById('guestNav').style.display = 'none';
            document.getElementById('userNav').style.display = 'block';
            const initials = user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2);
            document.getElementById('userAvatar').textContent = initials;
            document.getElementById('dropdownName').textContent = user.fullName;
            document.getElementById('writeReviewSection').style.display = 'block';
            document.getElementById('loginToReview').style.display = 'none';
            buildStars();
        } else {
            document.getElementById('loginToReview').style.display = 'block';
        }

        function toggleDropdown() { document.getElementById('userDropdown').classList.toggle('show'); }
        document.addEventListener('click', e => {
            if (!e.target.closest('.user-menu')) document.getElementById('userDropdown')?.classList.remove('show');
        });
        function logout() { localStorage.clear(); window.location.href = '/Auth/Login'; }

        function formatDateStr(isoStr) {
            if (!isoStr) return '';
            const datePart = isoStr.split('T')[0];
            const [yr, mo, dy] = datePart.split('-');
            return new Date(parseInt(yr), parseInt(mo) - 1, parseInt(dy))
                .toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
        }

        // ── Load Movie ────────────────────────────────────────
        async function loadMovie() {
            try {
                const res = await fetch(`/api/movies/${movieId}`);
                const data = await res.json();
                if (data.success) {
                    renderHero(data.data);
                    renderMovieInfo(data.data);
                }
            } catch {}
        }

        let isFavourited = false;

                // ── Favourite Toggle ──────────────────────────────────
        async function toggleHeroFavourite(event, movieId) {
            event.preventDefault();
            event.stopPropagation();

            const token = localStorage.getItem('token');
            if (!token) {
                window.location.href = '/Auth/Login';
                return;
            }

            try {
                const res = await fetch(`/api/favourites/toggle/${movieId}`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    }
                });

                if (res.ok) {
                    const data = await res.json();
                    const btn = document.getElementById(`heroHeart-${movieId}`);
                    if (btn) {
                        btn.textContent = data.data.isFavourited ? '❤️' : '🤍';
                        btn.style.background = data.data.isFavourited 
                            ? 'rgba(229, 9, 20, 0.2)' 
                            : 'rgba(255,255,255,0.1)';
                    }
                } else if (res.status === 401) {
                    window.location.href = '/Auth/Login';
                }
            } catch (err) {
                console.error('Failed to toggle favourite:', err);
            }
        }

        async function checkFavourite() {
            if (!token) return;
            try {
                const res = await fetch('/api/favourites/ids', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await res.json();
                if (data.success) {
                    isFavourited = data.data.includes(movieId);
                    updateHeartBtn();
                }
            } catch {}
        }

        function updateHeartBtn() {
            const btn = document.getElementById('heartBtn');
            if (!btn) return;
            btn.innerHTML = isFavourited ? '❤️' : '🤍';
            btn.style.background = isFavourited
                ? 'rgba(229,9,20,0.3)'
                : 'rgba(255,255,255,0.1)';
            btn.style.borderColor = isFavourited
                ? 'rgba(229,9,20,0.6)'
                : 'rgba(255,255,255,0.2)';
        }

        async function toggleFavourite() {
            if (!token) { window.location.href = '/Auth/Login'; return; }
            try {
                const res = await fetch(`/api/favourites/toggle/${movieId}`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await res.json();
                if (data.success) {
                    isFavourited = data.data;
                    updateHeartBtn();
                }
            } catch {}
        }

        function renderHero(m) {
            let trailerHtml = '';
            if (m.trailerUrl) {
                let videoId = '';
                if (m.trailerUrl.includes('youtu.be/')) {
                    videoId = m.trailerUrl.split('youtu.be/')[1].split('?')[0];
                } else if (m.trailerUrl.includes('youtube.com/watch')) {
                    videoId = new URL(m.trailerUrl).searchParams.get('v');
                }

                if (videoId) {
                    trailerEmbedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
                    const thumbUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
                    trailerHtml = `
                        <div class="hero-trailer-container" id="heroTrailerContainer">
                            <img id="heroTrailerThumb" class="hero-trailer-thumbnail" src="${thumbUrl}" alt="Trailer" 
                                 onerror="this.src='https://img.youtube.com/vi/${videoId}/hqdefault.jpg'" />
                            <div class="hero-play-overlay" onclick="playHeroTrailer()" id="heroPlayOverlay">
                                <div class="hero-play-btn">
                                    <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                </div>
                            </div>
                            <iframe id="heroTrailerIframe" class="hero-trailer-iframe" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>
                        </div>`;
                } else if (m.trailerUrl) {
                    trailerEmbedUrl = m.trailerUrl;
                    trailerHtml = `
                        <div class="hero-trailer-container" id="heroTrailerContainer">
                            <img id="heroTrailerThumb" class="hero-trailer-thumbnail" src="${m.posterUrl}" alt="Trailer" />
                            <div class="hero-play-overlay" onclick="playHeroTrailer()" id="heroPlayOverlay">
                                <div class="hero-play-btn">
                                    <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                </div>
                            </div>
                            <iframe id="heroTrailerIframe" class="hero-trailer-iframe" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>
                        </div>`;
                }
            }

            document.getElementById('movieHero').innerHTML = `
                ${m.posterUrl ? `<img class="hero-bg" src="${m.posterUrl}" alt="${m.title}" />` : ''}
                <div class="hero-overlay"></div>
                <div class="hero-content">
                    ${m.posterUrl
                        ? `<img class="movie-poster-large" src="${m.posterUrl}" alt="${m.title}" />`
                        : `<div class="movie-poster-placeholder">🎬</div>`}
                    <div style="flex:1; display:flex; flex-direction:column; gap:24px;">
                        <div>
                            <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px; flex-wrap:wrap;">
                                <span class="cert-tag">${m.certificateRating}</span>
                                ${m.genre.split(',').map(g => `<span class="genre-tag">${g.trim()}</span>`).join('')}
                            </div>
                            <h1 style="font-family:'Bebas Neue',sans-serif; font-size:58px; line-height:1; letter-spacing:0.02em; margin-bottom:12px;">${m.title}</h1>
                            <div style="display:flex; align-items:center; gap:16px; font-size:13px; color:#aaa; flex-wrap:wrap;">
                                <span>⏱ ${m.durationTime} min</span>
                                <span>🌐 ${m.language}</span>
                                <span>🎬 ${m.director}</span>
                                <span>📅 ${new Date(m.releaseDate).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'})}</span>
                            </div>
                        </div>
                        <div>
                            <a class="btn-primary" href="/Movies/${movieId}/Book">
                                🎟 Book Tickets
                            </a>
                        </div>
                    </div>
                    ${trailerHtml}
                </div>`;
        }

        function playHeroTrailer() {
            if (!trailerEmbedUrl) return;
            document.getElementById('heroTrailerThumb').style.display = 'none';
            document.getElementById('heroPlayOverlay').style.display = 'none';
            const iframe = document.getElementById('heroTrailerIframe');
            iframe.src = trailerEmbedUrl;
            iframe.style.display = 'block';
        }

        function renderMovieInfo(m) {
            document.getElementById('movieInfoSection').style.display = 'block';
            document.getElementById('movieDesc').textContent = m.description;

            document.getElementById('movieMeta').innerHTML = `
                <div style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px;">
                    <div style="font-size:11px; color:var(--muted); margin-bottom:4px; letter-spacing:0.06em;">DIRECTOR</div>
                    <div style="font-size:14px; font-weight:600;">${m.director}</div>
                </div>
                <div style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px;">
                    <div style="font-size:11px; color:var(--muted); margin-bottom:4px; letter-spacing:0.06em;">DURATION</div>
                    <div style="font-size:14px; font-weight:600;">${m.durationTime} minutes</div>
                </div>
                <div style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px;">
                    <div style="font-size:11px; color:var(--muted); margin-bottom:4px; letter-spacing:0.06em;">LANGUAGE</div>
                    <div style="font-size:14px; font-weight:600;">${m.language}</div>
                </div>
                <div style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:14px;">
                    <div style="font-size:11px; color:var(--muted); margin-bottom:4px; letter-spacing:0.06em;">RELEASE DATE</div>
                    <div style="font-size:14px; font-weight:600;">${new Date(m.releaseDate).toLocaleDateString('en-IN')}</div>
                </div>`;

            const castMembers = m.cast.split(',').map(c => c.trim());
            document.getElementById('castSection').innerHTML = castMembers.map(c => `
                <div class="cast-card">
                    <div class="cast-avatar">🎭</div>
                    <div style="font-size:11px; font-weight:700; color:var(--text); text-align:center; line-height:1.3;">${c}</div>
                </div>`).join('');
        }

        // ── Reviews ───────────────────────────────────────────
        function hoverStar(val) {
            document.querySelectorAll('.star').forEach((s, i) => {
                s.style.color = i < val ? '#f59e0b' : '#333';
            });
        }

        function unhoverStar() {
            document.querySelectorAll('.star').forEach((s, i) => {
                s.style.color = i < selectedRating ? '#f59e0b' : '#333';
            });
        }

        function selectStar(val) {
            selectedRating = val;
            unhoverStar();
        }

        function buildStars() {
            document.getElementById('starRating').innerHTML = [1,2,3,4,5].map(i => `
                <span class="star"
                    onmouseover="hoverStar(${i})"
                    onmouseout="unhoverStar()"
                    onclick="selectStar(${i})">★</span>
            `).join('');
        }

        async function loadReviews() {
            try {
                const headers = token ? { 'Authorization': `Bearer ${token}` } : {};
                const res = await fetch(`/api/reviews/movie/${movieId}`, { headers });
                const data = await res.json();

                if (data.success) {
                    renderReviews(data.data);
                    if (token) {
                        const myReview = data.data.find(r => r.isMyReview);
                        if (myReview) {
                            myReviewId = myReview.id;
                            document.getElementById('writeReviewSection').style.display = 'none';
                        }
                    }
                } else {
                    renderReviews([]);
                }
            } catch { renderReviews([]); }
        }

        function renderReviews(reviews) {
            if (!reviews.length) {
                document.getElementById('reviewsList').innerHTML = `
                    <div style="text-align:center; padding:30px; color:var(--muted); font-size:14px;
                                background:var(--surface); border:1px solid var(--border); border-radius:12px;">
                        No reviews yet. Be the first to review!
                    </div>`;
                document.getElementById('avgRatingBadge').style.display = 'none';
                return;
            }

            const avg = (reviews.reduce((s, r) => s + r.rating, 0) / reviews.length).toFixed(1);
            document.getElementById('avgRating').textContent = avg;
            document.getElementById('totalReviews').textContent =
                `${reviews.length} review${reviews.length > 1 ? 's' : ''}`;
            document.getElementById('avgRatingBadge').style.display = 'flex';

            document.getElementById('reviewsList').innerHTML = reviews.map(r => {
                const stars = '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating);
                const initials = r.userName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2);
                return `
                <div style="background:var(--surface); border:1px solid ${r.isMyReview ? 'rgba(229,9,20,0.3)' : 'var(--border)'};
                            border-radius:12px; padding:18px; margin-bottom:10px;">
                    <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:10px;">
                        <div style="display:flex; align-items:center; gap:12px;">
                            <div style="width:38px; height:38px; border-radius:50%; background:var(--red);
                                        display:flex; align-items:center; justify-content:center;
                                        font-size:13px; font-weight:700; flex-shrink:0; color:white;">
                                ${initials}
                            </div>
                            <div>
                                <div style="font-size:14px; font-weight:600; display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                                    ${r.userName}
                                    ${r.isMyReview ? '<span style="font-size:11px; color:var(--red); font-weight:700;">YOU</span>' : ''}
                                    ${r.isVerifiedBooking ? '<span style="font-size:11px; background:rgba(34,197,94,0.15); color:#4ade80; border:1px solid rgba(34,197,94,0.2); padding:1px 8px; border-radius:10px;">✅ Verified</span>' : ''}
                                </div>
                                <div style="font-size:11px; color:var(--muted); margin-top:2px;">${formatDateStr(r.createdAt)}</div>
                            </div>
                        </div>
                        <div style="display:flex; align-items:center; gap:10px;">
                            <div style="color:#f59e0b; font-size:18px; letter-spacing:1px;">${stars}</div>
                            ${r.isMyReview ? `<button onclick="deleteReview('${r.id}')" style="background:none; border:none; color:#f87171; font-size:16px; cursor:pointer;">🗑</button>` : ''}
                        </div>
                    </div>
                    ${r.comment ? `<div style="font-size:14px; color:#ccc; line-height:1.7; padding-left:50px;">${r.comment}</div>` : ''}
                </div>`;
            }).join('');
        }

        async function submitReview() {
            if (!selectedRating) { showReviewAlert('Please select a star rating ⭐', 'error'); return; }
            const comment = document.getElementById('reviewComment').value.trim();
            try {
                const res = await fetch('/api/reviews', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({ movieId, rating: selectedRating, comment })
                });
                const data = await res.json();
                if (data.success) {
                    showReviewAlert('Review submitted! ✅', 'success');
                    selectedRating = 0;
                    document.getElementById('reviewComment').value = '';
                    document.getElementById('writeReviewSection').style.display = 'none';
                    await loadReviews();
                } else {
                    showReviewAlert(data.message || 'Failed to submit', 'error');
                }
            } catch { showReviewAlert('Something went wrong', 'error'); }
        }

        async function deleteReview(id) {
            if (!confirm('Delete your review?')) return;
            try {
                const res = await fetch(`/api/reviews/${id}`, {
                    method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await res.json();
                if (data.success) { myReviewId = null; selectedRating = 0; await loadReviews(); }
            } catch {}
        }

        function showReviewAlert(msg, type) {
            const el = document.getElementById('reviewAlert');
            el.textContent = msg;
            el.style.color = type === 'error' ? '#f87171' : '#4ade80';
            el.style.display = 'block';
            setTimeout(() => el.style.display = 'none', 3000);
        }

        loadMovie();
        loadReviews();
    </script>
</body>
</html>