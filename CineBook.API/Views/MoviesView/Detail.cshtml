@{
    ViewData["Title"] = "Movie Detail";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineBook — Movie Detail</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body{font-family:'Outfit',sans-serif;}.brand{font-family:'Bebas Neue',sans-serif;letter-spacing:.06em;}
        #toast-container{position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none;}
        .toast{pointer-events:all;min-width:260px;max-width:340px;background:#141414;border:1px solid #2a2a2a;border-radius:12px;padding:14px 18px;display:flex;align-items:flex-start;gap:12px;box-shadow:0 8px 32px rgba(0,0,0,.6);animation:tIn .35s cubic-bezier(.34,1.56,.64,1) forwards;font-size:14px;color:#fff;}
        .toast.removing{animation:tOut .25s ease forwards;}
        .toast-success{border-left:3px solid #22c55e;}.toast-error{border-left:3px solid #E50914;}.toast-info{border-left:3px solid #3b82f6;}
        @@keyframes tIn{from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)}}
        @@keyframes tOut{from{opacity:1;transform:translateX(0)}to{opacity:0;transform:translateX(100px)}}
        @@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
        .fade-up{animation:fadeUp .4s ease forwards;}
        .hero-trailer-iframe{position:absolute;inset:0;width:100%;height:100%;border:none;display:none;}
        .star{font-size:28px;cursor:pointer;color:#333;transition:color .15s;user-select:none;}
        .user-dropdown{display:none;}.user-dropdown.show{display:block;}
        @@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
        .fade-in{animation:fadeIn .3s ease forwards;}
        .cast-scroll{scrollbar-width:none;}.cast-scroll::-webkit-scrollbar{display:none;}
    </style>
</head>
<body class="bg-[#080808] text-[#f5f5f5] min-h-screen">
<div id="toast-container"></div>

<!-- Navbar -->
<nav class="fixed top-0 left-0 right-0 h-16 z-50 bg-[#080808]/95 border-b border-[#282828] flex items-center px-4 sm:px-8 gap-4 backdrop-blur-xl">
    <button onclick="history.back()" class="text-[#888] hover:text-white text-xl p-1 transition-colors">←</button>
    <a href="/" class="no-underline"><span class="brand text-2xl sm:text-3xl text-[#E50914]">CINEBOOK</span></a>
    <div class="flex-1"></div>
    <div id="guestNav"><a href="/Auth/Login" class="bg-[#E50914] hover:bg-[#b20710] text-white font-semibold text-sm px-4 py-2 rounded-lg transition-colors">Sign In</a></div>
    <div id="userNav" class="hidden">
        <div class="relative">
            <div id="userAvatar" onclick="toggleDropdown()" class="w-9 h-9 rounded-full bg-[#E50914] flex items-center justify-center text-sm font-bold cursor-pointer select-none">?</div>
            <div id="userDropdown" class="user-dropdown absolute top-[calc(100%+10px)] right-0 w-48 bg-[#141414] border border-[#282828] rounded-xl p-2 z-50 shadow-2xl">
                <div class="px-3 py-2 border-b border-[#282828] mb-2"><div class="text-sm font-semibold" id="dropdownName"></div></div>
                <a class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-[#777] hover:bg-[#1a1a1a] hover:text-white transition-all" href="/Profile">👤 My Profile</a>
                <a class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-[#777] hover:bg-[#1a1a1a] hover:text-white transition-all" href="/Bookings">🎟 My Bookings</a>
                <button onclick="logout()" class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-[#f87171] hover:bg-[#1a1a1a] transition-all">🚪 Sign Out</button>
            </div>
        </div>
    </div>
</nav>
<!-- Hero — auto height, grows with content, no clipping -->
<div class="mt-16 relative overflow-hidden bg-[#141414]" id="movieHero">
    <div class="flex items-center justify-center py-24 text-[#555]"><div class="text-4xl">🎬</div></div>
</div>

<!-- Main -->
<div class="max-w-5xl mx-auto px-4 sm:px-8 py-10">

    <div id="movieInfoSection" class="hidden mb-12 fade-up">
        <div class="flex flex-col lg:flex-row gap-8">
            <div class="flex-1">
                <div class="text-sm sm:text-base text-[#aaa] leading-relaxed mb-6" id="movieDesc"></div>
                <div class="grid grid-cols-2 gap-3 mb-6" id="movieMeta"></div>
            </div>
            <div class="lg:w-72 flex-shrink-0">
                <div class="text-xs font-bold text-[#888] tracking-widest mb-3">CAST</div>
                <div class="cast-scroll flex gap-3 overflow-x-auto pb-2" id="castSection"></div>
            </div>
        </div>
    </div>

    <!-- Reviews -->
    <div id="reviewsSection" class="mb-12">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
            <div class="text-lg font-bold flex items-center gap-2 before:content-[''] before:w-0.5 before:h-5 before:bg-[#E50914] before:rounded">Reviews & Ratings</div>
            <div id="avgRatingBadge" class="hidden items-baseline gap-2">
                <span class="text-3xl font-bold text-[#f59e0b]" id="avgRating">0.0</span>
                <span class="text-sm text-[#777]" id="totalReviews">0 reviews</span>
            </div>
        </div>
        <div id="writeReviewSection" class="hidden mb-6">
            <div class="bg-[#111] border border-[#282828] rounded-2xl p-5 sm:p-6">
                <div class="text-sm font-semibold mb-4">✍ Write a Review</div>
                <div class="mb-4"><div class="text-xs text-[#888] mb-2 tracking-widest">YOUR RATING *</div><div id="starRating" class="flex gap-1"></div></div>
                <textarea id="reviewComment" placeholder="Share your thoughts about this movie... (optional)"
                    class="w-full bg-[#1a1a1a] border border-[#282828] rounded-xl p-3.5 text-sm text-white outline-none resize-none min-h-[90px] transition-colors focus:border-[#E50914] mb-4"
                    style="font-family:'Outfit',sans-serif;"></textarea>
                <div class="flex items-center gap-3">
                    <button onclick="submitReview()" class="bg-[#E50914] hover:bg-[#b20710] text-white font-semibold text-sm px-6 py-2.5 rounded-xl transition-all">Submit Review</button>
                    <div id="reviewAlert" class="text-sm hidden"></div>
                </div>
            </div>
        </div>
        <div id="loginToReview" class="hidden mb-6">
            <div class="bg-[#111] border border-[#282828] rounded-2xl p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
                <div class="text-sm text-[#777]">Sign in to write a review</div>
                <a href="/Auth/Login" class="bg-[#E50914] hover:bg-[#b20710] text-white font-semibold text-sm px-5 py-2 rounded-xl transition-all">Sign In</a>
            </div>
        </div>
        <div id="reviewsList"><div class="text-center py-8 text-[#555]">Loading reviews...</div></div>
    </div>
</div>

<script>
function showToast(msg,type='info',duration=4000){const icons={success:'✓',error:'✕',info:'ℹ'};const colors={success:'#22c55e',error:'#E50914',info:'#3b82f6'};const c=document.getElementById('toast-container');const t=document.createElement('div');t.className=`toast toast-${type}`;t.innerHTML=`<div style="width:22px;height:22px;border-radius:50%;background:${colors[type]}20;border:1px solid ${colors[type]}50;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px;color:${colors[type]};font-weight:700;">${icons[type]||'ℹ'}</div><div style="flex:1;line-height:1.5;">${msg}</div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#555;cursor:pointer;font-size:18px;padding:0;">✕</button>`;c.appendChild(t);setTimeout(()=>{t.classList.add('removing');setTimeout(()=>t.remove(),250);},duration);}

const token=localStorage.getItem('token');const user=JSON.parse(localStorage.getItem('user')||'{}');
const movieId=window.location.pathname.split('/').pop();
let selectedRating=0,isFavourited=false,trailerEmbedUrl='';

function initAuthUI(){
    if(token&&user.fullName){
        document.getElementById('guestNav').style.display='none';
        document.getElementById('userNav').classList.remove('hidden');
        document.getElementById('userNav').style.display='block';
        document.getElementById('userAvatar').textContent=user.fullName.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
        document.getElementById('dropdownName').textContent=user.fullName;
        document.getElementById('writeReviewSection').classList.remove('hidden');
        buildStars();
    }else{document.getElementById('loginToReview').classList.remove('hidden');}
}
function toggleDropdown(){document.getElementById('userDropdown').classList.toggle('show');}
document.addEventListener('click',e=>{if(!e.target.closest('#userAvatar')&&!e.target.closest('#userDropdown'))document.getElementById('userDropdown')?.classList.remove('show');});
function logout(){localStorage.clear();window.location.href='/Auth/Login';}

async function loadMovie(){
    try{const res=await fetch(`/api/movies/${movieId}`);const data=await res.json();if(data.success){renderHero(data.data);renderMovieInfo(data.data);}}
    catch{showToast('Failed to load movie','error');}
}

function renderHero(m){
    let trailerHtml='';
    if(m.trailerUrl){
        let vid='';
        try{
            if(m.trailerUrl.includes('youtu.be/'))vid=m.trailerUrl.split('youtu.be/')[1].split('?')[0];
            else if(m.trailerUrl.includes('youtube.com/watch'))vid=new URL(m.trailerUrl).searchParams.get('v');
        }catch{}
        if(vid){
            trailerEmbedUrl=`https://www.youtube.com/embed/${vid}?autoplay=1&rel=0&modestbranding=1`;
            const thumb=`https://img.youtube.com/vi/${vid}/maxresdefault.jpg`;
            /* Trailer — shown on ALL screens.
               Mobile: full width below text, mt-5
               sm+: fixed width beside text */
            trailerHtml=`
                <div class="relative w-full sm:w-[340px] md:w-[400px] lg:w-[460px] flex-shrink-0
                             h-[200px] sm:h-[220px] md:h-[260px]
                             mt-5 sm:mt-0
                             rounded-2xl overflow-hidden bg-black border border-white/15 shadow-2xl" id="trailerBox">
                    <img id="trailerThumb" src="${thumb}" class="w-full h-full object-cover opacity-60" onerror="this.src='${m.posterUrl||''}'" />
                    <div id="trailerOverlay" class="absolute inset-0 flex items-center justify-center cursor-pointer bg-black/20 hover:bg-black/40 transition-all" onclick="playTrailer()">
                        <div class="w-14 h-14 rounded-full bg-[#E50914]/90 border-[3px] border-white flex items-center justify-center hover:scale-110 hover:shadow-[0_0_40px_rgba(229,9,20,.5)] transition-all">
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                        </div>
                    </div>
                    <div class="absolute bottom-2.5 left-3 text-[10px] font-bold text-white/60 tracking-widest pointer-events-none">OFFICIAL TRAILER</div>
                    <iframe id="trailerIframe" class="hero-trailer-iframe" allow="autoplay;encrypted-media;fullscreen" allowfullscreen></iframe>
                </div>`;
        }
    }

    const genres=m.genre.split(',').map(g=>`<span class="inline-flex px-2.5 py-0.5 rounded-full bg-white/8 border border-white/10 text-xs text-[#bbb]">${g.trim()}</span>`).join('');

    document.getElementById('movieHero').innerHTML=`
        ${m.posterUrl?`<img class="absolute inset-0 w-full h-full object-cover" style="filter:brightness(.18);transform:scale(1.05)" src="${m.posterUrl}" />`:''}
        <div class="absolute inset-0" style="background:linear-gradient(to right,rgba(8,8,8,.99) 0%,rgba(8,8,8,.75) 50%,rgba(8,8,8,.2) 100%),linear-gradient(to top,rgba(8,8,8,1) 0%,transparent 55%)"></div>

        <!-- Content wrapped in same max-width/padding as the description section below -->
        <div class="relative max-w-6xl mx-auto w-full flex flex-col sm:flex-row sm:items-center px-4 sm:px-8 py-8 sm:py-12 lg:py-14 gap-100 sm:gap-6 lg:gap-10 lg:mt-16">

            <!-- Poster — small on mobile, bigger on sm+ -->
            <img src="${m.posterUrl||''}" alt="${m.title}"
                class="rounded-xl object-cover shadow-2xl border border-white/10 self-start sm:self-center flex-shrink-0
                       w-20 sm:w-36 lg:w-44"
                style="aspect-ratio:2/3;max-height:280px;"
                onerror="this.style.display='none'" />

            <!-- Text -->
            <div class="flex-1 flex flex-col gap-2 sm:gap-3 min-w-0">
                <div class="flex flex-wrap items-center gap-1.5 sm:gap-2">
                    <span class="bg-white/10 border border-white/20 text-[#ccc] text-xs font-bold px-2 py-0.5 rounded">${m.certificateRating}</span>
                    ${genres}
                </div>
                <h1 class="brand text-3xl sm:text-4xl lg:text-6xl leading-none">${m.title}</h1>
                <div class="flex flex-wrap items-center gap-2 sm:gap-3 text-xs sm:text-sm text-[#aaa]">
                    <span>⏱ ${m.durationTime} min</span>
                    <span class="w-1 h-1 rounded-full bg-[#555]"></span>
                    <span>🌐 ${m.language}</span>
                    <span class="w-1 h-1 rounded-full bg-[#555]"></span>
                    <span>🎬 ${m.director}</span>
                </div>
                <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
                    <a href="/Movies/${movieId}/Book"
                        class="bg-[#E50914] hover:bg-[#b20710] text-white font-bold text-sm sm:text-base px-5 sm:px-7 py-2.5 sm:py-3 rounded-xl transition-all hover:shadow-[0_8px_24px_rgba(229,9,20,.3)] hover:-translate-y-0.5 inline-flex items-center gap-2">
                        🎟 Book Tickets
                    </a>
                    <button id="favBtn" onclick="toggleFavourite()"
                        class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white/10 border-2 border-white/20 text-xl sm:text-2xl flex items-center justify-center hover:bg-white/20 transition-all">
                        🤍
                    </button>
                </div>
            </div>

            <!-- Trailer (ALL screens — stacks below on mobile, beside on sm+) -->
            ${trailerHtml}
        </div>`;

    checkFavourite();
}

function playTrailer(){
    if(!trailerEmbedUrl)return;
    document.getElementById('trailerThumb').style.display='none';
    document.getElementById('trailerOverlay').style.display='none';
    const iframe=document.getElementById('trailerIframe');iframe.src=trailerEmbedUrl;iframe.style.display='block';
}

function renderMovieInfo(m){
    document.getElementById('movieInfoSection').classList.remove('hidden');
    document.getElementById('movieDesc').textContent=m.description;
    document.getElementById('movieMeta').innerHTML=[
        ['DIRECTOR',m.director],['DURATION',`${m.durationTime} minutes`],['LANGUAGE',m.language],['RELEASE DATE',new Date(m.releaseDate).toLocaleDateString('en-IN')]
    ].map(([l,v])=>`<div class="bg-[#111] border border-[#282828] rounded-xl p-4"><div class="text-xs text-[#888] tracking-widest mb-1.5">${l}</div><div class="text-sm font-semibold">${v}</div></div>`).join('');
    document.getElementById('castSection').innerHTML=m.cast.split(',').map(c=>`
        <div class="flex-shrink-0 w-20 text-center">
            <div class="w-14 h-14 rounded-full bg-[#222] border-2 border-[#282828] flex items-center justify-center text-2xl mx-auto mb-2">🎭</div>
            <div class="text-xs font-semibold leading-tight">${c.trim()}</div>
        </div>`).join('');
}

async function checkFavourite(){
    if(!token)return;
    try{const res=await fetch('/api/favourites/ids',{headers:{'Authorization':`Bearer ${token}`}});const data=await res.json();if(data.success){isFavourited=data.data.includes(movieId);updateFavBtn();}}catch{}
}
function updateFavBtn(){
    const btn=document.getElementById('favBtn');if(!btn)return;
    btn.textContent=isFavourited?'❤️':'🤍';
    btn.style.background=isFavourited?'rgba(229,9,20,.25)':'rgba(255,255,255,.1)';
    btn.style.borderColor=isFavourited?'rgba(229,9,20,.6)':'rgba(255,255,255,.2)';
}
async function toggleFavourite(){
    if(!token){window.location.href='/Auth/Login';return;}
    try{const res=await fetch(`/api/favourites/toggle/${movieId}`,{method:'POST',headers:{'Authorization':`Bearer ${token}`,'Content-Type':'application/json'}});const data=await res.json();if(data.success){isFavourited=data.data.isFavourited??data.data;updateFavBtn();showToast(isFavourited?'Added to favourites ❤️':'Removed from favourites',isFavourited?'success':'info',2500);}}catch{}
}

function hoverStar(v){document.querySelectorAll('.star').forEach((s,i)=>s.style.color=i<v?'#f59e0b':'#333');}
function unhoverStar(){document.querySelectorAll('.star').forEach((s,i)=>s.style.color=i<selectedRating?'#f59e0b':'#333');}
function selectStar(v){selectedRating=v;unhoverStar();}
function buildStars(){document.getElementById('starRating').innerHTML=[1,2,3,4,5].map(i=>`<span class="star" onmouseover="hoverStar(${i})" onmouseout="unhoverStar()" onclick="selectStar(${i})">★</span>`).join('');}
function formatDate(iso){if(!iso)return'';const[yr,mo,dy]=iso.split('T')[0].split('-');return new Date(parseInt(yr),parseInt(mo)-1,parseInt(dy)).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'});}

async function loadReviews(){
    try{const headers=token?{'Authorization':`Bearer ${token}`}:{};const res=await fetch(`/api/reviews/movie/${movieId}`,{headers});const data=await res.json();
        if(data.success){renderReviews(data.data);if(token){const mine=data.data.find(r=>r.isMyReview);if(mine)document.getElementById('writeReviewSection').classList.add('hidden');}}
        else renderReviews([]);
    }catch{renderReviews([]);}
}

function renderReviews(reviews){
    if(!reviews.length){document.getElementById('reviewsList').innerHTML=`<div class="text-center py-8 bg-[#111] border border-[#282828] rounded-2xl text-sm text-[#777]">No reviews yet. Be the first to review!</div>`;document.getElementById('avgRatingBadge').classList.add('hidden');return;}
    const avg=(reviews.reduce((s,r)=>s+r.rating,0)/reviews.length).toFixed(1);
    document.getElementById('avgRating').textContent=avg;
    document.getElementById('totalReviews').textContent=`${reviews.length} review${reviews.length>1?'s':''}`;
    document.getElementById('avgRatingBadge').classList.remove('hidden');document.getElementById('avgRatingBadge').style.display='flex';
    document.getElementById('reviewsList').innerHTML=reviews.map(r=>{
        const stars='★'.repeat(r.rating)+'☆'.repeat(5-r.rating);
        const initials=r.userName.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
        return`<div class="fade-in bg-[#111] border ${r.isMyReview?'border-[#E50914]/30':'border-[#282828]'} rounded-2xl p-5 mb-3">
            <div class="flex items-start justify-between gap-3 mb-3">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-[#E50914] flex items-center justify-center text-sm font-bold flex-shrink-0">${initials}</div>
                    <div>
                        <div class="text-sm font-semibold flex flex-wrap items-center gap-2">
                            ${r.userName}
                            ${r.isMyReview?'<span class="text-xs text-[#E50914] font-bold">YOU</span>':''}
                            ${r.isVerifiedBooking?'<span class="text-xs text-green-400 bg-green-400/10 border border-green-400/20 px-2 py-0.5 rounded-full">✅ Verified</span>':''}
                        </div>
                        <div class="text-xs text-[#555] mt-0.5">${formatDate(r.createdAt)}</div>
                    </div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                    <div class="text-yellow-400 text-lg tracking-wide">${stars}</div>
                    ${r.isMyReview?`<button onclick="deleteReview('${r.id}')" class="text-[#f87171] hover:text-red-400 transition-colors text-lg">🗑</button>`:''}
                </div>
            </div>
            ${r.comment?`<div class="text-sm text-[#ccc] leading-relaxed pl-[52px]">${r.comment}</div>`:''}
        </div>`;
    }).join('');
}

async function submitReview(){
    if(!selectedRating){showToast('Please select a star rating ⭐','error');return;}
    const comment=document.getElementById('reviewComment').value.trim();
    try{const res=await fetch('/api/reviews',{method:'POST',headers:{'Content-Type':'application/json','Authorization':`Bearer ${token}`},body:JSON.stringify({movieId,rating:selectedRating,comment})});const data=await res.json();
        if(data.success){showToast('✅ Review submitted!','success');selectedRating=0;document.getElementById('reviewComment').value='';document.getElementById('writeReviewSection').classList.add('hidden');await loadReviews();}
        else showToast(data.message||'Failed to submit','error');
    }catch{showToast('Something went wrong','error');}
}
async function deleteReview(id){
    if(!confirm('Delete your review?'))return;
    try{const res=await fetch(`/api/reviews/${id}`,{method:'DELETE',headers:{'Authorization':`Bearer ${token}`}});const data=await res.json();
        if(data.success){showToast('Review deleted','info');selectedRating=0;await loadReviews();document.getElementById('writeReviewSection').classList.remove('hidden');buildStars();}
    }catch{}
}

initAuthUI();loadMovie();loadReviews();
</script>
</body>
</html>